<%# app/views/documents_portal/audit_report.html.erb
    Audit & Reports — Forensic Workstation
    System Design & UI Behavior Specification v1.0 %>

<%= render 'docs/doc_styles' %>

<style>
/* ── Audit-specific extensions ── */

/* Health ribbon tile */
.dp-health-tile {
  background: #0d2137;
  border-radius: 8px;
  padding: 14px 18px;
  display: flex;
  flex-direction: column;
  gap: 4px;
  min-width: 160px;
  flex: 1;
}
.dp-health-tile .ht-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  color: #90a4b7;
}
.dp-health-tile .ht-value {
  font-size: 22px;
  font-weight: 700;
  color: #64b5f6;
  font-family: var(--font-mono);
}
.dp-health-tile .ht-value.ok     { color: #66bb6a; }
.dp-health-tile .ht-value.warn   { color: #ffb74d; }
.dp-health-tile .ht-value.alert  { color: #ef5350; }
.dp-health-tile .ht-sub {
  font-size: 11px;
  color: #607d8b;
}
.dp-health-bar {
  background: #0d2137;
  border-bottom: 2px solid #1a3a5c;
  border-radius: 8px;
  padding: 12px 18px;
  display: flex;
  gap: 14px;
  flex-wrap: wrap;
  margin-bottom: 18px;
}

/* Registry / ledger pane indicators */
.dp-ledger-label {
  font-size: 10px;
  font-weight: 700;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  padding: 3px 10px;
  border-radius: 3px;
  display: inline-block;
  margin-bottom: 8px;
}
.dp-ledger-label.monetary   { background: #e8eaf6; color: #1a237e; border: 1px solid #9fa8da; }
.dp-ledger-label.operational { background: #e0f2f1; color: #004d40; border: 1px solid #80cbc4; }

/* Integrity status dot */
.dp-integrity-dot {
  display: inline-block;
  width: 10px;
  height: 10px;
  border-radius: 50%;
  margin-right: 6px;
  vertical-align: middle;
}
.dp-integrity-dot.synced   { background: #4caf50; }
.dp-integrity-dot.syncing  { background: #ffb74d; }
.dp-integrity-dot.diverged { background: #ef5350; }

/* HSM validation badge */
.dp-hsm-badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  padding: 3px 10px;
  border-radius: 3px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.dp-hsm-badge.validated    { background: #1b5e20; color: white; }
.dp-hsm-badge.not-validated { background: #b71c1c; color: white; }
.dp-hsm-badge.pending       { background: #e8e8e8; color: #666; }

/* Four-eyes row */
.dp-four-eyes {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 10px;
  margin: 10px 0;
}
.dp-four-eyes-cell {
  background: #f4f6fb;
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 8px 12px;
  font-size: 12px;
}
.dp-four-eyes-cell .fe-label {
  font-size: 10px;
  font-weight: 700;
  color: var(--text-muted);
  letter-spacing: 0.05em;
  text-transform: uppercase;
  margin-bottom: 3px;
}
.dp-four-eyes-cell .fe-value {
  font-family: var(--font-mono);
  font-size: 12px;
  color: var(--navy);
  font-weight: 600;
}

/* Velocity anomaly badge */
.dp-velocity-badge {
  background: #fff3e0;
  border: 1px solid #ffe0b2;
  border-radius: 4px;
  padding: 6px 12px;
  font-size: 11px;
  color: #e65100;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 8px;
}
.dp-velocity-badge .vb-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: #ef5350;
  flex-shrink: 0;
  animation: pulse-red 1.2s infinite;
}
@keyframes pulse-red {
  0%, 100% { opacity: 1; transform: scale(1); }
  50%       { opacity: 0.5; transform: scale(1.35); }
}

/* Registry divergence banner */
.dp-diverge-banner {
  background: #b71c1c;
  color: white;
  padding: 10px 18px;
  border-radius: 6px;
  font-size: 12px;
  font-weight: 600;
  display: flex;
  align-items: center;
  gap: 10px;
  margin: 10px 0;
  letter-spacing: 0.03em;
}

/* Report type selector */
.dp-report-chip {
  display: inline-block;
  font-size: 11px;
  font-weight: 600;
  padding: 4px 12px;
  border-radius: 20px;
  border: 1px solid #c5cdd5;
  background: #f0f4f8;
  color: #455a64;
  margin: 3px 4px 3px 0;
  cursor: default;
}
.dp-report-chip.active {
  background: #0d2137;
  color: white;
  border-color: #0d2137;
}

/* JSON block (reuse governance style) */
.dp-json-block {
  background: #1e1e1e;
  color: #d4d4d4;
  font-family: var(--font-mono);
  font-size: 11px;
  padding: 14px 18px;
  border-radius: 6px;
  margin: 10px 0 14px;
  line-height: 1.7;
  overflow-x: auto;
}
.dp-json-block .jk { color: #9cdcfe; }
.dp-json-block .jv { color: #ce9178; }
.dp-json-block .jn { color: #b5cea8; }
.dp-json-block .jb { color: #569cd6; }

.dp-badge {
  display: inline-block;
  font-size: 10px;
  font-weight: 700;
  padding: 2px 8px;
  border-radius: 3px;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.dp-badge.teal   { background: #e0f7fa; color: #006064; border: 1px solid #80deea; }
.dp-badge.navy   { background: #e8eaf6; color: #1a237e; border: 1px solid #9fa8da; }
.dp-badge.amber  { background: #fff8e1; color: #e65100; border: 1px solid #ffe082; }
.dp-badge.green  { background: #e8f5e9; color: #1b5e20; border: 1px solid #a5d6a7; }
.dp-badge.red    { background: #fce4ec; color: #b71c1c; border: 1px solid #ef9a9a; }
</style>

