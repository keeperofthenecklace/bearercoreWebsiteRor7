      <div class="dp-section-header">
        <div class="dp-section-num">§5</div>
        <h2>End-to-End User Interaction Flow</h2>
      </div>

      <h3>Forensic Investigation — Velocity Anomaly</h3>
      <div class="dp-table-wrap"><table class="dp-table">
        <thead><tr><th>Step</th><th>User action</th><th>System response</th></tr></thead>
        <tbody>
          <tr>
            <td>1</td>
            <td>Auditor notices Active Alerts = 7 (red) in the health ribbon on tab entry</td>
