    <span class="jk">"authorizer_2"</span>: <span class="jv">"GOV-DPT-03"</span>
  }
}
      </div>

      <h3>GET /api/v2/audit/events/export</h3>
      <p>Returns a CSV string in <code>data.csv</code>. Max 5,000 rows. Same filter params as index.</p>

      <h3>GET /api/v2/audit/health_metrics</h3>
      <p>Powers the health ribbon. Optional <code>?jurisdiction=KEN</code> to scope calculations.</p>
      <div class="dp-json-block">
<span class="jk">"data"</span>: {
  <span class="jk">"supply_integrity"</span>: <span class="jv">"99.2%"</span>,
  <span class="jk">"pending_verifications"</span>: <span class="jn">3</span>,
  <span class="jk">"active_alerts"</span>: <span class="jn">7</span>
}
      </div>

      <h3>POST /api/v2/audit/verify_signature</h3>
      <div class="dp-json-block">
<span class="jv">/* Request */</span>
{
