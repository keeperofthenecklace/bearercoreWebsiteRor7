          <tr><td class="f">serial_number</td><td class="t">string</td><td>Unique serial from SerialAllocationService</td></tr>
          <tr><td class="f">cbdc_batch_id</td><td class="t">uuid FK</td><td>Parent batch</td></tr>
          <tr><td class="f">denomination</td><td class="t">decimal</td><td>Face value in corridor asset currency</td></tr>
          <tr><td class="f">status</td><td class="t">enum</td><td><code>minted</code> | <code>issued</code> | <code>transferred</code> | <code>redeemed</code> | <code>burned</code></td></tr>
          <tr><td class="f">current_holder_id</td><td class="t">string</td><td>Current holder's DID or wallet identifier</td></tr>
          <tr><td class="f">blockchain_hash</td><td class="t">string</td><td>Ed25519 signed payload hash for verification</td></tr>
