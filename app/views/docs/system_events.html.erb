<%= render 'docs/doc_styles' %>

<style>
/* ── System Events–specific extensions ── */

/* Severity badge row in the event stream */
.se-sev {
  display: inline-block;
  font-size: 9px;
  font-weight: 800;
  padding: 2px 7px;
  border-radius: 3px;
  letter-spacing: 0.08em;
  text-transform: uppercase;
  font-family: var(--font-mono);
}
.se-sev.info     { background: #e0f7fa; color: #006064; border: 1px solid #80deea; }
.se-sev.warn     { background: #fff8e1; color: #e65100; border: 1px solid #ffe082; }
.se-sev.error    { background: #fce4ec; color: #b71c1c; border: 1px solid #ef9a9a; }
.se-sev.audit    { background: #1a1200; color: #ffd700; border: 1px solid #7d6608; }
.se-sev.critical { background: #b71c1c; color: #fff; border: 1px solid #7f0000; }

/* Node health card */
.se-node-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(160px, 1fr));
  gap: 10px;
  margin: 12px 0 20px;
}
.se-node-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  padding: 12px 14px;
  font-size: 12px;
}
.se-node-card .node-name {
  font-weight: 700;
  color: var(--navy);
  margin-bottom: 4px;
  font-size: 12px;
}
.se-node-card .node-status {
  display: flex;
  align-items: center;
  gap: 6px;
  margin-bottom: 6px;
}
.se-dot { width: 8px; height: 8px; border-radius: 50%; flex-shrink: 0; }
.se-dot.green  { background: #4caf50; box-shadow: 0 0 4px rgba(76,175,80,0.5); }
.se-dot.amber  { background: #ffb74d; box-shadow: 0 0 4px rgba(255,183,77,0.5); }
.se-dot.red    { background: #ef5350; box-shadow: 0 0 4px rgba(239,83,80,0.5); }
.se-node-card .node-stat { color: var(--text-muted); font-size: 11px; line-height: 1.7; }

/* Terminal log row mockup */
.se-terminal {
  background: #0d0d0d;
  border: 1px solid #2a2a2a;
  border-radius: 6px;
  padding: 0;
  overflow: hidden;
  margin: 10px 0 16px;
}
.se-terminal-bar {
  background: #1a1a1a;
  padding: 6px 14px;
  font-size: 11px;
  color: #666;
  display: flex;
  align-items: center;
  gap: 8px;
  border-bottom: 1px solid #2a2a2a;
}
.se-terminal-bar .live-dot {
  width: 6px; height: 6px; border-radius: 50%;
  background: #4caf50;
  box-shadow: 0 0 6px rgba(76,175,80,0.7);
  animation: pulse 1.5s infinite;
}
@keyframes pulse {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.3; }
}
.se-terminal-body { padding: 10px 14px; font-family: var(--font-mono); font-size: 11px; line-height: 1.9; }
.se-log-row { display: flex; gap: 12px; align-items: baseline; border-bottom: 1px solid #1a1a1a; padding: 2px 0; }
.se-log-row:last-child { border-bottom: none; }
.se-log-ts   { color: #555; min-width: 170px; flex-shrink: 0; }
.se-log-svc  { color: #6ea6e0; min-width: 90px; flex-shrink: 0; }
.se-log-msg.info  { color: #a0c4ff; }
.se-log-msg.warn  { color: #ffb74d; }
.se-log-msg.error { color: #ef5350; }
.se-log-msg.audit { color: #ffd700; }

/* Live-tail toggle button mockup */
.se-live-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  background: #0d2a0d;
  border: 1px solid #2e7d32;
  border-radius: 4px;
  color: #4caf50;
  font-size: 11px;
  font-weight: 700;
  font-family: var(--font-mono);
}

/* Metadata inspector card */
.se-meta-card {
  background: var(--bg-card);
  border: 1px solid var(--border);
  border-radius: 8px;
  overflow: hidden;
  margin: 10px 0 16px;
}
.se-meta-card-head {
  background: var(--navy);
  color: white;
  padding: 8px 16px;
  font-size: 11px;
  font-weight: 700;
  letter-spacing: 0.06em;
  text-transform: uppercase;
}
.se-meta-card-body { padding: 12px 16px; }
.se-meta-row {
  display: grid;
  grid-template-columns: 130px 1fr;
  gap: 4px 12px;
  font-size: 12px;
  margin-bottom: 5px;
}
.se-meta-lbl { color: var(--text-light); font-weight: 600; font-size: 11px; text-transform: uppercase; letter-spacing: 0.06em; }
.se-meta-val { color: var(--text); font-family: var(--font-mono); }

/* Audit-specific callout */
.dp-audit {
  background: #1a1200;
  border-left: 3px solid #ffd700;
  color: #ffd700;
  padding: 12px 16px;
  border-radius: 6px;
  margin-bottom: 14px;
  font-size: 13px;
  display: flex;
  gap: 10px;
}
.dp-audit .dp-ci { color: #ffd700; }
</style>

