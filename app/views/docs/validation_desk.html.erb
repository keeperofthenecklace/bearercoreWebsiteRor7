    <!-- ═══════════════════════════════════════════════════ §5 RIGHT PANE -->
    <div class="dp-section" id="right-pane">
      <div class="dp-section-header">
        <div class="dp-section-num">§5</div>
        <h2>Right Pane — Validation Controls &amp; Intelligence</h2>
      </div>

      <div class="dp-callout dp-warn"><span class="dp-ci">ℹ</span><div>Layout: QScrollArea, max width 320px, vertical scroll enabled. Ensures full panel usability on laptop screens without losing action buttons.</div></div>

      <h3>Security Evidence Panel — grpValEvidence</h3>
      <div class="dp-table-wrap"><table class="dp-table">
        <thead><tr><th>Badge</th><th>Widget</th><th>States</th></tr></thead>
        <tbody>
          <tr><td>Signature</td><td class="f">lblValSigBadge</td><td>✓ Valid (green) | ✗ Invalid (red) | ● Unknown (amber) | ○ Unverified (grey)</td></tr>
