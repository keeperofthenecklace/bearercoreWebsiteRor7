<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap');

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', Arial, sans-serif;
      color: #1a1a2e;
      font-size: 10.5pt;
      line-height: 1.65;
      background: #fff;
    }

    /* ── Cover ─────────────────────────────────────── */
    .cover {
      width: 100%;
      min-height: 100vh;
      background: #fff;
      page-break-after: always;
      display: flex;
      flex-direction: column;
      padding: 0;
    }
    .cover-inner {
      flex: 1;
      display: flex;
      justify-content: center;
      align-items: flex-start;
      padding: 64pt 60pt 40pt;
    }
    .cover-card {
      width: 68%;
      background: #0C1B38;
      padding: 34pt 44pt 28pt;
      border-bottom: 5pt solid #C9A84C;
      text-align: center;
    }
    .cover-eyebrow {
      font-size: 7.5pt;
      font-weight: 400;
      color: rgba(255,255,255,0.45);
      letter-spacing: 1px;
      margin-bottom: 18pt;
    }
    .cover-title {
      font-size: 30pt;
      font-weight: 700;
      color: #fff;
      line-height: 1.1;
      margin-bottom: 8pt;
    }
    .cover-title span { color: #C9A84C; }
    .cover-subtitle {
      font-size: 10.5pt;
      font-weight: 400;
      color: #C9A84C;
      margin-bottom: 18pt;
    }
    .cover-rule {
      width: 36pt;
      height: 1pt;
      background: rgba(255,255,255,0.2);
      margin: 0 auto 18pt;
    }
    .cover-meta {
      font-size: 8pt;
      color: rgba(255,255,255,0.4);
      line-height: 1.9;
    }

    /* ── Stat row (used on cover) ──────────────────── */
    .stat-row {
      display: table;
      width: 100%;
      background: #1A2B3C;
    }
    .stat {
      display: table-cell;
      width: 33%;
      text-align: center;
      padding: 22pt 10pt;
      border-right: 1pt solid rgba(255,255,255,0.07);
    }
    .stat:last-child { border-right: none; }
    .stat-number {
      font-size: 28pt;
      font-weight: 700;
      color: #C9A84C;
      display: block;
      line-height: 1.05;
    }
    .stat-label {
      font-size: 7pt;
      font-weight: 500;
      color: rgba(255,255,255,0.55);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      display: block;
      margin-top: 5pt;
    }

    /* ── Body pages ─────────────────────────────────── */
    .page {
      padding: 44pt 52pt 38pt;
      page-break-after: always;
    }
    .page:last-child { page-break-after: avoid; }

    .page-header {
      margin-bottom: 16pt;
    }
    .page-header-logo { display: none; }
    .page-header-label {
      font-size: 7.5pt;
      font-weight: 600;
      color: #888;
      text-transform: uppercase;
      letter-spacing: 2px;
    }

    h1 {
      font-size: 20pt;
      font-weight: 700;
      color: #1A2B3C;
      line-height: 1.2;
      margin-bottom: 0;
      padding-bottom: 10pt;
      border-bottom: 2pt solid #1A2B3C;
      margin-bottom: 18pt;
    }
    h2 {
      font-size: 11.5pt;
      font-weight: 700;
      color: #1A2B3C;
      margin-top: 20pt;
      margin-bottom: 8pt;
      padding-bottom: 5pt;
      border-bottom: 1pt solid #dde1ea;
    }
    h3 {
      font-size: 10.5pt;
      font-weight: 700;
      color: #1A2B3C;
      margin-top: 14pt;
      margin-bottom: 5pt;
    }
    p {
      margin-bottom: 10pt;
      color: #1a1a2e;
      text-align: justify;
    }
    ul, ol {
      margin: 0 0 12pt 18pt;
    }
    li {
      margin-bottom: 6pt;
      color: #1a1a2e;
      text-align: justify;
    }
    strong { color: #1A2B3C; }

    .lead {
      font-size: 10.5pt;
      color: #1A2B3C;
      line-height: 1.7;
      margin-bottom: 12pt;
      text-align: justify;
    }

    /* ── Callout ─────────────────────────────────────── */
    .callout {
      background: #f4f6fb;
      padding: 14pt 18pt;
      margin: 16pt 0;
      border-left: 3pt solid #1A2B3C;
    }
    .callout p { color: #1a1a2e; margin-bottom: 0; text-align: justify; }
    .callout strong { color: #1A2B3C; }

    /* ── Tables ──────────────────────────────────────── */
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 14pt 0;
      font-size: 9.5pt;
    }
    th {
      background: #1A2B3C;
      color: #C9A84C;
      font-size: 8pt;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 8pt 10pt;
      text-align: left;
      border: 1pt solid #1A2B3C;
    }
    td {
      padding: 7pt 10pt;
      border: 1pt solid #dde1ea;
      color: #1a1a2e;
    }
    tr:nth-child(even) td { background: #f8f9fc; }
    .tech-cell { background: #edf0f7 !important; }

    /* ── Governance threshold info box ───────────────── */
    .gauge-wrap {
      margin: 14pt 0 8pt;
      border: 1pt solid #dde1ea;
      padding: 14pt 18pt;
      text-align: center;
    }
    .gauge-label {
      font-size: 8.5pt;
      font-weight: 700;
      color: #1A2B3C;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 6pt;
    }
    .gauge-meta {
      font-size: 9pt;
      color: #444;
      text-align: center;
    }

    /* ── QR engagement block ─────────────────────────── */
    .qr-block {
      display: table;
      width: 100%;
      margin-top: 14pt;
      border: 1pt solid #dde1ea;
      padding: 16pt;
    }
    .qr-left {
      display: table-cell;
      vertical-align: middle;
      width: 86pt;
    }
    .qr-left img {
      width: 70pt;
      height: 70pt;
      display: block;
      border: 2pt solid #dde1ea;
    }
    .qr-right {
      display: table-cell;
      vertical-align: middle;
      padding-left: 16pt;
    }
    .qr-right p {
      color: #1a1a2e;
      margin-bottom: 5pt;
      font-size: 9.5pt;
      text-align: left;
    }
    .qr-right strong { color: #1A2B3C; font-size: 10.5pt; }
    .qr-right .qr-note {
      font-size: 7.5pt;
      color: #C9A84C;
      margin-bottom: 0;
      text-align: left;
    }

    /* ── Footer ──────────────────────────────────────── */
    .footer {
      font-size: 7pt;
      color: #aaa;
      text-align: center;
      margin-top: 28pt;
      padding-top: 8pt;
      border-top: 1pt solid #dde1ea;
    }
  </style>
</head>
<body>
  <%= yield %>
</body>
</html>
