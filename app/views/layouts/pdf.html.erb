<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:wght@700;800&display=swap');

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Inter', Arial, sans-serif;
      color: #2a2a3e;
      font-size: 10.5pt;
      line-height: 1.7;
      background: #fff;
    }

    /* ── Cover page ─────────────────────────────── */
    .cover {
      width: 100%;
      min-height: 100vh;
      background: #0C1B38;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: flex-start;
      padding: 72pt 64pt;
      page-break-after: always;
    }
    .cover-eyebrow {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 8pt;
      font-weight: 500;
      letter-spacing: 3px;
      text-transform: uppercase;
      color: #C9A84C;
      margin-bottom: 28pt;
    }
    .cover-title {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 36pt;
      font-weight: 800;
      color: #fff;
      line-height: 1.15;
      margin-bottom: 6pt;
    }
    .cover-title span { color: #C9A84C; }
    .cover-subtitle {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 13pt;
      font-weight: 300;
      color: rgba(255,255,255,0.65);
      margin-bottom: 48pt;
    }
    .cover-rule {
      width: 56pt;
      height: 3pt;
      background: #C9A84C;
      margin-bottom: 48pt;
    }
    .cover-meta {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 8.5pt;
      font-weight: 400;
      color: rgba(255,255,255,0.45);
      line-height: 1.8;
    }

    /* ── Body pages ─────────────────────────────── */
    .page {
      padding: 52pt 60pt 48pt 60pt;
      page-break-after: always;
    }
    .page:last-child { page-break-after: avoid; }

    .page-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      border-bottom: 1.5pt solid #C9A84C;
      padding-bottom: 8pt;
      margin-bottom: 32pt;
    }
    .page-header-logo {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 9pt;
      font-weight: 700;
      color: #1A2B3C;
      letter-spacing: 1px;
    }
    .page-header-logo span { color: #C9A84C; }
    .page-header-label {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 7.5pt;
      font-weight: 500;
      color: #999;
      letter-spacing: 2px;
      text-transform: uppercase;
    }

    h1 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 22pt;
      font-weight: 700;
      color: #1A2B3C;
      margin-bottom: 18pt;
      line-height: 1.2;
    }
    h2 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 14pt;
      font-weight: 700;
      color: #1A2B3C;
      margin-top: 28pt;
      margin-bottom: 10pt;
      padding-bottom: 5pt;
      border-bottom: 1pt solid #e8eaf0;
    }
    h3 {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 8.5pt;
      font-weight: 700;
      color: #2E7D32;
      margin-top: 18pt;
      margin-bottom: 6pt;
      text-transform: uppercase;
      letter-spacing: 1.5px;
    }
    p {
      margin-bottom: 12pt;
      color: #2a2a3e;
    }
    ul, ol {
      margin: 0 0 14pt 20pt;
    }
    li {
      margin-bottom: 5pt;
      color: #2a2a3e;
    }
    strong { color: #1A2B3C; }

    .lead {
      font-size: 12pt;
      font-weight: 400;
      color: #1A2B3C;
      line-height: 1.8;
      margin-bottom: 20pt;
      border-left: 3pt solid #2E7D32;
      padding-left: 14pt;
    }

    /* ── At-a-glance stat block ─────────────────── */
    .stat-row {
      display: table;
      width: 100%;
      margin: 22pt 0;
      background: #1A2B3C;
    }
    .stat {
      display: table-cell;
      width: 33%;
      text-align: center;
      padding: 18pt 10pt;
      border-right: 1pt solid rgba(255,255,255,0.08);
    }
    .stat:last-child { border-right: none; }
    .stat-number {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 26pt;
      font-weight: 700;
      color: #C9A84C;
      display: block;
      line-height: 1.1;
    }
    .stat-label {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 7pt;
      font-weight: 500;
      color: rgba(255,255,255,0.55);
      text-transform: uppercase;
      letter-spacing: 1.5px;
      display: block;
      margin-top: 5pt;
    }

    /* ── Callout box ─────────────────────────────── */
    .callout {
      background: #0C1B38;
      padding: 20pt 24pt;
      margin: 22pt 0;
      border-left: 4pt solid #2E7D32;
    }
    .callout p { color: rgba(255,255,255,0.85); margin-bottom: 0; }
    .callout strong { color: #C9A84C; }

    /* ── Tables ─────────────────────────────────── */
    table {
      width: 100%;
      border-collapse: collapse;
      margin: 16pt 0;
      font-size: 9.5pt;
    }
    th {
      background: #1A2B3C;
      color: #C9A84C;
      font-family: 'Inter', Arial, sans-serif;
      font-size: 8pt;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 1px;
      padding: 8pt 10pt;
      text-align: left;
    }
    td {
      padding: 7pt 10pt;
      border-bottom: 1pt solid #e8eaf0;
      color: #2a2a3e;
    }
    tr:nth-child(even) td { background: #f7f8fc; }

    /* Technology column — code-style callout */
    .tech-cell {
      font-family: 'Courier New', Courier, monospace;
      font-size: 8.5pt;
      font-weight: 600;
      color: #0C1B38;
      background: #eef2f7 !important;
    }

    /* ── Governance threshold gauge ─────────────── */
    .gauge-wrap {
      margin: 14pt 0 8pt;
    }
    .gauge-label {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 8pt;
      font-weight: 600;
      color: #1A2B3C;
      text-transform: uppercase;
      letter-spacing: 1px;
      margin-bottom: 6pt;
    }
    .gauge-track {
      width: 100%;
      height: 9pt;
      background: #e8eaf0;
      border-radius: 5pt;
      overflow: hidden;
    }
    .gauge-fill {
      height: 100%;
      background: #2E7D32;
      border-radius: 5pt;
    }
    .gauge-meta {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 7.5pt;
      color: #666;
      margin-top: 4pt;
    }

    /* ── Engagement QR block ─────────────────────── */
    .qr-block {
      display: table;
      width: 100%;
      margin-top: 18pt;
      padding: 18pt;
      background: #1A2B3C;
    }
    .qr-left {
      display: table-cell;
      vertical-align: middle;
      width: 90pt;
    }
    .qr-left img {
      width: 72pt;
      height: 72pt;
      border: 3pt solid rgba(255,255,255,0.15);
      display: block;
    }
    .qr-right {
      display: table-cell;
      vertical-align: middle;
      padding-left: 18pt;
    }
    .qr-right p {
      color: rgba(255,255,255,0.75);
      margin-bottom: 5pt;
      font-size: 9.5pt;
    }
    .qr-right strong { color: #C9A84C; font-size: 11pt; }
    .qr-right .qr-note {
      font-size: 7.5pt;
      color: rgba(255,255,255,0.4);
      margin-bottom: 0;
      text-transform: uppercase;
      letter-spacing: 1px;
    }

    /* ── Footer ─────────────────────────────────── */
    .footer {
      font-family: 'Inter', Arial, sans-serif;
      font-size: 7pt;
      font-weight: 400;
      color: #aaa;
      text-align: center;
      margin-top: 36pt;
      padding-top: 10pt;
      border-top: 1pt solid #e8eaf0;
    }
  </style>
</head>
<body>
  <%= yield %>
</body>
</html>
