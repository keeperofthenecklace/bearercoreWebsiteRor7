<%# ─── HERO ───────────────────────────────────────────────────────────────── %>
<section class="relative flex flex-col items-center text-center overflow-hidden bg-white"
         style="padding-top: 160px; padding-bottom: 100px;">

  <%# Guilloché SVG background — fine displaced-line security texture %>
  <svg class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
    <defs>
      <filter id="guilloche-warp" x="-5%" y="-5%" width="110%" height="110%">
        <feTurbulence type="turbulence" baseFrequency="0.018 0.032" numOctaves="2" seed="4" result="noise"/>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="5" xChannelSelector="R" yChannelSelector="G"/>
      </filter>
      <pattern id="guilloche-lines" x="0" y="0" width="10" height="10" patternUnits="userSpaceOnUse">
        <line x1="0" y1="5" x2="10" y2="5" stroke="#C9A84C" stroke-width="0.4"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#guilloche-lines)" filter="url(#guilloche-warp)" opacity="0.035"/>
  </svg>

  <%# Radial gold glow behind logo %>
  <div class="absolute pointer-events-none"
       style="width: 560px; height: 360px; top: 60px; left: 50%; transform: translateX(-50%);
              background: radial-gradient(ellipse at center, rgba(201,168,76,0.10) 0%, transparent 72%);"></div>

  <div class="relative z-10 px-6 max-w-3xl mx-auto">

    <%# Logo with spinning dashed halo %>
    <div class="flex justify-center mb-10">
      <div class="relative w-[230px] h-[230px]">
        <svg class="absolute -inset-4 w-[262px] h-[262px]" viewBox="0 0 262 262" fill="none"
             style="animation: spin 40s linear infinite;">
          <circle cx="131" cy="131" r="127" stroke="#C9A84C" stroke-width="1"
                  stroke-dasharray="6 5" opacity="0.30"/>
        </svg>
        <svg class="absolute -inset-8 w-[294px] h-[294px]" viewBox="0 0 294 294" fill="none"
             style="animation: spin 90s linear infinite reverse;">
          <circle cx="147" cy="147" r="143" stroke="#C9A84C" stroke-width="0.6"
                  stroke-dasharray="3 8" opacity="0.15"/>
        </svg>
        <%= image_tag "bearercore_logo.png",
              alt: "bearerCORE",
              class: "relative w-[230px] h-[230px] rounded-full z-10",
              style: "box-shadow: 0 16px 72px rgba(12,27,56,0.18);" %>
      </div>
    </div>

    <%# Eyebrow %>
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-7 border"
         style="border-color: rgba(201,168,76,0.35); background: rgba(201,168,76,0.05);">
      <span class="w-1.5 h-1.5 rounded-full" style="background: #C9A84C;"></span>
      <span class="text-xs font-semibold tracking-widest uppercase" style="color: #C9A84C;">Central Bank Digital Currency Platform</span>
    </div>

    <%# Headline — Playfair Display serif %>
    <h1 class="font-bold mb-10"
        style="color: #0C1B38;
               font-size: clamp(1.6rem, 4vw, 2.6rem);
               letter-spacing: 0.02em;
               white-space: nowrap;
               line-height: 1.15;
               font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
      Sovereign Payment Infrastructure
    </h1>

    <%# CTAs %>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#contact"
         class="btn-gold inline-flex items-center gap-3 px-8 py-4 rounded-full text-base font-semibold"
         style="background: #C9A84C; color: #0C1B38; box-shadow: 0 4px 20px rgba(201,168,76,0.28);">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Schedule a Governor's Briefing
      </a>
      <a href="/technical-overview"
         class="inline-flex items-center gap-2 px-7 py-4 rounded-full text-base font-medium border-2 transition-all hover:bg-gray-50"
         style="border-color: #0C1B38; color: #0C1B38;">
        Technical Overview
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="/docs" class="text-sm font-medium hover:underline" style="color: #9CA3AF;">
        Platform Documentation
      </a>
    </div>

  </div>
</section>

<style>
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>


<%# ─── INCLUSION BY DESIGN ────────────────────────────────────────────────── %>
<section class="py-24 px-6 bg-white border-t border-gray-100"
         data-controller="fade-in">
  <div class="max-w-6xl mx-auto grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">

    <%# Left: copy %>
    <div class="reveal">
      <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: #C9A84C;">Inclusion by Design</div>
      <h2 class="font-serif-display text-4xl md:text-5xl font-bold leading-tight mb-6" style="color: #0C1B38;">
        Cash principles.<br>Digital speed.
      </h2>
      <p class="text-lg text-gray-500 leading-relaxed">
        bearerCORE extends the reach of Central Bank money to the unbanked through a secure, smartphone-based CBDC Note system. By utilizing the trust model of physical currency, we enable sovereign peer-to-peer transfers that are accessible to everyone, ensuring the issuing Central Bank maintains full auditability and oversight through a highly resilient infrastructure.
      </p>
    </div>

    <%# Right: animated CBDC flow diagram %>
    <div class="reveal reveal-delay-2 flex items-center justify-center">
      <div class="w-full max-w-sm">

        <%# Central Bank node %>
        <div class="flex items-center gap-4 p-5 rounded-2xl border-2"
             style="border-color: #C9A84C; background: rgba(201,168,76,0.04);">
          <div class="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0"
               style="background: #C9A84C;">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #0C1B38;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
            </svg>
          </div>
          <div>
            <div class="font-bold text-sm" style="color: #0C1B38;">Central Bank</div>
            <div class="text-xs text-gray-400">Issues and authenticates sovereign CBDC Notes</div>
          </div>
          <span class="ml-auto text-xs font-semibold px-2 py-1 rounded-full"
                style="background: rgba(201,168,76,0.15); color: #C9A84C;">ISSUER</span>
        </div>

        <%# Animated connector 1 %>
        <div class="flex items-center justify-center my-1 py-1 relative" style="height: 64px;">
          <svg width="2" height="64" viewBox="0 0 2 64" class="absolute">
            <line x1="1" y1="0" x2="1" y2="64" stroke="#E5E7EB" stroke-width="2"/>
            <line x1="1" y1="0" x2="1" y2="64" stroke="#C9A84C" stroke-width="1.5"
                  class="flow-line-animated" opacity="0.6"/>
          </svg>
          <div class="absolute flex flex-col items-center gap-1">
            <div class="w-2 h-2 rounded-full flow-dot" style="background: #C9A84C;"></div>
          </div>
          <div class="absolute bottom-1 text-xs text-gray-400 font-medium tracking-wide">CBDC Delivery</div>
        </div>

        <%# Commercial Bank node %>
        <div class="flex items-center gap-4 p-5 rounded-2xl border border-gray-200 bg-white shadow-sm">
          <div class="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0"
               style="background: #0C1B38;">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
            </svg>
          </div>
          <div>
            <div class="font-bold text-sm" style="color: #0C1B38;">Commercial Bank</div>
            <div class="text-xs text-gray-400">Validates &amp; distributes to holders</div>
          </div>
          <span class="ml-auto text-xs font-semibold px-2 py-1 rounded-full"
                style="background: rgba(12,27,56,0.08); color: #0C1B38;">DISTRIBUTOR</span>
        </div>

        <%# Animated connector 2 %>
        <div class="flex items-center justify-center my-1 py-1 relative" style="height: 64px;">
          <svg width="2" height="64" viewBox="0 0 2 64" class="absolute">
            <line x1="1" y1="0" x2="1" y2="64" stroke="#E5E7EB" stroke-width="2"/>
            <line x1="1" y1="0" x2="1" y2="64" stroke="#C9A84C" stroke-width="1.5"
                  class="flow-line-animated" opacity="0.6" style="animation-delay: 0.45s;"/>
          </svg>
          <div class="absolute flex flex-col items-center gap-1">
            <div class="w-2 h-2 rounded-full flow-dot-delayed" style="background: #C9A84C;"></div>
          </div>
          <div class="absolute bottom-1 text-xs text-gray-400 font-medium tracking-wide">Instant Transfer</div>
        </div>

        <%# End User node %>
        <div class="flex items-center gap-4 p-5 rounded-2xl border border-gray-200 bg-white shadow-sm">
          <div class="w-11 h-11 rounded-full flex items-center justify-center flex-shrink-0 bg-gray-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 text-gray-500" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/>
            </svg>
          </div>
          <div>
            <div class="font-bold text-sm" style="color: #0C1B38;">End User</div>
            <div class="text-xs text-gray-400">No bank account required</div>
          </div>
          <span class="ml-auto text-xs font-semibold px-2 py-1 rounded-full"
                style="background: #F3F4F6; color: #6B7280;">BEARER</span>
        </div>

      </div>
    </div>
  </div>
</section>


