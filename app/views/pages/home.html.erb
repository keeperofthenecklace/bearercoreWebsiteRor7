      <span class="text-xl font-light tracking-wide" style="color: #0C1B38;">
        bearer<span class="font-bold" style="color: #C9A84C;">CORE</span><sup class="text-xs font-normal ml-0.5 opacity-50">™</sup>
      </span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a href="/technical-overview" class="text-sm font-medium hover:opacity-70 transition-colors" style="color: #0C1B38;">Technical Overview</a>
      <a href="/technical-overview" class="text-sm font-medium hover:opacity-70 transition-colors" style="color: #0C1B38;">Central Bank Access</a>
      <a href="mailto:governors@bearercore.com?subject=Briefing%20Request"
         class="btn-gold text-sm font-semibold px-5 py-2 rounded-full"
