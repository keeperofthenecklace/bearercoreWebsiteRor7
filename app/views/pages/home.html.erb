<%# ─── MODAL SCOPE — wraps page so all CTA buttons can trigger modal#open ─── %>
<div data-controller="modal">

<%# ══════════════════════════════════════════════════════════════════════════ %>
<%# MODAL OVERLAY                                                              %>
<%# ══════════════════════════════════════════════════════════════════════════ %>
<div class="fixed inset-0 z-[200] hidden flex items-center justify-center p-4"
     style="background: rgba(12,27,56,0.6); backdrop-filter: blur(4px);"
     data-modal-target="overlay"
     data-action="click->modal#closeOnBackdrop">

  <div class="relative w-full max-w-md bg-white rounded-2xl shadow-2xl overflow-hidden"
       style="box-shadow: 0 24px 80px rgba(12,27,56,0.22);">

    <%# Header %>
    <div class="px-8 pt-8 pb-6 border-b border-gray-100">
      <div class="flex items-center justify-between">
        <div>
          <div class="text-xs font-semibold tracking-widest uppercase mb-1" style="color: #C9A84C;">Restricted Access</div>
          <h2 class="text-xl font-bold" style="color: #0C1B38; letter-spacing: -0.01em;">
            Request a Sovereign Briefing
          </h2>
        </div>
        <button class="w-8 h-8 flex items-center justify-center rounded-full text-gray-400 hover:text-gray-600 hover:bg-gray-100 transition-colors"
                data-action="modal#close" aria-label="Close">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <%# ── FORM STATE ─────────────────────────────────────────────────────── %>
    <div data-modal-target="formState">
      <%= form_with url: briefing_requests_path, method: :post,
                    data: { action: "submit->modal#submit" },
                    class: "px-8 py-6" do |f| %>

        <div class="space-y-4">

          <div>
            <%= f.label :name, "Full Name", class: "block text-xs font-semibold uppercase tracking-widest mb-1.5", style: "color: #0C1B38;" %>
            <%= f.text_field :name,
                  placeholder: "H.E. John Mensah",
                  required: true,
                  class: "w-full px-4 py-3 text-sm border rounded-xl outline-none transition-all",
                  style: "border-color: #E5E7EB; color: #0C1B38;",
                  onfocus: "this.style.borderColor='#C9A84C'; this.style.boxShadow='0 0 0 3px rgba(201,168,76,0.12)'",
                  onblur:  "this.style.borderColor='#E5E7EB'; this.style.boxShadow='none'" %>
          </div>

          <div>
            <%= f.label :title, "Official Title", class: "block text-xs font-semibold uppercase tracking-widest mb-1.5", style: "color: #0C1B38;" %>
            <%= f.text_field :title,
                  placeholder: "Governor, Central Bank of Ghana",
                  required: true,
                  class: "w-full px-4 py-3 text-sm border rounded-xl outline-none transition-all",
                  style: "border-color: #E5E7EB; color: #0C1B38;",
                  onfocus: "this.style.borderColor='#C9A84C'; this.style.boxShadow='0 0 0 3px rgba(201,168,76,0.12)'",
                  onblur:  "this.style.borderColor='#E5E7EB'; this.style.boxShadow='none'" %>
          </div>

          <div>
            <%= f.label :institution, "Central Bank / Institution", class: "block text-xs font-semibold uppercase tracking-widest mb-1.5", style: "color: #0C1B38;" %>
            <%= f.text_field :institution,
                  placeholder: "Bank of Ghana",
                  required: true,
                  class: "w-full px-4 py-3 text-sm border rounded-xl outline-none transition-all",
                  style: "border-color: #E5E7EB; color: #0C1B38;",
                  onfocus: "this.style.borderColor='#C9A84C'; this.style.boxShadow='0 0 0 3px rgba(201,168,76,0.12)'",
                  onblur:  "this.style.borderColor='#E5E7EB'; this.style.boxShadow='none'" %>
          </div>

          <div>
            <%= f.label :email, "Work Email", class: "block text-xs font-semibold uppercase tracking-widest mb-1.5", style: "color: #0C1B38;" %>
            <%= f.email_field :email,
                  placeholder: "governor@centralbank.gov",
                  required: true,
                  class: "w-full px-4 py-3 text-sm border rounded-xl outline-none transition-all",
                  style: "border-color: #E5E7EB; color: #0C1B38;",
                  onfocus: "this.style.borderColor='#C9A84C'; this.style.boxShadow='0 0 0 3px rgba(201,168,76,0.12)'",
                  onblur:  "this.style.borderColor='#E5E7EB'; this.style.boxShadow='none'" %>
          </div>

        </div>

        <%# Error message %>
        <p class="hidden mt-3 text-sm text-red-600" data-modal-target="errorMsg"></p>

        <button type="submit"
                class="w-full mt-6 py-3.5 rounded-xl text-sm font-semibold transition-all"
                style="background: #C9A84C; color: #0C1B38;"
                data-modal-target="submitBtn">
          Submit Briefing Request
        </button>

      <% end %>

      <%# Footer %>
      <div class="px-8 pb-6 pt-0">
        <p class="text-xs text-center text-gray-400 leading-relaxed">
          Processed through a secure, encrypted channel.
          No third-party trackers. No marketing communications.
        </p>
      </div>
    </div>

    <%# ── SUCCESS STATE (hidden until form submitted) ─────────────────────── %>
    <div class="hidden px-8 py-12 text-center" data-modal-target="successState">
      <div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-6"
           style="background: rgba(201,168,76,0.12);">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
        </svg>
      </div>
      <h3 class="text-lg font-bold mb-3" style="color: #0C1B38;">Request Received</h3>
      <p class="text-sm text-gray-500 leading-relaxed max-w-xs mx-auto">
        Your request for a Sovereign Briefing has been received. Our protocol team will
        reach out shortly to coordinate a secure session.
      </p>
      <p class="text-xs text-gray-400 mt-4">
        A confirmation has been sent to your work email.
      </p>
      <button class="mt-8 text-sm font-medium transition-colors hover:opacity-70"
              style="color: #C9A84C;"
              data-action="modal#close">
        Close
      </button>
    </div>

  </div>
</div>
<%# /MODAL %>


<%# ─── NAV ─────────────────────────────────────────────────────────────────── %>
