<%# ─── HERO ───────────────────────────────────────────────────────────────── %>
<section class="relative flex flex-col items-center text-center overflow-hidden bg-white"
         style="padding-top: 160px; padding-bottom: 100px;">

  <%# Guilloché SVG background — fine displaced-line security texture %>
  <svg class="absolute inset-0 w-full h-full pointer-events-none" aria-hidden="true" preserveAspectRatio="xMidYMid slice">
    <defs>
      <filter id="guilloche-warp" x="-5%" y="-5%" width="110%" height="110%">
        <feTurbulence type="turbulence" baseFrequency="0.018 0.032" numOctaves="2" seed="4" result="noise"/>
        <feDisplacementMap in="SourceGraphic" in2="noise" scale="5" xChannelSelector="R" yChannelSelector="G"/>
      </filter>
      <pattern id="guilloche-lines" x="0" y="0" width="10" height="10" patternUnits="userSpaceOnUse">
        <line x1="0" y1="5" x2="10" y2="5" stroke="#C9A84C" stroke-width="0.4"/>
      </pattern>
    </defs>
    <rect width="100%" height="100%" fill="url(#guilloche-lines)" filter="url(#guilloche-warp)" opacity="0.035"/>
  </svg>

  <%# Radial gold glow behind logo %>
  <div class="absolute pointer-events-none"
       style="width: 560px; height: 360px; top: 60px; left: 50%; transform: translateX(-50%);
              background: radial-gradient(ellipse at center, rgba(201,168,76,0.10) 0%, transparent 72%);"></div>

  <div class="relative z-10 px-6 max-w-3xl mx-auto">

    <%# Logo with spinning dashed halo %>
    <div class="flex justify-center mb-10">
      <div class="relative w-[230px] h-[230px]">
        <svg class="absolute -inset-4 w-[262px] h-[262px]" viewBox="0 0 262 262" fill="none"
             style="animation: spin 40s linear infinite;">
          <circle cx="131" cy="131" r="127" stroke="#C9A84C" stroke-width="1"
                  stroke-dasharray="6 5" opacity="0.30"/>
        </svg>
        <svg class="absolute -inset-8 w-[294px] h-[294px]" viewBox="0 0 294 294" fill="none"
             style="animation: spin 90s linear infinite reverse;">
          <circle cx="147" cy="147" r="143" stroke="#C9A84C" stroke-width="0.6"
                  stroke-dasharray="3 8" opacity="0.15"/>
        </svg>
        <%= image_tag "bearercore_logo.png",
              alt: "bearerCORE",
              class: "relative w-[230px] h-[230px] rounded-full z-10",
              style: "box-shadow: 0 16px 72px rgba(12,27,56,0.18);" %>
      </div>
    </div>

    <%# Eyebrow %>
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-7 border"
         style="border-color: rgba(201,168,76,0.35); background: rgba(201,168,76,0.05);">
      <span class="w-1.5 h-1.5 rounded-full" style="background: #C9A84C;"></span>
      <span class="text-xs font-semibold tracking-widest uppercase" style="color: #C9A84C;">Central Bank Digital Currency Platform</span>
    </div>

    <%# Headline — Playfair Display serif %>
    <h1 class="font-bold mb-10"
        style="color: #0C1B38;
               font-size: clamp(1.75rem, 6vw, 2.6rem);
               letter-spacing: 0.02em;
               line-height: 1.15;
               font-family: -apple-system, BlinkMacSystemFont, 'SF Pro Text', 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
      Sovereign Payment Infrastructure
    </h1>

    <%# CTAs %>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="#contact"
         class="btn-gold inline-flex items-center gap-3 px-8 py-4 rounded-full text-base font-semibold"
         style="background: #C9A84C; color: #0C1B38; box-shadow: 0 4px 20px rgba(201,168,76,0.28);">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
        </svg>
        Schedule a Governor's Briefing
      </a>
      <a href="/technical-overview"
         class="inline-flex items-center gap-2 px-7 py-4 rounded-full text-base font-medium border-2 transition-all hover:bg-gray-50"
         style="border-color: #0C1B38; color: #0C1B38;">
        Technical Overview
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="/docs" class="text-sm font-medium hover:underline" style="color: #9CA3AF;">
        Platform Documentation
      </a>
    </div>

  </div>
</section>

<style>
  @keyframes spin { from { transform: rotate(0deg); } to { transform: rotate(360deg); } }
</style>



