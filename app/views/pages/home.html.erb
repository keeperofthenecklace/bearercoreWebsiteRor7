  <div class="hidden border-t border-gray-100 bg-white"
       data-nav-target="menu">
    <div class="flex flex-col px-6 py-3 gap-1">
      <a href="/technical-overview" class="text-sm font-medium py-2 border-b border-gray-50" style="color: #0C1B38;">Technical Overview</a>
      <a href="/technical-overview" class="text-sm font-medium py-2 border-b border-gray-50" style="color: #0C1B38;">Central Bank Access</a>
