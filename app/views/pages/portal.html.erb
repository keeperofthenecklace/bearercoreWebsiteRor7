          <span style="width: 18px; height: 18px; background: rgba(201,168,76,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;">
            <svg width="10" height="10" viewBox="0 0 10 10"><polyline points="2,5 4,7 8,3" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span style="color: rgba(255,255,255,0.75); font-size: 0.875rem; line-height: 1.5;">System architecture specifications</span>
        </li>
        <li style="display: flex; align-items: flex-start; gap: 10px;">
          <span style="width: 18px; height: 18px; background: rgba(201,168,76,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;">
            <svg width="10" height="10" viewBox="0 0 10 10"><polyline points="2,5 4,7 8,3" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span style="color: rgba(255,255,255,0.75); font-size: 0.875rem; line-height: 1.5;">Cryptographic verification &amp; audit logs</span>
        </li>
        <li style="display: flex; align-items: flex-start; gap: 10px;">
          <span style="width: 18px; height: 18px; background: rgba(201,168,76,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;">
            <svg width="10" height="10" viewBox="0 0 10 10"><polyline points="2,5 4,7 8,3" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span style="color: rgba(255,255,255,0.75); font-size: 0.875rem; line-height: 1.5;">Latency benchmarks &amp; offline metrics</span>
        </li>
        <li style="display: flex; align-items: flex-start; gap: 10px;">
          <span style="width: 18px; height: 18px; background: rgba(201,168,76,0.15); border-radius: 50%; display: flex; align-items: center; justify-content: center; flex-shrink: 0; margin-top: 1px;">
            <svg width="10" height="10" viewBox="0 0 10 10"><polyline points="2,5 4,7 8,3" fill="none" stroke="#C9A84C" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </span>
          <span style="color: rgba(255,255,255,0.75); font-size: 0.875rem; line-height: 1.5;">Compliance &amp; integration reference docs</span>
        </li>
      </ul>

      <a href="/technical-overview" style="display: flex; align-items: center; justify-content: center; gap: 8px; background: linear-gradient(135deg, #C9A84C, #b8943f); color: #0C1B38; font-size: 0.875rem; font-weight: 700; letter-spacing: 0.03em; text-decoration: none; padding: 14px 24px; border-radius: 12px; transition: opacity 0.2s; text-align: center;" onmouseover="this.style.opacity='0.9'" onmouseout="this.style.opacity='1'">
        Open Technical Review
        <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"/></svg>
      </a>
