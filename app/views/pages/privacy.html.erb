<%# ─── NAV ─────────────────────────────────────────────────────────────────── %>
<nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-gray-100"
     data-controller="nav">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <%= image_tag "bearercore_logo.png", alt: "bearerCORE", class: "h-9 w-9 rounded-full" %>
      <span class="text-xl font-light tracking-wide" style="color: #0C1B38;">
        bearer<span class="font-bold" style="color: #C9A84C;">CORE</span><sup class="text-xs font-normal ml-0.5 opacity-50">™</sup>
      </span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a href="/public-vision.pdf" download class="text-sm font-medium hover:opacity-70 transition-colors" style="color: #0C1B38;">Public Vision</a>
      <a href="/protocol-desk"     class="text-sm font-medium hover:opacity-70 transition-colors" style="color: #0C1B38;">Request Briefing</a>
      <a href="/central-bank-access"
         class="text-sm font-semibold px-5 py-2 rounded-full border-2 transition-all hover:bg-gray-50"
         style="border-color: #0C1B38; color: #0C1B38;">
        Central Bank Access
      </a>
    </div>
  </div>
</nav>


<%# ─── PAGE HEADER ────────────────────────────────────────────────────────── %>
<div style="padding-top: 73px;">
  <div class="py-16 px-6 border-b border-gray-100 bg-white">
    <div class="max-w-3xl mx-auto">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">
        TowerPoint Group · bearerCORE™
      </div>
      <h1 class="text-3xl md:text-4xl font-bold mb-4" style="color: #0C1B38; letter-spacing: -0.01em;">
        Our Privacy Principles
      </h1>
      <p class="text-base text-gray-500 leading-relaxed max-w-xl">
        bearerCORE is engineered around a single conviction: sovereign infrastructure
        should serve people, not surveil them.
      </p>
      <div class="flex items-center gap-3 mt-6 text-xs text-gray-400">
        <span>Effective: January 2026</span>
        <span class="w-1 h-1 rounded-full bg-gray-300"></span>
        <span>TowerPoint Group Ltd.</span>
        <span class="w-1 h-1 rounded-full bg-gray-300"></span>
        <span>Ghana · Pan-African · GDPR-aligned</span>
      </div>
    </div>
  </div>
</div>


<%# ─── PRINCIPLES ─────────────────────────────────────────────────────────── %>
<div class="py-16 px-6 bg-gray-50">
  <div class="max-w-3xl mx-auto">

    <%# Principle cards %>
    <% principles = [
      {
        number: "01",
        title:  "Data Sovereignty & Minimization",
        body:   "TowerPoint Group operates on a \"Privacy by Design\" principle. bearerCORE™ is engineered to minimize the collection of Personal Identifiable Information (PII). We do not track individual spending habits; we provide the infrastructure for secure, sovereign value transfer."
      },
      {
        number: "02",
        title:  "Cryptographic Security",
        body:   "All data transmitted through the bearerCORE™ gateway is secured using AES-256-GCM encryption and authenticated via Ed25519 digital signatures. This ensures that only authorized entities — as defined by the issuing Central Bank — can validate transaction data."
      },
      {
        number: "03",
        title:  "Regional & International Compliance",
        body:   nil,
        list:   [
          { region: "Ghana",          detail: "Data Protection Act, 2012 (Act 843)." },
          { region: "Pan-African",    detail: "The AU Malabo Convention (2014) regarding Cyber Security and Personal Data Protection." },
          { region: "International",  detail: "Alignment with GDPR principles regarding data portability and the \"Right to be Forgotten\" (where applicable to immutable ledger constraints)." }
        ]
      },
      {
        number: "04",
        title:  "Non-Custodial Infrastructure",
        body:   "TowerPoint Group does not hold, manage, or have access to private keys or \"digital money\" on behalf of users. Access is managed solely by the participating Central Bank and the end-user."
      }
    ] %>

    <div class="space-y-6">
      <% principles.each do |p| %>
        <div class="bg-white rounded-2xl border border-gray-100 overflow-hidden"
             style="box-shadow: 0 2px 16px rgba(12,27,56,0.05);">
          <div class="flex gap-0">

            <%# Number sidebar %>
            <div class="flex-shrink-0 w-14 flex items-start justify-center pt-7"
                 style="background: #0C1B38;">
              <span class="text-xs font-bold" style="color: rgba(201,168,76,0.6); letter-spacing: 1px;"><%= p[:number] %></span>
            </div>

            <%# Content %>
            <div class="px-7 py-6 flex-1">
              <h2 class="text-base font-bold mb-3" style="color: #0C1B38;"><%= p[:title] %></h2>

              <% if p[:body] %>
                <p class="text-sm text-gray-500 leading-relaxed"><%= p[:body] %></p>
              <% end %>

              <% if p[:list] %>
                <ul class="space-y-3 mt-1">
                  <% p[:list].each do |item| %>
                    <li class="flex gap-3 text-sm">
                      <span class="flex-shrink-0 font-semibold" style="color: #C9A84C; min-width: 90px;"><%= item[:region] %></span>
                      <span class="text-gray-500 leading-relaxed"><%= item[:detail] %></span>
                    </li>
                  <% end %>
                </ul>
              <% end %>
            </div>

          </div>
        </div>
      <% end %>
    </div>


    <%# Full legal framework link %>
    <div class="mt-12 pt-8 border-t border-gray-200 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div>
        <p class="text-sm font-semibold mb-1" style="color: #0C1B38;">Legal Framework</p>
        <p class="text-xs text-gray-400 leading-relaxed max-w-sm">
          The principles above summarise our data governance commitments.
          The complete legal instrument is available as a formal PDF document.
        </p>
      </div>
      <a href="/legal-framework.pdf" target="_blank" rel="noopener"
         class="flex-shrink-0 inline-flex items-center gap-2 text-sm font-semibold px-5 py-3 rounded-xl border-2 transition-all hover:bg-gray-50"
         style="border-color: #0C1B38; color: #0C1B38;">
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        View Full Legal Framework (PDF)
      </a>
    </div>

  </div>
</div>


<%# ─── FOOTER ─────────────────────────────────────────────────────────────── %>
