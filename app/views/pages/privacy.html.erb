      <div class="flex items-center gap-3">
        <%= image_tag "bearercore_logo.png", alt: "bearerCORE", class: "h-7 w-7 rounded-full" %>
        <span class="font-light text-lg" style="color: #0C1B38;">
          bearer<span class="font-bold" style="color: #C9A84C;">CORE</span><sup class="text-xs opacity-50 ml-0.5">™</sup>
        </span>
        <span class="hidden sm:block text-gray-200 mx-2">|</span>
        <span class="hidden sm:block text-xs text-gray-400 tracking-wide uppercase">Sovereign CBDC Infrastructure</span>
      </div>
      <div class="flex items-center gap-8 text-sm text-gray-400">
        <a href="/privacy" class="hover:text-gray-700 transition-colors font-medium" style="color: #C9A84C;">Privacy</a>
        <a href="/terms"   class="hover:text-gray-700 transition-colors">Terms</a>
        <a href="https://towerpointgroup.com" target="_blank" rel="noopener" class="hover:text-gray-700 transition-colors">TowerPoint Group</a>
        <a href="https://www.linkedin.com/company/bearercore/" target="_blank" rel="noopener"
           class="hover:text-gray-700 transition-colors flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
    <div class="mt-6 pt-6 border-t border-gray-50 flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-gray-300">
      <span>&copy; <%= Date.current.year %> TowerPoint Group Ltd. All rights reserved.</span>
      <span>Ed25519 &nbsp;·&nbsp; AES-256-GCM</span>
    </div>
  </div>
</footer>
