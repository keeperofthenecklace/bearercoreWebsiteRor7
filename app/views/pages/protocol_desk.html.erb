<%# ─── PROTOCOL DESK ─────────────────────────────────────────────────────────── %>

<%# ─── NAV ─────────────────────────────────────────────────────────────────── %>
<nav class="fixed top-0 left-0 right-0 z-50 bg-white border-b border-gray-100">
  <div class="max-w-7xl mx-auto px-6 py-4 flex items-center justify-between">
    <a href="/" class="flex items-center gap-3">
      <%= image_tag "bearercore_logo.png", alt: "bearerCORE", class: "h-9 w-9 rounded-full" %>
      <span class="text-xl font-light tracking-wide" style="color: #0C1B38;">
        bearer<span class="font-bold" style="color: #C9A84C;">CORE</span><sup class="text-xs font-normal ml-0.5 opacity-50">™</sup>
      </span>
    </a>
    <div class="hidden md:flex items-center gap-8">
      <a href="/technical-overview" class="text-sm font-medium hover:opacity-70 transition-colors" style="color: #0C1B38;">Technical Overview</a>
      <a href="/public-vision.pdf" target="_blank" rel="noopener"
         class="text-sm font-medium hover:opacity-70 transition-colors" style="color: #0C1B38;">
        Public Vision
      </a>
    </div>
  </div>
</nav>


<%# ─── HEADER BAND ───────────────────────────────────────────────────────────── %>
<div style="padding-top: 73px;">
  <div class="py-16 px-6 text-center" style="background: #0C1B38;">
    <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full mb-6 border"
         style="border-color: rgba(201,168,76,0.4); background: rgba(201,168,76,0.08);">
      <span class="w-1.5 h-1.5 rounded-full" style="background: #C9A84C;"></span>
      <span class="text-xs font-semibold tracking-widest uppercase" style="color: #C9A84C;">Restricted Access</span>
    </div>
    <h1 class="text-3xl md:text-4xl font-bold mb-4" style="color: #fff; letter-spacing: 0.01em;">
      Protocol Desk
    </h1>
    <p class="text-base max-w-xl mx-auto" style="color: rgba(255,255,255,0.6); line-height: 1.7;">
      bearerCORE's sovereign briefing materials are reserved for qualified central bank
      and institutional counterparties. Complete the form below to request access.
    </p>
  </div>
</div>


<%# ─── OVERVIEW + FORM ─────────────────────────────────────────────────────── %>
<div class="py-16 px-6 bg-gray-50">
  <div class="max-w-5xl mx-auto">
    <div class="grid md:grid-cols-5 gap-12 items-start">

      <%# Left: overview ─────────────────────────────────────────────────── %>
      <div class="md:col-span-2">
        <p class="text-xs font-semibold tracking-widest uppercase mb-6" style="color: #C9A84C;">What You'll Receive</p>

        <div class="space-y-6">
          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center mt-0.5"
                 style="background: rgba(12,27,56,0.07);">
              <svg class="w-4 h-4" style="color: #0C1B38;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold mb-1" style="color: #0C1B38;">Sovereign Briefing Litepaper</p>
              <p class="text-sm leading-relaxed" style="color: #6B7280;">Technical architecture, cryptographic protocol specifications, and deployment model for central bank CBDC issuance.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center mt-0.5"
                 style="background: rgba(12,27,56,0.07);">
              <svg class="w-4 h-4" style="color: #0C1B38;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold mb-1" style="color: #0C1B38;">Protocol Team Introduction</p>
              <p class="text-sm leading-relaxed" style="color: #6B7280;">A direct channel to our team for technical questions, pilot programme enquiries, and corridor implementation discussions.</p>
            </div>
          </div>

          <div class="flex gap-4">
            <div class="flex-shrink-0 w-8 h-8 rounded-full flex items-center justify-center mt-0.5"
                 style="background: rgba(12,27,56,0.07);">
              <svg class="w-4 h-4" style="color: #0C1B38;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
              </svg>
            </div>
            <div>
              <p class="text-sm font-semibold mb-1" style="color: #0C1B38;">Secure Channel Only</p>
              <p class="text-sm leading-relaxed" style="color: #6B7280;">No marketing communications. No third-party data sharing. Materials delivered directly to your institutional address.</p>
            </div>
          </div>
        </div>

        <div class="mt-10 pt-8 border-t border-gray-200">
          <p class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: #9CA3AF;">Eligible Institutions</p>
          <ul class="space-y-2 text-sm" style="color: #6B7280;">
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full flex-shrink-0" style="background: #C9A84C;"></span>
              Central banks and monetary authorities
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full flex-shrink-0" style="background: #C9A84C;"></span>
              Licensed commercial banks (Tier 1 &amp; 2)
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full flex-shrink-0" style="background: #C9A84C;"></span>
              Multilateral development institutions
            </li>
            <li class="flex items-center gap-2">
              <span class="w-1 h-1 rounded-full flex-shrink-0" style="background: #C9A84C;"></span>
              Accredited financial regulators
            </li>
          </ul>
        </div>
      </div>

      <%# Right: form ────────────────────────────────────────────────────── %>
      <div class="md:col-span-3">
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden"
             style="box-shadow: 0 8px 40px rgba(12,27,56,0.09);">

          <%# form header %>
          <div class="px-8 pt-8 pb-6 border-b border-gray-100">
            <div class="text-xs font-semibold tracking-widest uppercase mb-1" style="color: #C9A84C;">Sovereign Briefing</div>
            <h2 class="text-xl font-bold" style="color: #0C1B38; letter-spacing: -0.01em;">Request Access</h2>
          </div>

          <%# form state %>
          <div id="pd-form-state" class="px-8 py-8">
            <%= form_with model: BriefingRequest.new, url: briefing_requests_path,
                          html: { id: "pd-form", data: { turbo: "false" } } do |f| %>

              <div class="space-y-5">

                <div>
                  <%= f.label :name, "Full Name", class: "block text-xs font-semibold uppercase tracking-widest mb-1.5", style: "color: #0C1B38;" %>
                  <%= f.text_field :name,
                        placeholder: "H.E. John Mensah",
                        required: true,
                        class: "w-full px-4 py-3 text-sm border rounded-xl outline-none transition-all",
                        style: "border-color: #E5E7EB; color: #0C1B38;",
                        onfocus: "this.style.borderColor='#C9A84C'; this.style.boxShadow='0 0 0 3px rgba(201,168,76,0.12)'",
                        onblur:  "this.style.borderColor='#E5E7EB'; this.style.boxShadow='none'" %>
                </div>

                <div>
                  <%= f.label :email, "Institutional Email", class: "block text-xs font-semibold uppercase tracking-widest mb-1.5", style: "color: #0C1B38;" %>
                  <%= f.email_field :email,
                        placeholder: "governor@centralbank.gov",
                        required: true,
                        class: "w-full px-4 py-3 text-sm border rounded-xl outline-none transition-all",
                        style: "border-color: #E5E7EB; color: #0C1B38;",
                        onfocus: "this.style.borderColor='#C9A84C'; this.style.boxShadow='0 0 0 3px rgba(201,168,76,0.12)'",
                        onblur:  "this.style.borderColor='#E5E7EB'; this.style.boxShadow='none'" %>
                  <p class="mt-1.5 text-xs" style="color: #9CA3AF;">Institutional addresses only — Gmail, Hotmail, Outlook and other public providers are not accepted.</p>
                  <p id="pd-email-error" class="hidden mt-1 text-xs font-medium" style="color: #DC2626;"></p>
                </div>

                <div>
                  <%= f.label :institution, "Organisation / Central Bank", class: "block text-xs font-semibold uppercase tracking-widest mb-1.5", style: "color: #0C1B38;" %>
                  <%= f.text_field :institution,
                        placeholder: "Bank of Ghana",
                        required: true,
                        class: "w-full px-4 py-3 text-sm border rounded-xl outline-none transition-all",
                        style: "border-color: #E5E7EB; color: #0C1B38;",
                        onfocus: "this.style.borderColor='#C9A84C'; this.style.boxShadow='0 0 0 3px rgba(201,168,76,0.12)'",
                        onblur:  "this.style.borderColor='#E5E7EB'; this.style.boxShadow='none'" %>
                </div>

                <div>
                  <%= f.label :title, "Job Title", class: "block text-xs font-semibold uppercase tracking-widest mb-1.5", style: "color: #0C1B38;" %>
                  <%= f.text_field :title,
                        placeholder: "Governor, Central Bank of Ghana",
                        required: true,
                        class: "w-full px-4 py-3 text-sm border rounded-xl outline-none transition-all",
                        style: "border-color: #E5E7EB; color: #0C1B38;",
                        onfocus: "this.style.borderColor='#C9A84C'; this.style.boxShadow='0 0 0 3px rgba(201,168,76,0.12)'",
                        onblur:  "this.style.borderColor='#E5E7EB'; this.style.boxShadow='none'" %>
                </div>

              </div>

              <p id="pd-error" class="hidden mt-3 text-sm text-red-600"></p>

              <button type="submit" id="pd-submit"
                      class="w-full mt-7 py-3.5 rounded-xl text-sm font-semibold transition-all"
                      style="background: #C9A84C; color: #0C1B38;">
                Submit Briefing Request
              </button>

            <% end %>

            <p class="mt-5 text-xs text-center text-gray-400 leading-relaxed">
              Processed through a secure, encrypted channel.
              No third-party trackers. No marketing communications.
            </p>
          </div>

          <%# success state (hidden until form submitted) %>
          <div id="pd-success" class="hidden px-8 py-14 text-center">
            <div class="w-14 h-14 rounded-full flex items-center justify-center mx-auto mb-6"
                 style="background: rgba(201,168,76,0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-7 w-7" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7"/>
              </svg>
            </div>
            <h3 class="text-lg font-bold mb-3" style="color: #0C1B38;">Request Received</h3>
            <p class="text-sm text-gray-500 leading-relaxed max-w-xs mx-auto">
              Your briefing request has been received. Our protocol team will reach out
              to your institutional address shortly to coordinate a secure session.
            </p>
            <p class="text-xs text-gray-400 mt-4">A confirmation has been sent to your work email.</p>
            <a href="/" class="inline-block mt-8 text-sm font-medium transition-colors hover:opacity-70"
               style="color: #C9A84C;">
              Return to bearerCORE &rarr;
            </a>
          </div>

        </div>
      </div>

    </div>
  </div>
</div>


<%# ─── FOOTER ─────────────────────────────────────────────────────────────── %>
<footer class="border-t border-gray-100 bg-white py-10 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="flex flex-col md:flex-row items-center justify-between gap-6">
      <div class="flex items-center gap-3">
        <%= image_tag "bearercore_logo.png", alt: "bearerCORE", class: "h-7 w-7 rounded-full" %>
        <span class="font-light text-lg" style="color: #0C1B38;">
          bearer<span class="font-bold" style="color: #C9A84C;">CORE</span><sup class="text-xs opacity-50 ml-0.5">™</sup>
        </span>
        <span class="hidden sm:block text-gray-200 mx-2">|</span>
        <span class="hidden sm:block text-xs text-gray-400 tracking-wide uppercase">Sovereign CBDC Infrastructure</span>
      </div>
      <div class="flex items-center gap-8 text-sm text-gray-400">
        <a href="/privacy" class="hover:text-gray-700 transition-colors">Privacy</a>
        <a href="/terms"   class="hover:text-gray-700 transition-colors">Terms</a>
        <a href="https://towerpointgroup.com" target="_blank" rel="noopener" class="hover:text-gray-700 transition-colors">TowerPoint Group</a>
        <a href="https://www.linkedin.com/company/bearercore/" target="_blank" rel="noopener"
           class="hover:text-gray-700 transition-colors flex items-center gap-1.5">
          <svg class="w-3.5 h-3.5 flex-shrink-0" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
      </div>
    </div>
    <div class="mt-6 pt-6 border-t border-gray-50 flex flex-col md:flex-row items-center justify-between gap-2 text-xs text-gray-300">
      <span>&copy; <%= Date.current.year %> bearerCORE. All rights reserved.</span>
      <span>Ed25519 &nbsp;·&nbsp; AES-256-GCM</span>
    </div>
  </div>
</footer>


<script>
  // ── Consumer email blocklist (mirrors server-side CONSUMER_EMAIL_DOMAINS) ──
  const PD_PUBLIC_DOMAINS = new Set([
    'gmail.com', 'googlemail.com',
    'hotmail.com', 'hotmail.co.uk', 'hotmail.fr', 'hotmail.es', 'hotmail.de', 'hotmail.it',
    'outlook.com', 'outlook.co.uk', 'outlook.fr', 'outlook.de', 'outlook.es', 'outlook.it', 'outlook.com.au',
    'live.com', 'live.co.uk', 'live.fr', 'live.de', 'live.com.au',
    'msn.com',
    'yahoo.com', 'yahoo.co.uk', 'yahoo.fr', 'yahoo.de', 'yahoo.es', 'yahoo.it', 'yahoo.com.au', 'yahoo.co.in',
    'icloud.com', 'me.com', 'mac.com',
    'aol.com',
    'protonmail.com', 'proton.me',
    'mail.com',
    'yandex.com', 'yandex.ru',
    'qq.com', '163.com', '126.com',
    'rediffmail.com',
    'gmx.com', 'gmx.de', 'gmx.net', 'gmx.at',
    'web.de', 't-online.de',
    'orange.fr', 'free.fr', 'sfr.fr', 'wanadoo.fr',
    'virginmedia.com', 'btinternet.com', 'sky.com', 'talktalk.net'
  ]);

  function pdIsPublicEmail(email) {
    const at = email.lastIndexOf('@');
    if (at === -1) return false;
    return PD_PUBLIC_DOMAINS.has(email.slice(at + 1).toLowerCase().trim());
  }

  function pdShowEmailError(msg) {
    const el    = document.getElementById('pd-email-error');
    const field = document.querySelector('#pd-form [type="email"]');
    el.textContent = msg;
    el.classList.remove('hidden');
    if (field) {
      field.style.borderColor = '#DC2626';
      field.style.boxShadow   = '0 0 0 3px rgba(220,38,38,0.12)';
    }
  }

  function pdClearEmailError() {
    const el    = document.getElementById('pd-email-error');
    const field = document.querySelector('#pd-form [type="email"]');
    el.textContent = '';
    el.classList.add('hidden');
    if (field) {
      field.style.borderColor = '#E5E7EB';
      field.style.boxShadow   = 'none';
    }
  }

  // Real-time check on blur
  document.querySelector('#pd-form [type="email"]').addEventListener('blur', function() {
    if (this.value && pdIsPublicEmail(this.value)) {
      pdShowEmailError('Public email providers are not accepted. Please use your institutional address.');
    } else {
      pdClearEmailError();
    }
  });

  // Submit via fetch() — Turbo is disabled on this form, so this is the only submit path
  document.getElementById('pd-form').addEventListener('submit', function(e) {
    e.preventDefault();

    pdClearEmailError();
    document.getElementById('pd-error').classList.add('hidden');

    const emailField = document.querySelector('#pd-form [type="email"]');
    if (emailField && pdIsPublicEmail(emailField.value)) {
      pdShowEmailError('Public email providers are not accepted. Please use your institutional address.');
      return;
    }

    const btn = document.getElementById('pd-submit');
    btn.disabled    = true;
    btn.textContent = 'Submitting…';

    const form = this;
    fetch(form.action, {
      method:  'POST',
      headers: {
        'Accept':       'application/json',
        'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]')?.content || ''
      },
      body: new FormData(form)
    })
    .then(function(res) {
      return res.json().then(function(data) { return { ok: res.ok, data: data }; });
    })
    .then(function(result) {
      if (result.ok && result.data.success) {
        document.getElementById('pd-form-state').classList.add('hidden');
        document.getElementById('pd-success').classList.remove('hidden');
      } else {
        const errors = result.data && result.data.errors;
        const msg    = errors ? errors.join(', ') : 'An error occurred. Please try again.';
        const el     = document.getElementById('pd-error');
        el.textContent = msg;
        el.classList.remove('hidden');
        btn.disabled    = false;
        btn.textContent = 'Submit Briefing Request';
      }
    })
    .catch(function() {
      const el = document.getElementById('pd-error');
      el.textContent = 'Connection error — please try again.';
      el.classList.remove('hidden');
      btn.disabled    = false;
      btn.textContent = 'Submit Briefing Request';
    });
  });
</script>
