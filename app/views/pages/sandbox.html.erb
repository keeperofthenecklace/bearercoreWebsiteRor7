              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </div>
          <div>
            <h3 style="color: white; margin: 0; font-size: 16px; font-weight: 600;">Governor Desk</h3>
            <p style="color: rgba(255,255,255,0.7); margin: 4px 0 0; font-size: 12px;">Governance Workflow</p>
