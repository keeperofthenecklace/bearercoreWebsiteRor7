<%# ─── QUICK ACCESS CARDS ──────────────────────────────────────────────────── %>
<section style="padding: 32px 24px; background: linear-gradient(135deg, #1a4d3e 0%, #2d6a4f 100%);">
  <div style="max-width: 1000px; margin: 0 auto;">
    <div style="display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px;">

      <!-- Trade Claim -->
