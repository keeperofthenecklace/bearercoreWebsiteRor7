<%# ─── FETCH INTERCEPTOR — redirect /api/* → SmartCHEQ ────────────────────── %>
<script>
(function() {
  window.SC_API_BASE = '';

  var _origFetch = window.fetch;
  window.fetch = function(url, opts) {
    if (typeof url === 'string' && url.startsWith('/api/')) {
      url = window.SC_API_BASE + url;
    }
    return _origFetch.call(this, url, opts);
  };

  window.showTradeClaimModal = function() {
    var modal = document.getElementById('tradeClaimModalOverlay');
    if (modal) { modal.style.display = 'flex'; document.body.style.overflow = 'hidden'; }
  };
  window.hideTradeClaimModal = function() {
    var modal = document.getElementById('tradeClaimModalOverlay');
    if (modal) { modal.style.display = 'none'; document.body.style.overflow = ''; }
  };

  window.showSupervisorDeskModal = function() {
    var modal = document.getElementById('supervisorDeskModalOverlay');
    if (modal) {
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      if (typeof loadSupervisorDesk === 'function') loadSupervisorDesk();
    }
  };
  window.hideSupervisorDeskModal = function() {
    var modal = document.getElementById('supervisorDeskModalOverlay');
    if (modal) { modal.style.display = 'none'; document.body.style.overflow = ''; }
  };

  window.showGovernorDeskModal = function() {
    var modal = document.getElementById('governorDeskModalOverlay');
    if (modal) {
      modal.style.display = 'flex';
      document.body.style.overflow = 'hidden';
      if (typeof loadMacroConsole === 'function') loadMacroConsole();
    }
  };
  window.hideGovernorDeskModal = function() {
    var modal = document.getElementById('governorDeskModalOverlay');
    if (modal) { modal.style.display = 'none'; document.body.style.overflow = ''; }
  };
})();
</script>

