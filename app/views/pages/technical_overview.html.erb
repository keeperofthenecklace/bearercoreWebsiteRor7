              ["Note lifecycle states", "5", "MINTED → ISSUED → TRANSFERRED → REDEEMED → BURNED"],
              ["API version", "v2", "RESTful JSON; OAuth2 via Doorkeeper"],
              ["Backend stack", "Rails 7.1 / Ruby 3.3.6", "PostgreSQL + Sidekiq + Redis"],
              ["Desktop client", "Qt6 / C++", "macOS ARM64; libsodium + Crypto++ + OpenSSL 3"],
