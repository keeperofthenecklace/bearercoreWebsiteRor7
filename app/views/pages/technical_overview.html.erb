<%# ─── HYBRID ARCHITECTURE ────────────────────────────────────────────────── %>
<section class="py-20 px-6 bg-white" data-controller="fade-in">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-14">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">System Design</div>
      <h2 class="font-serif-display text-3xl md:text-4xl font-bold reveal" style="color: #0C1B38;">Hybrid CBDC Architecture</h2>
      <p class="text-gray-500 mt-4 max-w-2xl mx-auto leading-relaxed reveal reveal-delay-1">
        bearerCORE combines a bearer instrument layer with a sovereign registry and settlement corridor — delivering the offline capability of physical cash with the auditability of a digital ledger.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-6">

      <div class="rounded-2xl p-8 reveal reveal-delay-1" style="background: linear-gradient(135deg, #0C1B38 0%, #152545 100%);">
        <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: #C9A84C;">Layer 1</div>
        <h3 class="text-lg font-bold text-white mb-3">Representation Layer</h3>
        <p class="text-gray-300 text-sm leading-relaxed">CBDC PNG banknotes — self-contained bearer instruments with embedded Ed25519 signatures, AES-256-GCM vault encryption, QR codes, and Code 128 barcodes. Transferable via email, SFTP, USB, NFC, or Bluetooth.</p>
      </div>

      <div class="rounded-2xl p-8 border border-gray-100 shadow-sm reveal reveal-delay-2">
        <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: #C9A84C;">Layer 2</div>
        <h3 class="text-lg font-bold mb-3" style="color: #0C1B38;">Registry Layer</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Rails 7.1 API — validation registry, issuance authorisation engine, FX corridor manager, and governance platform. Enforces duplicate detection, state transitions, and immutable audit logs via append-only ValidationEvent records.</p>
      </div>

      <div class="rounded-2xl p-8 border border-gray-100 shadow-sm reveal reveal-delay-3">
        <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: #C9A84C;">Layer 3</div>
        <h3 class="text-lg font-bold mb-3" style="color: #0C1B38;">Corridor Layer</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Distributed ledger — 54 bilateral AU member corridors for inter-central-bank settlement. Real-time FX rate resolution, LiquidityLock reserve backing, SHA-256 Merkle tree integrity, and PAPSS / RTGS gateway integration.</p>
      </div>

    </div>

    <%# Two-component callout %>
    <div class="mt-10 rounded-2xl border border-gray-100 shadow-sm overflow-hidden reveal">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="p-8 border-b md:border-b-0 md:border-r border-gray-100">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(12,27,56,0.08);">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" style="color: #0C1B38;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17H3a2 2 0 01-2-2V5a2 2 0 012-2h14a2 2 0 012 2v10a2 2 0 01-2 2h-2"/>
              </svg>
            </div>
            <div class="text-xs font-semibold tracking-widest uppercase" style="color: #C9A84C;">Component 1</div>
          </div>
          <h4 class="font-bold text-base mb-2" style="color: #0C1B38;">Qt6 Desktop Application</h4>
          <p class="text-gray-500 text-sm leading-relaxed mb-3">Runs on Central Bank workstations (macOS ARM64). Mints, cryptographically signs, and delivers CBDC banknote files to commercial banks via email or SFTP.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-2 py-1 rounded-full font-mono" style="background: rgba(12,27,56,0.06); color: #0C1B38;">Qt6 / C++17</span>
            <span class="text-xs px-2 py-1 rounded-full font-mono" style="background: rgba(12,27,56,0.06); color: #0C1B38;">libsodium</span>
            <span class="text-xs px-2 py-1 rounded-full font-mono" style="background: rgba(12,27,56,0.06); color: #0C1B38;">Crypto++</span>
            <span class="text-xs px-2 py-1 rounded-full font-mono" style="background: rgba(12,27,56,0.06); color: #0C1B38;">OpenSSL 3</span>
          </div>
        </div>
        <div class="p-8">
          <div class="flex items-center gap-3 mb-4">
            <div class="w-8 h-8 rounded-lg flex items-center justify-center" style="background: rgba(201,168,76,0.12);">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M5 12h14M12 5l7 7-7 7"/>
              </svg>
            </div>
            <div class="text-xs font-semibold tracking-widest uppercase" style="color: #C9A84C;">Component 2</div>
          </div>
          <h4 class="font-bold text-base mb-2" style="color: #0C1B38;">Rails 7.1 API Backend</h4>
          <p class="text-gray-500 text-sm leading-relaxed mb-3">Cloud-hosted sovereign infrastructure. Handles validation, registry, issuance authorisation, FX corridors, governance, and audit exports. OAuth2 via Doorkeeper, background jobs via Sidekiq.</p>
          <div class="flex flex-wrap gap-2">
            <span class="text-xs px-2 py-1 rounded-full font-mono" style="background: rgba(201,168,76,0.1); color: #0C1B38;">Ruby 3.3.6</span>
            <span class="text-xs px-2 py-1 rounded-full font-mono" style="background: rgba(201,168,76,0.1); color: #0C1B38;">Rails 7.1</span>
            <span class="text-xs px-2 py-1 rounded-full font-mono" style="background: rgba(201,168,76,0.1); color: #0C1B38;">PostgreSQL</span>
            <span class="text-xs px-2 py-1 rounded-full font-mono" style="background: rgba(201,168,76,0.1); color: #0C1B38;">Sidekiq</span>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>


<%# ─── CBDC BEARER INSTRUMENT ─────────────────────────────────────────────── %>
<section class="py-20 px-6" style="background: #F8F9FC;">
  <div class="max-w-5xl mx-auto" data-controller="fade-in">
    <div class="text-center mb-14">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Core Instrument</div>
      <h2 class="font-serif-display text-3xl md:text-4xl font-bold reveal" style="color: #0C1B38;">The CBDC Banknote</h2>
      <p class="text-gray-500 mt-4 max-w-2xl mx-auto leading-relaxed reveal reveal-delay-1">
        CBDC — Cryptographic Visual Image Banknote — is a PNG file that behaves exactly like physical cash. Possession of the file constitutes ownership. No bank account required.
      </p>
    </div>

    <%# Properties grid %>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">

      <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm reveal reveal-delay-1">
        <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Bearer Format</div>
        <p class="text-gray-600 text-sm leading-relaxed">File possession = ownership. No account balance, no ledger entry, no identity disclosure required to hold a CBDC note — identical to physical cash.</p>
      </div>

      <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm reveal reveal-delay-1">
        <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Visual Authenticity</div>
        <p class="text-gray-600 text-sm leading-relaxed">Rendered with denomination graphics, Central Bank branding, serial number printed on face, 55×55 px encrypted QR code, and Code 128 barcode.</p>
      </div>

      <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm reveal reveal-delay-2">
        <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Ed25519 Signature</div>
        <p class="text-gray-600 text-sm leading-relaxed">Every note is digitally signed by the issuing Central Bank's primary key. Any party holding the public key can verify authenticity — offline, without platform access.</p>
      </div>

      <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm reveal reveal-delay-2">
        <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Embedded Metadata</div>
        <p class="text-gray-600 text-sm leading-relaxed">Serial number, denomination, issuer, timestamps, holder ID, manifest hash — all stored in the PNG iTXt chunk as zlib-compressed <code class="text-xs">key=value</code> pairs.</p>
      </div>

      <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm reveal reveal-delay-3">
        <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Vault Encryption</div>
        <p class="text-gray-600 text-sm leading-relaxed">Sensitive mint data is AES-256-GCM encrypted inside the PNG. The note can be publicly inspected; the vault payload requires the Central Bank's decryption key.</p>
      </div>

      <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm reveal reveal-delay-3">
        <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">DLT Anchoring</div>
        <p class="text-gray-600 text-sm leading-relaxed">Every CBDC note is registered on the distributed ledger at issuance. State changes — transfer, redemption, burn — are anchored as immutable events.</p>
      </div>

    </div>

    <%# Lifecycle strip %>
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-7 reveal">
      <div class="text-xs font-semibold tracking-widest uppercase mb-5" style="color: #C9A84C;">Note Lifecycle States</div>
      <div class="flex flex-wrap items-center gap-2">
        <% ["MINTED", "ISSUED", "TRANSFERRED", "REDEEMED", "BURNED"].each_with_index do |state, i| %>
          <div class="flex items-center gap-2">
            <span class="px-3 py-1.5 rounded-full text-xs font-semibold font-mono
              <%= i == 0 ? 'text-white' : (i == 4 ? 'text-white' : '') %>"
              style="<%= i == 0 ? 'background: #0C1B38;' : (i == 4 ? 'background: #7f1d1d; opacity: 0.85;' : 'background: rgba(201,168,76,0.15); color: #0C1B38;') %>">
              <%= state %>
            </span>
            <% if i < 4 %>
              <svg xmlns="http://www.w3.org/2000/svg" class="h-3 w-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
              </svg>
            <% end %>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>


<%# ─── CRYPTOGRAPHIC STACK ────────────────────────────────────────────────── %>
<section class="py-20 px-6 bg-white">
  <div class="max-w-5xl mx-auto" data-controller="fade-in">
    <div class="text-center mb-12">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Security Architecture</div>
      <h2 class="font-serif-display text-3xl md:text-4xl font-bold reveal" style="color: #0C1B38;">Cryptographic Stack</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

      <div class="rounded-2xl p-7 border border-gray-100 shadow-sm reveal reveal-delay-1">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background: rgba(201,168,76,0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
            </svg>
          </div>
          <div>
            <div class="font-bold text-sm mb-1" style="color: #0C1B38;">Ed25519 · Issuance Signing</div>
            <div class="text-xs font-mono text-gray-400 mb-3">IETF RFC 8037 · 128-bit security · libsodium</div>
            <p class="text-gray-500 text-sm leading-relaxed">Every CBDC note is signed by the issuing Central Bank using libsodium Ed25519. The 32-byte public key can be published in a government gazette. Signature verification requires no platform access — any party can confirm authenticity independently. Private keys are server-side only; the Qt desktop client never generates keys, only verifies.</p>
          </div>
        </div>
      </div>

      <div class="rounded-2xl p-7 border border-gray-100 shadow-sm reveal reveal-delay-1">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background: rgba(201,168,76,0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
            </svg>
          </div>
          <div>
            <div class="font-bold text-sm mb-1" style="color: #0C1B38;">AES-256-GCM · Vault Encryption</div>
            <div class="text-xs font-mono text-gray-400 mb-3">Authenticated encryption · Crypto++ AutoSeededRandomPool</div>
            <p class="text-gray-500 text-sm leading-relaxed">Mint data is encrypted at rest per note. Key, IV, and ciphertext (<code class="text-xs">encKey</code>, <code class="text-xs">encIv</code>, <code class="text-xs">ciphermint</code>) are stored as hex strings in the PNG iTXt chunk. The note can transit public channels; the vault payload is inaccessible without the Central Bank's vault key.</p>
          </div>
        </div>
      </div>

      <div class="rounded-2xl p-7 border border-gray-100 shadow-sm reveal reveal-delay-2">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background: rgba(201,168,76,0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1zM5 20h2a1 1 0 001-1v-2a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1z"/>
            </svg>
          </div>
          <div>
            <div class="font-bold text-sm mb-1" style="color: #0C1B38;">AES-128-GCM · QR Payload</div>
            <div class="text-xs font-mono text-gray-400 mb-3">zlib compress → AES-GCM encrypt → Base64URL encode</div>
            <p class="text-gray-500 text-sm leading-relaxed">Each 55×55 px QR code encodes a 6-field compact JSON payload (transaction ID, entities, timestamp, serial, amount), zlib-compressed and AES-128-GCM encrypted, rendered as a Base64URL string under 350 characters. Decryption requires the QR shared key.</p>
          </div>
        </div>
      </div>

      <div class="rounded-2xl p-7 border border-gray-100 shadow-sm reveal reveal-delay-2">
        <div class="flex items-start gap-4">
          <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background: rgba(201,168,76,0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1"/>
            </svg>
          </div>
          <div>
            <div class="font-bold text-sm mb-1" style="color: #0C1B38;">SHA-256 · Manifest &amp; Blockchain</div>
            <div class="text-xs font-mono text-gray-400 mb-3">Merkle tree · Unique Mint Hash IDs · double-spend prevention</div>
            <p class="text-gray-500 text-sm leading-relaxed">Every batch produces a SHA-256 manifest hash covering all note payloads. The distributed ledger builds a Merkle tree of these hashes, anchoring each block's integrity. Duplicate detection compares Unique Mint Hash IDs before any note enters the registry.</p>
          </div>
        </div>
      </div>

    </div>

    <%# Authenticity proof steps %>
    <div class="mt-10 rounded-2xl border border-gray-100 shadow-sm p-8 reveal">
      <div class="text-xs font-semibold tracking-widest uppercase mb-6" style="color: #C9A84C;">Offline Authenticity Verification — Four Steps</div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-4">
        <% [
          ["01", "Extract Metadata", "Read PNG iTXt 'Comment' chunk; zlib-decompress; parse key=value pairs"],
          ["02", "Reconstruct Payload", "Concatenate serialNumber + denomination + asset_code + issued_at + batch_id in canonical form"],
          ["03", "Verify Signature", "Verify issuer_sig against the canonical payload using the Central Bank's published Ed25519 public key"],
          ["04", "Check Registry", "Cross-reference serial against the national CBDC registry to confirm the note has not been redeemed or burned"]
        ].each do |step, title, desc| %>
          <div>
            <div class="font-mono text-xs mb-2" style="color: #C9A84C;"><%= step %></div>
            <div class="font-bold text-sm mb-2" style="color: #0C1B38;"><%= title %></div>
            <p class="text-gray-500 text-xs leading-relaxed"><%= desc %></p>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>


<%# ─── MINTING PIPELINE ────────────────────────────────────────────────────── %>
<section class="py-20 px-6" style="background: linear-gradient(135deg, #0C1B38 0%, #152545 100%);">
  <div class="max-w-5xl mx-auto" data-controller="fade-in">
    <div class="text-center mb-14">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Issuance</div>
      <h2 class="font-serif-display text-3xl md:text-4xl font-bold text-white reveal">CBDC Minting Pipeline</h2>
      <p class="text-gray-400 mt-4 max-w-xl mx-auto leading-relaxed reveal reveal-delay-1">
        End-to-end issuance from governance authorisation to commercial bank delivery — executed on the Central Bank's Qt6 desktop workstation.
      </p>
    </div>

    <div class="space-y-3">
      <% [
        ["Authorize Package", "Governance-gated issuance request. Rails API returns batch_id and note payloads after Four-Eyes dual-operator approval.", "POST /issuance_authorizations/{auth_code}/cvib_batches"],
        ["Load Template", "Denomination blank image loaded from Central Bank asset library. Denomination value rendered onto image in national currency."],
        ["Serial Number Generation", "Pattern-based unique serial number generated per note. Embedded visually on the note face and in metadata."],
        ["Embed Metadata", "All note fields written to PNG iTXt 'Comment' chunk as zlib-compressed key=value pairs: serial, denomination, issuer, timestamps, signature, manifest hash."],
        ["Generate QR + Barcode", "55×55 px AES-128-GCM encrypted QR code overlaid. Code 128 barcode encodes ISO3166:serial:position:height:holderId."],
        ["Apply CBDC Mode", "Production mode: full size, no watermarks. Sandbox/Pilot/Specimen: 70% size, diagonal 'SPECIMEN' watermark, red border — below legal tender threshold."],
        ["Package &amp; Deliver", "ZIP of PNGs + manifest.json built; SHA-256 manifest hash confirmed with Rails API. Bundle delivered to commercial bank via encrypted email or SFTP.", "POST /cvib_batches/{batch_id}/confirm_manifest"]
      ].each_with_index do |(title, desc, endpoint), i| %>
        <div class="flex items-start gap-5 rounded-2xl p-6 reveal"
             style="background: rgba(255,255,255,0.05);">
          <div class="w-9 h-9 rounded-lg flex-shrink-0 flex items-center justify-center font-bold text-sm font-mono"
               style="background: rgba(201,168,76,0.2); color: #C9A84C;">
            <%= '%02d' % (i + 1) %>
          </div>
          <div class="flex-1 min-w-0">
            <div class="font-bold text-sm text-white mb-1"><%= title.html_safe %></div>
            <p class="text-gray-400 text-sm leading-relaxed"><%= desc %></p>
            <% if endpoint %>
              <code class="block mt-2 text-xs font-mono" style="color: #C9A84C; opacity: 0.8;"><%= endpoint %></code>
            <% end %>
          </div>
        </div>
      <% end %>
    </div>
  </div>
</section>


<%# ─── VALIDATION PIPELINE ────────────────────────────────────────────────── %>
<section class="py-20 px-6" style="background: #F8F9FC;">
  <div class="max-w-5xl mx-auto" data-controller="fade-in">
    <div class="text-center mb-14">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Validation Desk</div>
      <h2 class="font-serif-display text-3xl md:text-4xl font-bold reveal" style="color: #0C1B38;">Five-Stage Validation Pipeline</h2>
      <p class="text-gray-500 mt-4 max-w-xl mx-auto leading-relaxed reveal reveal-delay-1">
        Every inbound CBDC note traverses five mandatory stages before registry acceptance. Triggered server-side via a single API call.
      </p>
      <code class="block mt-3 text-xs font-mono reveal reveal-delay-2" style="color: #C9A84C;">POST /api/v2/validation/pipeline/run</code>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-5 gap-4">
      <% [
        ["Format Detection", "Magic bytes check: PNG (89 50 4E 47) or JPEG (FF D8). Never file extension.", "1"],
        ["Metadata Extraction", "iTXt 'Comment' chunk read. zlib-decompressed if comp_flag=1. key=value pairs parsed.", "2"],
        ["Duplicate Check", "Serial cross-referenced against the CBDC Registry. Unique Mint Hash ID match rejects replay attacks.", "3"],
        ["Signature Verification", "Ed25519 issuer_sig verified against canonical payload using stored IssuerKey.", "4"],
        ["Registry Admission", "ValidationSession created, ValidationEvent audit entry written. State transitions to ISSUED.", "5"]
      ].each do |title, desc, step| %>
        <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm text-center reveal">
          <div class="w-10 h-10 rounded-full flex items-center justify-center text-white font-bold text-sm mx-auto mb-4"
               style="background: #0C1B38;">
            <%= step %>
          </div>
          <div class="font-bold text-sm mb-2" style="color: #0C1B38;"><%= title %></div>
          <p class="text-gray-500 text-xs leading-relaxed"><%= desc %></p>
        </div>
      <% end %>
    </div>

    <%# Validation actions %>
    <div class="mt-10 bg-white rounded-2xl border border-gray-100 shadow-sm p-7 reveal">
      <div class="text-xs font-semibold tracking-widest uppercase mb-5" style="color: #C9A84C;">Post-Validation Actions</div>
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
        <% [
          ["Approve", "/api/v2/validation/approve"],
          ["Reject", "/api/v2/validation/reject"],
          ["Freeze", "/api/v2/validation/freeze"],
          ["Flag", "/api/v2/validation/flag"]
        ].each do |action, path| %>
          <div class="rounded-xl p-3 text-center" style="background: rgba(12,27,56,0.04);">
            <div class="font-bold text-sm mb-1" style="color: #0C1B38;"><%= action %></div>
            <code class="text-xs font-mono text-gray-400"><%= path %></code>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</section>


<%# ─── GOVERNANCE & MONETARY CONTROLS ─────────────────────────────────────── %>
<section class="py-20 px-6 bg-white">
  <div class="max-w-5xl mx-auto" data-controller="fade-in">
    <div class="text-center mb-14">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Governance</div>
      <h2 class="font-serif-display text-3xl md:text-4xl font-bold reveal" style="color: #0C1B38;">Sovereign Monetary Controls</h2>
      <p class="text-gray-500 mt-4 max-w-2xl mx-auto leading-relaxed reveal reveal-delay-1">
        All monetary supply actions require on-chain governance votes with quorum thresholds — mirroring the legal and institutional safeguards Central Banks apply to physical currency issuance.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">

      <div class="rounded-2xl p-8 border border-gray-100 shadow-sm reveal reveal-delay-1">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(201,168,76,0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4"/>
            </svg>
          </div>
          <div class="font-bold text-base" style="color: #0C1B38;">Supply Expansion — Issuance</div>
        </div>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full mt-2 flex-shrink-0" style="background: #C9A84C;"></div>
            <p class="text-gray-500 text-sm leading-relaxed"><strong class="text-gray-700">Issuance Cap:</strong> Governance-set ceiling per corridor. Raising the cap requires ≥3/5 board seats — analogous to the statutory limit on banknote printing.</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full mt-2 flex-shrink-0" style="background: #C9A84C;"></div>
            <p class="text-gray-500 text-sm leading-relaxed"><strong class="text-gray-700">100% Reserve Backing:</strong> Every issuance must be backed by an ACTIVE LiquidityLock — the digital equivalent of backing banknotes with gold reserves.</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full mt-2 flex-shrink-0" style="background: #C9A84C;"></div>
            <p class="text-gray-500 text-sm leading-relaxed"><strong class="text-gray-700">Four-Eyes Approval:</strong> Dual-operator authentication required. No single authority can create new money unilaterally.</p>
          </div>
        </div>
      </div>

      <div class="rounded-2xl p-8 border border-gray-100 shadow-sm reveal reveal-delay-2">
        <div class="flex items-center gap-3 mb-5">
          <div class="w-10 h-10 rounded-xl flex items-center justify-center" style="background: rgba(201,168,76,0.12);">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M20 12H4"/>
            </svg>
          </div>
          <div class="font-bold text-base" style="color: #0C1B38;">Supply Contraction — Burn</div>
        </div>
        <div class="space-y-3">
          <div class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full mt-2 flex-shrink-0" style="background: #C9A84C;"></div>
            <p class="text-gray-500 text-sm leading-relaxed"><strong class="text-gray-700">≥67% Governance Quorum:</strong> Highest threshold in the system — mirrors the physical dual-custodian requirement for note destruction.</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full mt-2 flex-shrink-0" style="background: #C9A84C;"></div>
            <p class="text-gray-500 text-sm leading-relaxed"><strong class="text-gray-700">Governor + Deputy Dual Signature:</strong> Both principals must authenticate simultaneously before any burn executes.</p>
          </div>
          <div class="flex items-start gap-3">
            <div class="w-1.5 h-1.5 rounded-full mt-2 flex-shrink-0" style="background: #C9A84C;"></div>
            <p class="text-gray-500 text-sm leading-relaxed"><strong class="text-gray-700">DLT Destruction Seal:</strong> Permanent on-chain record proves supply reduction is irreversible. Circulating supply updates in real time.</p>
          </div>
        </div>
      </div>

    </div>

    <%# Sovereignty rule %>
    <div class="rounded-2xl p-7 reveal" style="background: linear-gradient(135deg, #0C1B38 0%, #152545 100%);">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Sovereign Authority Rule</div>
      <p class="text-white text-sm leading-relaxed max-w-3xl">
        Every participating Central Bank holds the exclusive cryptographic authority to mint CBDC digital banknotes denominated in its own national unit of account. No node can unilaterally issue the currency of another member nation. Legal accountability is therefore unambiguous: the issuing Central Bank is always the sovereign authority, and its Ed25519 signing key is the cryptographic proof of that authority.
      </p>
    </div>
  </div>
</section>


<%# ─── OFFLINE-FIRST & FINANCIAL INCLUSION ────────────────────────────────── %>
<section class="py-20 px-6" style="background: #F8F9FC;">
  <div class="max-w-5xl mx-auto" data-controller="fade-in">
    <div class="text-center mb-14">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Inclusion by Design</div>
      <h2 class="font-serif-display text-3xl md:text-4xl font-bold reveal" style="color: #0C1B38;">Offline-First by Design</h2>
      <p class="text-gray-500 mt-4 max-w-2xl mx-auto leading-relaxed reveal reveal-delay-1">
        Because a CBDC note is a file, it can be transferred via any channel that can move data — encrypted email, SFTP, Bluetooth, NFC, USB, or SD card. A decisive advantage across the 54 African Union corridors where connectivity is intermittent.
      </p>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-10">
      <% [
        ["No Bank Account", "File possession = ownership. No account, no identity disclosure required to hold a CBDC note.", "reveal reveal-delay-1"],
        ["No Smartphone", "CBDC files transfer via USB, SD card, NFC, Bluetooth, email, or SMS attachment — any data transport.", "reveal reveal-delay-2"],
        ["No Internet", "Fully offline capable. Registry sync happens retroactively when connectivity returns.", "reveal reveal-delay-2"],
        ["Low Financial Literacy", "Visual banknote format — recognisable denomination graphic, serial number printed on face.", "reveal reveal-delay-3"],
        ["Informal Economy", "Bearer instrument — no identity linkage required to hold. Linkage only at point of redemption.", "reveal reveal-delay-3"],
        ["Rural Agents", "CBDC bundle delivered via SFTP/email. Agents distribute notes to customers with zero real-time connectivity.", "reveal reveal-delay-4"]
      ].each do |title, desc, reveal_class| %>
        <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm <%= reveal_class %>">
          <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;"><%= title %></div>
          <p class="text-gray-600 text-sm leading-relaxed"><%= desc %></p>
        </div>
      <% end %>
    </div>

    <%# Case study %>
    <div class="bg-white rounded-2xl border border-gray-100 shadow-sm p-8 reveal">
      <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: #C9A84C;">Field Case Study</div>
      <blockquote class="text-gray-600 leading-relaxed text-sm max-w-3xl">
        In a rural corridor village with no mobile network, a farmer receives payment of 5,000 NGN in CBDC notes transferred via a merchant's tablet over local Bluetooth. The farmer holds the CBDC files on a USB drive. Three weeks later, at the nearest town market, a CBDC-enabled terminal verifies the Ed25519 signature offline and accepts the notes. The farmer has participated in the digital monetary system without ever having a bank account, internet connection, or smartphone.
      </blockquote>
      <div class="mt-4 text-xs text-gray-400 italic">bearerCORE™ Platform Manual, April 2026 — TowerPoint Group</div>
    </div>
  </div>
</section>


