      </div>

      <div class="rounded-2xl p-7 reveal reveal-delay-3" style="background: rgba(255,255,255,0.07);">
        <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: #C9A84C;">Regional Interoperability</div>
