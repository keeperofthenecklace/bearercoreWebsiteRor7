<%# ─── PAGE HEADER ────────────────────────────────────────────────────────── %>
<section class="bg-white border-b border-gray-100"
         style="padding-top: 120px; padding-bottom: 64px;">
  <div class="max-w-4xl mx-auto px-6 text-center">
    <div class="text-xs font-semibold tracking-widest uppercase mb-4" style="color: #C9A84C;">Technical Overview</div>
    <h1 class="font-serif-display text-4xl md:text-5xl font-bold mb-5" style="color: #0C1B38; letter-spacing: -0.02em;">
      Platform Architecture &amp; Security
    </h1>
    <p class="text-xl text-gray-500 max-w-2xl mx-auto leading-relaxed">
      For Central Bank IT teams and implementation partners. A complete view of the cryptographic, operational, and compliance architecture underpinning bearerCORE.
    </p>
    <div class="flex items-center justify-center gap-4 mt-8">
      <a href="/docs"
         class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-semibold transition-all hover:opacity-90"
         style="background: #0C1B38; color: white;">
        Platform Documentation
        <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"/>
        </svg>
      </a>
      <a href="/"
         class="text-sm text-gray-400 hover:text-gray-600 transition-colors">
        ← Back to home
      </a>
    </div>
  </div>
</section>


<%# ─── PITCH QUOTE ────────────────────────────────────────────────────────── %>
<section style="background: linear-gradient(135deg, #0C1B38 0%, #152545 100%);" class="py-20 px-6">
  <div class="max-w-4xl mx-auto text-center">
    <div class="text-xs font-semibold tracking-widest uppercase mb-6" style="color: #C9A84C;">The Platform</div>
    <blockquote class="text-2xl md:text-3xl font-light text-white leading-relaxed mb-10">
      "A robust digital currency platform designed for ease-of-use and low-literacy inclusion, enabling instant peer-to-peer transfers using existing monetary principles."
    </blockquote>
    <div class="w-16 h-px mx-auto" style="background: #C9A84C; opacity: 0.4;"></div>
  </div>
</section>


<%# ─── CORE CAPABILITIES GRID ─────────────────────────────────────────────── %>
<section class="py-20 px-6 bg-white">
  <div class="max-w-6xl mx-auto">
    <div class="text-center mb-14">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Core Capabilities</div>
      <h2 class="font-serif-display text-3xl md:text-4xl font-bold" style="color: #0C1B38;">Built for Monetary Sovereignty</h2>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">

      <div class="rounded-2xl p-7 border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200">
        <div class="inline-flex items-center justify-center w-11 h-11 rounded-xl mb-5" style="background: rgba(12,27,56,0.07);">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #0C1B38;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12l2 2 4-4m5.618-4.016A11.955 11.955 0 0112 2.944a11.955 11.955 0 01-8.618 3.04A12.02 12.02 0 003 9c0 5.591 3.824 10.29 9 11.622 5.176-1.332 9-6.03 9-11.622 0-1.042-.133-2.052-.382-3.016z"/>
          </svg>
        </div>
        <div class="text-xs font-semibold tracking-widest mb-2" style="color: #C9A84C;">PRIVACY</div>
        <h3 class="text-base font-bold mb-3" style="color: #0C1B38;">No account tracking, just digital cash</h3>
        <p class="text-gray-500 text-sm leading-relaxed">CVIB banknotes carry cryptographic identity without exposing user data. Bearer instruments — like physical cash — by design.</p>
      </div>

      <div class="rounded-2xl p-7 border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200">
        <div class="inline-flex items-center justify-center w-11 h-11 rounded-xl mb-5" style="background: rgba(12,27,56,0.07);">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #0C1B38;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z"/>
          </svg>
        </div>
        <div class="text-xs font-semibold tracking-widest mb-2" style="color: #C9A84C;">SIMPLICITY</div>
        <h3 class="text-base font-bold mb-3" style="color: #0C1B38;">Designed for every user</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Offline-capable, low-bandwidth, and accessible to unbanked and low-literacy users across urban and rural Africa.</p>
      </div>

      <div class="rounded-2xl p-7 border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200">
        <div class="inline-flex items-center justify-center w-11 h-11 rounded-xl mb-5" style="background: rgba(12,27,56,0.07);">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #0C1B38;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
        </div>
        <div class="text-xs font-semibold tracking-widest mb-2" style="color: #C9A84C;">COMPLIANCE</div>
        <h3 class="text-base font-bold mb-3" style="color: #0C1B38;">Architected for Central Bank standards</h3>
        <p class="text-gray-500 text-sm leading-relaxed">Ed25519-signed issuance, AES-256-GCM vault encryption, full audit trails, and governance voting built in from day one.</p>
      </div>

      <div class="rounded-2xl p-7 border border-gray-100 shadow-sm hover:shadow-md hover:-translate-y-1 transition-all duration-200">
        <div class="inline-flex items-center justify-center w-11 h-11 rounded-xl mb-5" style="background: rgba(12,27,56,0.07);">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #0C1B38;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.8">
            <path stroke-linecap="round" stroke-linejoin="round" d="M13 10V3L4 14h7v7l9-11h-7z"/>
          </svg>
        </div>
        <div class="text-xs font-semibold tracking-widest mb-2" style="color: #C9A84C;">INDEPENDENCE</div>
        <h3 class="text-base font-bold mb-3" style="color: #0C1B38;">Works outside banking walls</h3>
        <p class="text-gray-500 text-sm leading-relaxed">No SWIFT dependency. No correspondent bank required. Sovereign infrastructure that a Central Bank owns and controls end-to-end.</p>
      </div>

    </div>
  </div>
</section>


<%# ─── CRYPTOGRAPHIC STACK ────────────────────────────────────────────────── %>
<section class="py-20 px-6" style="background: #F8F9FC;">
  <div class="max-w-5xl mx-auto">
    <div class="text-center mb-12">
      <div class="text-xs font-semibold tracking-widest uppercase mb-3" style="color: #C9A84C;">Security Architecture</div>
      <h2 class="font-serif-display text-3xl font-bold" style="color: #0C1B38;">Cryptographic Stack</h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

      <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm flex items-start gap-5">
        <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background: rgba(201,168,76,0.12);">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z"/>
          </svg>
        </div>
        <div>
          <div class="font-bold text-sm mb-1" style="color: #0C1B38;">Ed25519 Digital Signatures</div>
          <p class="text-gray-500 text-sm leading-relaxed">Every CVIB banknote is signed by the issuing Central Bank using libsodium Ed25519. Signature is embedded in the PNG iTXt chunk and verified on ingest.</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm flex items-start gap-5">
        <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background: rgba(201,168,76,0.12);">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
          </svg>
        </div>
        <div>
          <div class="font-bold text-sm mb-1" style="color: #0C1B38;">AES-256-GCM Vault Encryption</div>
          <p class="text-gray-500 text-sm leading-relaxed">Mint data is encrypted at rest in per-note vaults. Key, IV, and ciphertext are embedded in the PNG. Decryption requires the Central Bank vault key.</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm flex items-start gap-5">
        <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background: rgba(201,168,76,0.12);">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 7v10c0 2.21 3.582 4 8 4s8-1.79 8-4V7M4 7c0 2.21 3.582 4 8 4s8-1.79 8-4M4 7c0-2.21 3.582-4 8-4s8 1.79 8 4"/>
          </svg>
        </div>
        <div>
          <div class="font-bold text-sm mb-1" style="color: #0C1B38;">Immutable Audit Ledger</div>
          <p class="text-gray-500 text-sm leading-relaxed">Every action against a ValidationSession generates an append-only ValidationEvent record. Exportable as signed logs for regulatory review.</p>
        </div>
      </div>

      <div class="bg-white rounded-2xl p-6 border border-gray-100 shadow-sm flex items-start gap-5">
        <div class="w-10 h-10 rounded-xl flex-shrink-0 flex items-center justify-center" style="background: rgba(201,168,76,0.12);">
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" style="color: #C9A84C;" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 17v-2m3 2v-4m3 4v-6m2 10H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
          </svg>
        </div>
        <div>
          <div class="font-bold text-sm mb-1" style="color: #0C1B38;">On-Chain Governance</div>
          <p class="text-gray-500 text-sm leading-relaxed">Policy changes, FX corridor updates, and issuance authorizations are governed by GovernanceProposal / GovernanceVote — fully auditable by all participants.</p>
        </div>
      </div>

    </div>
  </div>
</section>


<%# ─── CTA BACK TO HOME ───────────────────────────────────────────────────── %>
<section class="py-20 px-6 bg-white border-t border-gray-100">
  <div class="max-w-xl mx-auto text-center">
    <h2 class="font-serif-display text-2xl font-bold mb-4" style="color: #0C1B38;">Ready to brief your Governor?</h2>
    <p class="text-gray-500 mb-8">Schedule a private session with our team and receive the full technical dossier for your jurisdiction.</p>
    <div class="flex flex-col sm:flex-row items-center justify-center gap-4">
      <a href="mailto:governors@bearercore.com?subject=Governor%27s%20Briefing%20Request"
         class="inline-flex items-center gap-3 px-8 py-4 rounded-full text-base font-semibold transition-all hover:opacity-90"
