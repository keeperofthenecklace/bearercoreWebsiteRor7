                <td class="px-6 py-4 text-gray-500"><%= note %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    </div>
  </div>
</section>


<%# ─── CROSS-BORDER CORRIDORS ─────────────────────────────────────────────── %>
<section class="py-20 px-6" style="background: linear-gradient(135deg, #0C1B38 0%, #152545 100%);">
