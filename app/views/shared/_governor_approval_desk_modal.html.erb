  await govAlert({
    tag:     'Halt Initiated',
    title:   'Corridor Suspended',
    message: `<strong style="color:#fff;">${govSelectedCorridorLabel}</strong> has been suspended. Audit log entry recorded.<br><br><span style="font-size:11px;color:rgba(255,255,255,0.4);font-family:monospace;">POST /api/v2/corridors/${govSelectedCorridorId}/halt</span>`,
    danger:  true,
  });
}

