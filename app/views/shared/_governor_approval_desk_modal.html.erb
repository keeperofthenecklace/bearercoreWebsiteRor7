// ── Regional bloc membership ─────────────────────────────────────────────────
const GOV_BLOCS = {
  'ECOWAS': ['NGA','GHA','SEN','CIV','BEN','TGO','MLI','BFA','NER','GIN','SLE','GMB','LBR','GNB','CPV'],
  'EAC':    ['KEN','TZA','UGA','RWA','BDI','SSD'],
  'SADC':   ['ZAF','ZWE','ZMB','MOZ','MWI','BWA','NAM','LSO','SWZ','AGO','MDG','MUS'],
  'CEMAC':  ['CMR','CAF','COG','GAB','GNQ','TCD'],
  'AMU':    ['MAR','DZA','TUN','LBY','MRT'],
  'IGAD':   ['ETH','SOM','DJI','ERI','SDN'],
};

function govGetBloc(isoCode) {
  const code = (isoCode || '').toUpperCase().slice(0, 3);
  for (const [bloc, members] of Object.entries(GOV_BLOCS)) {
    if (members.includes(code)) return bloc;
  }
  return 'Other';
}

let govCorridorLiquidityData = [];
let govSelectedCorridorId    = '';
let govSelectedCorridorLabel = '';

// ── Build grouped corridor listbox ──────────────────────────────────────────
function govBuildCorridorSelect(corridors) {
  const sel = document.getElementById('govCorridorSelect');
  if (!sel) return;

  const term     = (document.getElementById('govCorridorSearch')?.value || '').toLowerCase();
  const filtered = term
    ? corridors.filter(c => {
        const d = (c.corridor_display || c.code || `${c.source_country}→${c.target_country}`).toLowerCase();
        return d.includes(term);
      })
    : corridors;

  // Group by bloc
  const groups = {};
  filtered.forEach(c => {
    const bloc = govGetBloc(c.source_country);
    if (!groups[bloc]) groups[bloc] = [];
    groups[bloc].push(c);
  });

  sel.innerHTML = '';

  if (filtered.length === 0) {
    const opt = document.createElement('option');
    opt.value = '';
    opt.textContent = '— No corridors found —';
    opt.style.background = '#0f2744';
    sel.appendChild(opt);
    return;
  }

  const orderedBlocs = [...Object.keys(GOV_BLOCS), 'Other'].filter(b => groups[b]?.length > 0);

  orderedBlocs.forEach(bloc => {
    const group = document.createElement('optgroup');
    group.label = `— ${bloc} —`;

    groups[bloc].forEach(c => {
      const display = c.corridor_display || c.code || `${c.source_country} → ${c.target_country}`;
      const id      = c.id || c.code;
      const opt     = document.createElement('option');
      opt.value       = id;
      opt.textContent = display;
      opt.style.background = '#0f2744';
      group.appendChild(opt);
    });

    sel.appendChild(group);
  });

  // Restore previously selected corridor
  if (govSelectedCorridorId) sel.value = govSelectedCorridorId;
}

function govFilterCorridors() {
  govBuildCorridorSelect(govCorridorLiquidityData);
}

// ── Corridor selected from listbox ──────────────────────────────────────────
function govSelectCorridor(id, label) {
  if (!id) return;
  govSelectedCorridorId    = id;
  govSelectedCorridorLabel = (label || id).trim();

  const lbl = document.getElementById('govQuickActionsCorridorLabel');
  if (lbl) lbl.textContent = `Corridor: ${govSelectedCorridorLabel}`;

  loadCorridorGauge(id);
}

// ── Single-corridor fuel gauge ───────────────────────────────────────────────
async function loadCorridorGauge(corridorId) {
  const content = document.getElementById('govFuelGaugeContent');
  if (!content) return;
  content.innerHTML = '<div style="color:#475569;font-size:13px;text-align:center;padding:20px;">⏳ Loading…</div>';

  let pos = null;
  try {
    const res = await fetch(`/api/v2/corridors/${corridorId}/liquidity_position`, {
      headers: getGovernorAuthHeaders()
    });
    if (res.ok) {
      const data = await res.json();
      pos = data.data || data.liquidity_position || data;
    }
  } catch (_) {}

  if (!pos || typeof pos !== 'object' || Object.keys(pos).length === 0) {
    const cached = govCorridorLiquidityData.find(c => String(c.id || c.code) === String(corridorId));
    pos = cached?.liquidity_position || cached?.liquidity_snapshot || cached || {};
  }

  renderSingleCorridorGauge(pos, govSelectedCorridorLabel);
}

function renderSingleCorridorGauge(pos, corridorLabel) {
  const content = document.getElementById('govFuelGaugeContent');
  if (!content) return;

  const total       = parseFloat(pos.domestic_available || pos.domestic || pos.total_liquidity || 0);
  const linked      = parseFloat(pos.linked_outstanding || pos.linked || 0);
  const headroom    = Math.max(0, total - linked);
  const drawdownPct = total > 0 ? Math.min(100, Math.round((linked / total) * 100)) : 0;
  const headroomPct = 100 - drawdownPct;
  const currency    = pos.asset_code || pos.currency || '';

  const barColor   = headroomPct < 10 ? '#dc2626' : headroomPct < 30 ? '#f59e0b' : '#0d9488';
  const statusText = headroomPct < 10 ? '⚠ REPLENISH REQUIRED'
                   : headroomPct < 30 ? '⚡ LOW RESERVE'
                   : '✓ HEALTHY';
  const statusColor = headroomPct < 10 ? '#fca5a5' : headroomPct < 30 ? '#fbbf24' : '#2dd4bf';
  const fmtNum = n => n ? n.toLocaleString(undefined, { maximumFractionDigits: 0 }) : '—';
  const hasData = total > 0;

  content.innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:10px;">
      <div>
        <div style="font-size:13px;font-weight:700;color:#e2e8f0;margin-bottom:2px;">${corridorLabel}</div>
        <div style="font-size:10px;font-weight:700;color:${statusColor};letter-spacing:0.5px;">${statusText}</div>
      </div>
      <div style="text-align:right;">
        <div style="font-size:22px;font-weight:800;color:${barColor};">${headroomPct}%</div>
        <div style="font-size:9px;color:#475569;text-transform:uppercase;">headroom</div>
      </div>
    </div>
    ${hasData ? `
    <div style="position:relative;height:18px;background:rgba(255,255,255,0.1);border-radius:9px;overflow:hidden;margin-bottom:12px;">
      <div style="position:absolute;top:0;left:0;bottom:0;width:${drawdownPct}%;background:${barColor};border-radius:9px;transition:width 0.6s ease;"></div>
      <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:rgba(255,255,255,0.9);">${drawdownPct}% drawn</div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
      <div style="text-align:center;background:rgba(255,255,255,0.04);border-radius:8px;padding:10px 6px;">
        <div style="font-size:9px;color:#475569;text-transform:uppercase;margin-bottom:4px;">Allotted</div>
        <div style="font-size:13px;font-weight:700;color:#e2e8f0;">${currency} ${fmtNum(total)}</div>
      </div>
      <div style="text-align:center;background:rgba(255,255,255,0.04);border-radius:8px;padding:10px 6px;">
        <div style="font-size:9px;color:#475569;text-transform:uppercase;margin-bottom:4px;">Drawn</div>
        <div style="font-size:13px;font-weight:700;color:${barColor};">${currency} ${fmtNum(linked)}</div>
      </div>
      <div style="text-align:center;background:rgba(0,212,192,0.08);border-radius:8px;padding:10px 6px;border:1px solid rgba(13,148,136,0.2);">
        <div style="font-size:9px;color:#475569;text-transform:uppercase;margin-bottom:4px;">Free</div>
        <div style="font-size:13px;font-weight:700;color:#2dd4bf;">${currency} ${fmtNum(headroom)}</div>
      </div>
    </div>` : `
    <div style="color:#475569;font-size:12px;text-align:center;padding:16px 0;background:rgba(255,255,255,0.03);border-radius:8px;">
      No liquidity data available for this corridor
    </div>`}`;
}

// ── Load corridors into grouped listbox ─────────────────────────────────────
async function loadGovCorridorLiquidity() {
  try {
    const res  = await fetch('/api/v2/corridors?per_page=50', { headers: getGovernorAuthHeaders() });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();

    // Rails envelope: { meta: {}, data: { corridors: [...] }, error: null }
    let corridors = [];
    if (Array.isArray(data))                                  corridors = data;
    else if (Array.isArray(data.data))                        corridors = data.data;
    else if (Array.isArray(data.corridors))                   corridors = data.corridors;
    else if (data.data && Array.isArray(data.data.corridors)) corridors = data.data.corridors;
    else if (data.data && Array.isArray(data.data.data))      corridors = data.data.data;

    console.log('[GovernorDesk] corridors loaded:', corridors.length);
    govCorridorLiquidityData = corridors;
    govBuildCorridorSelect(corridors);

    const tsEl = document.getElementById('govLastAuditTimestamp');
    if (tsEl) tsEl.textContent = new Date().toLocaleTimeString();
  } catch (err) {
    console.error('[GovernorDesk] corridor load error:', err);
    const sel = document.getElementById('govCorridorSelect');
    if (sel) sel.innerHTML = '<option value="" style="background:#0f2744;">⚠ Could not load corridors</option>';
  }
}

// ── Recent Bulk Allotments ───────────────────────────────────────────────────
async function loadGovRecentEvents() {
  const rows = document.getElementById('govRecentEventsRows');
  if (!rows) return;
  rows.innerHTML = '<div style="color:#475569;font-size:12px;text-align:center;padding:20px;">⏳ Loading…</div>';

  try {
    const res = await fetch('/api/v2/governance/proposals?category=bulk_allotment&per_page=5', {
      headers: getGovernorAuthHeaders()
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();

    let proposals = [];
    if (Array.isArray(data))                                  proposals = data;
    else if (Array.isArray(data.data))                        proposals = data.data;
    else if (data.data && Array.isArray(data.data.proposals)) proposals = data.data.proposals;
    else if (Array.isArray(data.proposals))                   proposals = data.proposals;

    renderGovRecentEvents(proposals);
  } catch (err) {
    if (rows) rows.innerHTML = `<div style="color:#f87171;font-size:12px;padding:12px;">⚠ ${err.message}</div>`;
  }
}

function renderGovRecentEvents(proposals) {
  const rows = document.getElementById('govRecentEventsRows');
  if (!rows) return;

  if (proposals.length === 0) {
    rows.innerHTML = '<div style="color:#475569;font-size:12px;text-align:center;padding:20px;">No bulk allotments on record.</div>';
    return;
  }

  rows.innerHTML = proposals.slice(0, 5).map(p => {
    const propId   = p.proposal_id || p.title || ('ALOT-' + (p.id || '').toString().slice(0, 8).toUpperCase());
    const amount   = parseFloat(p.new_cap || p.amount || 0);
    const corridor = p.corridor || p.corridor_name || '—';
    const status   = (p.status || 'pending').toLowerCase();
    const ts       = p.created_at || p.submitted_at || '';
    const dateStr  = ts ? new Date(ts).toLocaleDateString() : '—';
    const amtStr   = amount ? amount.toLocaleString(undefined, { maximumFractionDigits: 0 }) : '—';

    const statusColor = status === 'approved' ? '#2dd4bf'
                      : status === 'rejected' ? '#f87171'
                      : '#fbbf24';

    return `
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:8px;padding:9px 12px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:3px;">
          <span style="font-size:11px;font-weight:700;color:#e2e8f0;font-family:monospace;">${propId}</span>
          <span style="font-size:10px;font-weight:700;color:${statusColor};">${status.toUpperCase()}</span>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:10px;color:#64748b;">
          <span>${corridor}</span>
          <span>${amtStr} · ${dateStr}</span>
        </div>
      </div>`;
  }).join('');
}

// ── Corridor Halt (context-aware to selected corridor) ───────────────────────
async function govHaltCorridor() {
  if (!govSelectedCorridorId) {
    await govAlert({ tag:'Error', title:'No Corridor Selected', message:'Select a corridor from the list above before halting.', danger:true });
    return;
  }
  const confirmed = await govConfirmHalt(govSelectedCorridorLabel);
  if (!confirmed) {
    await govAlert({ tag:'Cancelled', title:'Halt Cancelled', message:'Confirmation code did not match. No action was taken.' });
    return;
