<script>
// ── Custom dialog system ──────────────────────────────────────────────────────
function govDialog({ tag, title, icon, body, buttons, danger }) {
  return new Promise(resolve => {
    const overlay  = document.getElementById('govDialogOverlay');
    const iconWrap = document.getElementById('govDialogIconWrap');
    document.getElementById('govDialogTag').textContent   = tag   || '';
    document.getElementById('govDialogTitle').textContent = title || '';
    iconWrap.innerHTML   = icon || '';
    iconWrap.style.cssText = danger
      ? 'width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(220,38,38,0.2);border:1px solid rgba(220,38,38,0.4);'
      : 'width:44px;height:44px;border-radius:12px;display:flex;align-items:center;justify-content:center;flex-shrink:0;background:rgba(201,168,76,0.18);border:1px solid rgba(201,168,76,0.35);';
    document.getElementById('govDialogBody').innerHTML = body || '';
    const footer = document.getElementById('govDialogFooter');
    footer.innerHTML = '';
    (buttons || [{ label:'OK', value:true, primary:true }]).forEach(btn => {
      const el = document.createElement('button');
      el.innerHTML = btn.label;
      el.style.cssText = btn.primary
        ? `padding:10px 22px;background:${danger ? 'linear-gradient(135deg,#dc2626,#b91c1c)' : 'linear-gradient(135deg,#C9A84C,#b8943f)'};color:${danger ? '#fff' : '#0C1B38'};border:none;border-radius:9px;font-size:13px;font-weight:700;cursor:pointer;letter-spacing:0.02em;transition:opacity 0.15s;`
        : `padding:10px 22px;background:transparent;border:1px solid rgba(255,255,255,0.18);color:rgba(255,255,255,0.65);border-radius:9px;font-size:13px;font-weight:600;cursor:pointer;transition:opacity 0.15s;`;
      el.onmouseenter = () => el.style.opacity = '0.82';
      el.onmouseleave = () => el.style.opacity = '1';
      if (btn.id) { el.id = btn.id; el.disabled = true; el.style.opacity = '0.4'; }
      el.onclick = () => { if (el.disabled) return; overlay.style.display = 'none'; resolve(btn.value); };
      footer.appendChild(el);
    });
    overlay.style.display = 'flex';
  });
}

function govAlert({ tag, title, message, danger }) {
  const strokeColor = danger ? '#f87171' : '#6ee7b7';
  const icon = danger
    ? `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="${strokeColor}" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r="0.5" fill="${strokeColor}"/></svg>`
    : `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="${strokeColor}" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>`;
  return govDialog({
    tag, title, icon, danger,
    body: `<p style="color:rgba(255,255,255,0.75);font-size:13px;line-height:1.65;margin:0;">${message}</p>`,
    buttons: [{ label: 'OK', value: true, primary: true }],
  });
}

async function govConfirmHalt(corridor) {
  const inputId = 'govHaltInput_' + Date.now();
  const confirmed = await govDialog({
    tag:   'Corridor Action',
    title: `Halt Corridor: ${corridor}`,
    danger: true,
    icon:  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><polygon points="7.86 2 16.14 2 22 7.86 22 16.14 16.14 22 7.86 22 2 16.14 2 7.86 7.86 2"/><line x1="12" y1="8" x2="12" y2="12"/><circle cx="12" cy="16" r="0.5" fill="#f87171"/></svg>`,
    body:  `<div style="margin-bottom:16px;font-size:13px;color:rgba(255,255,255,0.7);line-height:1.6;">This will <strong style="color:#f87171;">immediately suspend</strong> the <strong style="color:#fff;">${corridor}</strong> corridor. No further CVIB minting or settlement will be permitted until it is reinstated.</div>
            <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.25);border-radius:10px;padding:14px;">
              <div style="font-size:11px;font-weight:700;color:#f87171;letter-spacing:0.08em;text-transform:uppercase;margin-bottom:8px;">Confirmation Required</div>
              <div style="font-size:12px;color:rgba(255,255,255,0.5);margin-bottom:8px;">Type <strong style="color:#f87171;font-family:monospace;">HALT</strong> to proceed. This action will be recorded in the audit log.</div>
              <input id="${inputId}" type="text" placeholder="Type HALT" style="width:100%;padding:9px 12px;background:#0a1628;border:1px solid rgba(220,38,38,0.4);border-radius:7px;color:#fff;font-size:13px;font-family:monospace;letter-spacing:0.08em;outline:none;box-sizing:border-box;" oninput="document.getElementById('govHaltConfirmBtn').disabled=this.value.trim().toUpperCase()!=='HALT';document.getElementById('govHaltConfirmBtn').style.opacity=this.value.trim().toUpperCase()==='HALT'?'1':'0.4';">
            </div>`,
    buttons: [
      { label: 'Cancel', value: false },
      { label: '&#9889; Halt Corridor', value: true, primary: true, id: 'govHaltConfirmBtn' },
    ],
  });
  if (!confirmed) return false;
  const val = document.getElementById(inputId);
  return val ? val.value.trim().toUpperCase() === 'HALT' : false;
}
// ═══════════════════════════════════════════════════════════════════════════
// GOVERNOR APPROVAL DESK  —  STATE & FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════

let governorAuths = [];
let filteredGovernorAuths = [];
let governorCurrentPage = 1;
const governorPageSize = 5;
let selectedGovernorAuth = null;
let selectedGovernorAuthData = null;

// Re-use the flag / country helpers already defined in the supervisor partial.
// They are global, so we can call resolveSupervisorFlag() and resolveCorridorCurrency() directly.

const govStatusConfig = {
  'pending':  { bg: '#fef3c7', color: '#d97706', border: '#f59e0b', icon: '⏳', label: 'Pending' },
  'approved': { bg: '#d1fae5', color: '#059669', border: '#059669', icon: '✅', label: 'Approved' },
  'rejected': { bg: '#fee2e2', color: '#dc2626', border: '#ef4444', icon: '⛔', label: 'Rejected' },
  'expired':  { bg: '#f3f4f6', color: '#9ca3af', border: '#d1d5db', icon: '⌛', label: 'Expired' },
};

// ── Field resolution helper ──────────────────────────────────────────────────
// Rails serializers can use many different key shapes. This function extracts
// the canonical value from whichever key the API actually returns.
function govField(auth) {
  // Institution name — try nested object then flat string keys
  const institution =
    auth.institution?.name ||
    auth.institution?.institution_name ||
    auth.institution_name ||
    auth.originator_name ||
    auth.originator?.name ||
    auth.trade_claim?.institution?.name ||
    auth.trade_claim?.originator_name ||
    null;

  // Trade claim reference — the linked trade claim ID/reference
  const tradeClaimRef =
    auth.trade_claim_reference ||
    auth.trade_claim?.reference ||
    auth.claim_reference ||
    auth.claim_id ||
    null;

  // Corridor — source/target country codes
  let fromCountry =
    auth.source_country ||
    auth.corridor_source_country ||
    auth.corridor?.source_country ||
    auth.corridor?.from_country ||
    auth.trade_claim?.corridor?.source_country ||
    auth.trade_claim?.source_country ||
    '';
  let toCountry =
    auth.target_country ||
    auth.corridor_target_country ||
    auth.corridor?.target_country ||
    auth.corridor?.to_country ||
    auth.trade_claim?.corridor?.target_country ||
    auth.trade_claim?.target_country ||
    '';

  // Parse corridor name string as fallback ("NGA → KEN Corridor", "Nigeria-Kenya", etc.)
  const corridorName =
    auth.corridor_name ||
    auth.corridor?.name ||
    auth.trade_claim?.corridor?.name ||
    '';
  if (corridorName && (!fromCountry || !toCountry)) {
    const stripped = corridorName.replace(/\s*corridor\s*$/i, '').trim();
    const parts = stripped.split(/\s*[→\-]\s*/);
    if (parts.length >= 2) {
      if (!fromCountry) fromCountry = parts[0].trim();
      if (!toCountry)   toCountry   = parts[1].trim();
    }
  }

  // Asset code
  const assetCode =
    auth.asset_code ||
    auth.asset?.code ||
    auth.linked_asset_code ||
    auth.cvib_asset_code ||
    '';

  // Amount — try every Rails key variant
  const rawAmount =
    auth.amount ||
    auth.total_amount ||
    auth.amount_total ||
    auth.issuance_amount ||
    auth.authorized_amount ||
    auth.trade_claim?.amount ||
    auth.trade_claim?.trade_details?.amount ||
    0;
  const amount = parseFloat(rawAmount) || 0;

  // Currency (used when assetCode is blank)
  const currency =
    auth.currency ||
    auth.currency_code ||
    auth.asset?.currency_code ||
    assetCode ||
    '';

  // Beneficiary
  const benefName =
    auth.beneficiary?.name ||
    auth.beneficiary_name ||
    auth.trade_claim?.beneficiary?.name ||
    auth.trade_claim?.beneficiary_name ||
    '';
  const benefBank =
    auth.beneficiary?.bank ||
    auth.beneficiary?.bank_name ||
    auth.beneficiary_bank ||
    auth.beneficiary_bank_name ||
    auth.trade_claim?.beneficiary?.bank ||
    '';
  const benefCountry =
    auth.beneficiary?.country ||
    auth.beneficiary_country ||
    auth.trade_claim?.beneficiary?.country ||
    toCountry ||
    '';

  return { institution, tradeClaimRef, fromCountry, toCountry, corridorName, assetCode, amount, currency, benefName, benefBank, benefCountry };
}

// ── Modal open / close ──────────────────────────────────────────────────────
function showGovernorDeskModal() {
  document.getElementById('governorDeskModalOverlay').style.display = 'flex';
  document.body.style.overflow = 'hidden';
  loadGovernorAuthorizations();
  loadGovCorridorLiquidity();
  loadGovRecentEvents();

  // Delegated row click — attached once, works for all dynamically rendered rows
  const rowsContainer = document.getElementById('governorAuthsRows');
  if (rowsContainer && !rowsContainer._clickBound) {
    rowsContainer.addEventListener('click', function(e) {
      e.stopPropagation();
      const row = e.target.closest('[data-auth-key]');
      if (row) selectGovernorAuth(row.dataset.authKey);
    });
    rowsContainer._clickBound = true;
  }
}

function hideGovernorDeskModal() {
  document.getElementById('governorDeskModalOverlay').style.display = 'none';
  document.body.style.overflow = '';
}

function toggleGovernorSection(sectionId) {
  const el = document.getElementById(sectionId);
  if (el) el.style.display = el.style.display === 'none' ? 'block' : 'none';
}

// ── Auth headers (reuses supervisor token helper) ───────────────────────────
function getGovernorAuthHeaders() {
  const token = (typeof getSupervisorToken === 'function')
    ? getSupervisorToken()
    : (document.querySelector('meta[name="csrf-token"]')?.content || '');
  const headers = { 'Accept': 'application/json', 'Content-Type': 'application/json' };
  const csrf = document.querySelector('meta[name="csrf-token"]')?.content;
  if (csrf)  headers['X-CSRF-Token'] = csrf;
  headers['Authorization'] = `Bearer ${token}`;
  return headers;
}

// ── Load authorizations ─────────────────────────────────────────────────────
async function loadGovernorAuthorizations() {
  const loading = document.getElementById('governorAuthsLoading');
  const rows    = document.getElementById('governorAuthsRows');
  loading.style.display = 'flex';
  rows.innerHTML = '';

  try {
    const res = await fetch('/api/v2/issuance_authorizations?per_page=50', {
      headers: getGovernorAuthHeaders()
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);

    const data = await res.json();

    // Handle all envelope shapes: { data: [...] }, { authorizations: [...] }, or bare []
    let raw = [];
    if (Array.isArray(data))            raw = data;
    else if (Array.isArray(data.data))  raw = data.data;
    else if (Array.isArray(data.authorizations)) raw = data.authorizations;
    else if (data.data && typeof data.data === 'object') raw = [data.data];

    // Log first record so we can see the real field shape in the console
    if (raw.length > 0) {
      console.log('[GovernorDesk] sample record keys:', Object.keys(raw[0]));
      console.log('[GovernorDesk] sample record:', JSON.stringify(raw[0], null, 2));
    }

    // Include pending + any that lack governance_status (default = pending)
    governorAuths = raw.filter(a => {
      const gs = (a.governance_status || 'pending').toLowerCase();
      return gs === 'pending';
    });

    document.getElementById('governorQueueCount').textContent = governorAuths.length;
    applyGovernorFilters();
  } catch (err) {
    console.error('[GovernorDesk] load error:', err);
    loading.style.display = 'none';
    rows.innerHTML = '<div style="padding:40px;text-align:center;color:#ef4444;">Error loading authorizations — check API endpoint</div>';
  }
}

function applyGovernorFilters() {
  const term = (document.getElementById('governorSearchInput')?.value || '').toLowerCase();
  filteredGovernorAuths = governorAuths.filter(a => {
    const f = govField(a);
    const code = (a.auth_code || a.id || '').toString().toLowerCase();
    const inst = (f.institution || '').toLowerCase();
    const tc   = (f.tradeClaimRef || '').toString().toLowerCase();
    return code.includes(term) || inst.includes(term) || tc.includes(term);
  });
  governorCurrentPage = 1;
  renderGovernorAuths();
}

function renderGovernorAuths() {
  const loading = document.getElementById('governorAuthsLoading');
  const rows    = document.getElementById('governorAuthsRows');
  loading.style.display = 'none';

  if (filteredGovernorAuths.length === 0) {
    rows.innerHTML = '<div style="padding:40px;text-align:center;color:#6b7280;">No authorizations pending governance review</div>';
    updateGovernorPagination();
    return;
  }

  const start     = (governorCurrentPage - 1) * governorPageSize;
  const pageItems = filteredGovernorAuths.slice(start, start + governorPageSize);

  rows.innerHTML = pageItems.map((auth, i) => {
    const rowNum   = start + i + 1;
    const f        = govField(auth);
    const authCode = auth.auth_code || auth.id || '—';
    const inst     = f.institution || 'Unknown';
    const tcId     = f.tradeClaimRef || '—';
    const asset    = f.assetCode || f.currency || '—';
    const amount   = f.amount;
    const { fromCountry, toCountry } = f;

    const fromFlag = (typeof resolveSupervisorFlag === 'function') ? resolveSupervisorFlag(fromCountry) : '🌍';
    const toFlag   = (typeof resolveSupervisorFlag === 'function') ? resolveSupervisorFlag(toCountry)   : '🌍';

    const rowKey     = auth.id || auth.auth_code;
    const isSelected = selectedGovernorAuth === rowKey;
    const govStatus  = (auth.governance_status || 'pending').toLowerCase();
    const conf       = govStatusConfig[govStatus] || govStatusConfig['pending'];

    return `
      <div class="governor-auth-row ${isSelected ? 'selected' : ''}"
           data-auth-key="${rowKey}"
           style="
             display: grid;
             grid-template-columns: 40px 160px 180px 120px 140px 110px 120px;
             gap: 8px; padding: 14px 20px;
             border-bottom: 1px solid #f3f4f6; cursor: pointer;
             background: ${isSelected ? '#dbeafe' : 'white'};
           ">
        <div style="font-size:13px;color:#6b7280;">${fromFlag || '🌍'} ${rowNum}</div>
        <div>
          <div style="font-size:12px;font-weight:600;font-family:monospace;color:#1e40af;">${authCode}</div>
          <span style="padding:2px 7px;border-radius:10px;font-size:10px;font-weight:600;background:${conf.bg};color:${conf.color};border:1px solid ${conf.border};">${conf.icon} ${conf.label}</span>
        </div>
        <div style="font-size:12px;color:#374151;overflow:hidden;text-overflow:ellipsis;">${inst.substring(0,22)}</div>
        <div style="font-size:12px;font-family:monospace;color:#374151;">${tcId}</div>
        <div style="font-size:12px;">${fromFlag || ''} ${fromCountry || '—'} → ${toFlag || ''} ${toCountry || '—'}</div>
        <div style="font-size:12px;font-weight:600;color:#1d1d1f;">${asset}</div>
        <div style="font-size:12px;font-weight:600;color:#1d1d1f;">${amount ? amount.toLocaleString() : '—'}</div>
      </div>`;
  }).join('');

  updateGovernorPagination();
}

function updateGovernorPagination() {
  const total = Math.ceil(filteredGovernorAuths.length / governorPageSize);
  let html = '';
  for (let i = 1; i <= Math.min(total, 5); i++) {
    html += `<button onclick="goToGovernorPage(${i})" style="
      padding:6px 12px;
      background:${i === governorCurrentPage ? '#1e4d7b' : 'white'};
      color:${i === governorCurrentPage ? 'white' : '#374151'};
      border:1px solid ${i === governorCurrentPage ? '#1e4d7b' : '#e5e7eb'};
      border-radius:6px;cursor:pointer;
    ">${i}</button>`;
  }
  document.getElementById('governorPageNumbers').innerHTML = html;
}

function goToGovernorPage(p) { governorCurrentPage = p; renderGovernorAuths(); }
function governorPrevPage()  { if (governorCurrentPage > 1) { governorCurrentPage--; renderGovernorAuths(); } }
function governorNextPage()  {
  if (governorCurrentPage < Math.ceil(filteredGovernorAuths.length / governorPageSize)) {
    governorCurrentPage++;
    renderGovernorAuths();
  }
}

// ── Select authorization ────────────────────────────────────────────────────
function selectGovernorAuth(authId) {
  selectedGovernorAuth = authId;
  selectedGovernorAuthData = governorAuths.find(a =>
    a.id === authId || a.auth_code === authId || (a.id || a.auth_code) === authId
  );

  console.log('[GovernorDesk] selectGovernorAuth called with:', authId);
  console.log('[GovernorDesk] governorAuths length:', governorAuths.length);
  console.log('[GovernorDesk] found:', selectedGovernorAuthData);

  if (!selectedGovernorAuthData) {
    console.warn('[GovernorDesk] No matching auth found for id:', authId);
    return;
  }

  document.getElementById('governorReviewSection').style.display = 'block';
  populateGovernorDetails(selectedGovernorAuthData);
  populateGovernorSignatures(selectedGovernorAuthData);
  renderGovernorLifecycle(selectedGovernorAuthData);
  renderGovernorAuths();

  // Scroll the modal's own content area down to the review section
  setTimeout(() => {
    const reviewEl = document.getElementById('governorReviewSection');
    const scrollContainer = reviewEl.closest('[style*="overflow-y"]') || reviewEl.parentElement;
    if (scrollContainer) {
      scrollContainer.scrollTo({ top: reviewEl.offsetTop - 20, behavior: 'smooth' });
    } else {
      reviewEl.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }
  }, 50);
}

function populateGovernorDetails(auth) {
  const inst      = auth.institution?.name || auth.institution_name || 'Unknown';
  const authCode  = auth.auth_code || '—';
  const tcId      = auth.trade_claim_reference || auth.trade_claim?.reference || auth.trade_claim_id || '—';
  const assetCode = auth.asset_code || '—';
  const amount    = parseFloat(auth.amount_total || auth.total_amount || 0);

  let fromCountry = auth.corridor?.source_country || auth.corridor?.from_country || '';
  let toCountry   = auth.corridor?.target_country || auth.corridor?.to_country   || '';
  if ((!fromCountry || !toCountry) && auth.corridor?.name) {
    const parts = auth.corridor.name.replace(/\s*corridor\s*$/i,'').split(/\s*[→\-]\s*/);
    if (parts.length >= 2) { fromCountry = fromCountry || parts[0]; toCountry = toCountry || parts[1]; }
  }
  const fromFlag = (typeof resolveSupervisorFlag === 'function') ? resolveSupervisorFlag(fromCountry) : '🌍';
  const toFlag   = (typeof resolveSupervisorFlag === 'function') ? resolveSupervisorFlag(toCountry)   : '🌍';
  const curr     = (typeof resolveCorridorCurrency === 'function')
    ? resolveCorridorCurrency(toCountry) || resolveCorridorCurrency(fromCountry) || ''
    : '';

  document.getElementById('govInstitutionName').textContent    = inst;
  document.getElementById('govInstitutionFlag').textContent    = fromFlag || '🏦';
  document.getElementById('govAuthCode').textContent           = authCode;
  document.getElementById('govTradeClaimId').textContent       = tcId;
  document.getElementById('govCorridorDisplay').innerHTML      = `${fromFlag} ${fromCountry || '—'} → ${toFlag} ${toCountry || '—'}`;
  document.getElementById('govCorridorDisplay2').innerHTML     = `${fromFlag} ${fromCountry || '—'} → ${toFlag} ${toCountry || '—'}`;
  document.getElementById('govAssetCode').textContent          = assetCode;
  document.getElementById('govAmount').textContent             = `${assetCode} ${amount.toLocaleString()}`;

  // Beneficiary info
  document.getElementById('govBeneficiaryName').textContent    = auth.beneficiary?.name    || auth.beneficiary_name    || '—';
  document.getElementById('govBeneficiaryBank').textContent    = auth.beneficiary?.bank    || auth.beneficiary_bank    || '—';
  document.getElementById('govBeneficiaryCountry').textContent = auth.beneficiary?.country || auth.beneficiary_country || '—';
}

// ── Populate Governance Signatures panel ────────────────────────────────────
function populateGovernorSignatures(auth) {
  const sigs       = auth.governance_signatures || [];
  const govStatus  = (auth.governance_status || 'pending').toLowerCase();
  const isApproved = govStatus === 'approved';

  // When no detail records exist, derive counts from governance_status
  const current  = auth.current_signatures  || sigs.length || (isApproved ? 2 : 0);
  const required = auth.required_signatures || 2;

  // Map by role
  const sigMap = {};
  sigs.forEach(s => { sigMap[(s.signer_role || '').toLowerCase()] = s; });

  function applySignature(rowId, iconId, metaId, badgeId, roleKey) {
    const sig  = sigMap[roleKey] || sigMap[roleKey.replace('_', ' ')] || null;
    const icon = document.getElementById(iconId);
    const meta = document.getElementById(metaId);
    const badge= document.getElementById(badgeId);
    const row  = document.getElementById(rowId);
    if (!icon || !meta || !badge || !row) return;

    // Treat as signed if we have a detail record OR if governance is approved (fallback)
    const signed = sig || isApproved;

    if (signed) {
      icon.textContent       = '✅';
      meta.textContent       = sig
        ? `Signed by ${sig.signer_id || 'Governor'} at ${sig.signed_at ? new Date(sig.signed_at).toLocaleTimeString() : '—'}`
        : 'Approved';
      badge.textContent      = 'Approved';
      badge.style.background = '#d1fae5';
      badge.style.color      = '#059669';
      row.style.borderColor  = '#a7f3d0';
    } else {
      icon.textContent       = '○';
      meta.textContent       = 'Awaiting signature';
      badge.textContent      = 'Pending';
      badge.style.background = '#fef3c7';
      badge.style.color      = '#d97706';
      row.style.borderColor  = '#e5e7eb';
    }
  }

  applySignature('govSigDeputy',    'govSigDeputyIcon',    'govSigDeputyMeta',    'govSigDeputyBadge',    'deputy_governor');
  applySignature('govSigGovernor',  'govSigGovernorIcon',  'govSigGovernorMeta',  'govSigGovernorBadge',  'governor');

  // Progress bar
  const pct = Math.min(100, Math.round((current / required) * 100));
  const progressBar  = document.getElementById('govSigProgressBar');
  const progressText = document.getElementById('govSigProgressText');
  if (progressBar)  progressBar.style.width      = `${pct}%`;
  if (progressText) progressText.textContent      = `${current} / ${required} required`;
  if (progressBar)  progressBar.style.background  = current >= required ? '#059669' : '#2563eb';
}

// ── Lifecycle table ─────────────────────────────────────────────────────────
const GOV_LIFECYCLE_STAGES = [
  { key: 'authorization_created', label: 'Authorization Created',  icon: '📄' },
  { key: 'supervisor_approved',   label: 'Supervisor Approved',    icon: '🧑‍⚖️' },
  { key: 'governance_review',     label: 'Governance Review',      icon: '🏛️' },
  { key: 'issuance_eligible',     label: 'Issuance-Eligible',      icon: '🏦' },
  { key: 'liquidity_locked',      label: 'Liquidity Locked',       icon: '🔒' },
  { key: 'minted',                label: 'Minted',                 icon: '💴' },
];

function renderGovernorLifecycle(auth) {
  const tbody = document.getElementById('govLifecycleTableBody');
  if (!tbody) return;

  const govStatus = (auth.governance_status || 'pending').toLowerCase();

  // Which stages have been reached based on governance_status
  const reachedMap = {
    authorization_created: true,
    supervisor_approved:   true,
    governance_review:     true,
    issuance_eligible:     govStatus === 'approved',
    liquidity_locked:      govStatus === 'approved' && !!auth.backing_lock_id,
    minted:                false,
  };

  const currentKey = govStatus === 'approved' ? 'issuance_eligible' : 'governance_review';

  tbody.innerHTML = GOV_LIFECYCLE_STAGES.map(stage => {
    const isReached  = !!reachedMap[stage.key];
    const isCurrent  = stage.key === currentKey;

    let statusHtml;
    if (isCurrent) {
      statusHtml = `<span style="background:#dbeafe;color:#1d4ed8;padding:2px 8px;border-radius:8px;font-size:10px;font-weight:700;">CURRENT</span>`;
    } else if (isReached) {
      statusHtml = `<span style="background:#f0fdf4;color:#16a34a;padding:2px 8px;border-radius:8px;font-size:10px;font-weight:600;">✓ Done</span>`;
    } else {
      statusHtml = `<span style="color:#d1d5db;font-size:11px;">—</span>`;
    }

    const conditionHtml = stage.key === 'governance_review'
      ? `<span style="font-size:11px;color:${govStatus==='approved'?'#059669':'#6b7280'};">${govStatus==='approved'?'✓ Governor approved':'⟳ Awaiting signatures'}</span>`
      : `<span style="color:#d1d5db;font-size:11px;">${isReached ? '✓ satisfied' : '—'}</span>`;

    const satisfiedHtml = !isReached && !isCurrent
      ? `<span style="color:#d1d5db;">—</span>`
      : isReached
        ? `<span style="color:#059669;font-weight:600;">✓ Yes</span>`
        : `<span style="color:#f59e0b;font-weight:600;">⟳ Pending</span>`;

    return `
      <tr style="border-bottom:1px solid #f3f4f6;${isCurrent ? 'background:#eff6ff;' : ''}">
        <td style="padding:9px 12px;font-size:12px;font-weight:${isCurrent?'600':'400'};color:${isReached?'#374151':'#9ca3af'};">
          ${stage.icon} ${stage.label}
        </td>
        <td style="padding:9px 12px;">${statusHtml}</td>
        <td style="padding:9px 12px;">${conditionHtml}</td>
        <td style="padding:9px 12px;">${satisfiedHtml}</td>
      </tr>`;
  }).join('');
}

// ── Governor sign (approve) ─────────────────────────────────────────────────
async function governorSignAuthorization() {
  if (!selectedGovernorAuthData) { alert('Please select an authorization first'); return; }

  const notes  = (document.getElementById('governorDecisionNotes')?.value || '').trim();
  const authCode = selectedGovernorAuthData.auth_code;

  const confirmed = await showGovernorConfirmModal(selectedGovernorAuthData, notes);
  if (!confirmed) return;

  const btn = document.getElementById('btnGovernorApprove');
  const origHTML = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '⏳ Signing...';

  try {
    const res = await fetch(`/api/v2/issuance_authorizations/${authCode}/governance_sign`, {
      method:  'POST',
      headers: getGovernorAuthHeaders(),
      body:    JSON.stringify({ notes, signer_role: 'governor' })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);

    // Reload full auth record from server so signatures + status are fresh
    try {
      const refreshRes = await fetch(`/api/v2/issuance_authorizations?governance_status=pending&per_page=50`, {
        headers: getGovernorAuthHeaders()
      });
      const refreshData = await refreshRes.json();
      const refreshed = (refreshData.data || []).find(a => a.auth_code === authCode || a.id === authCode);
      if (refreshed) {
        selectedGovernorAuthData = refreshed;
        // Update in the master array too
        const idx = governorAuths.findIndex(a => a.auth_code === authCode || a.id === authCode);
        if (idx !== -1) governorAuths[idx] = refreshed;
      } else {
        // Not in pending anymore — approved, merge what we have
        selectedGovernorAuthData = { ...selectedGovernorAuthData, ...(data.data || data) };
      }
    } catch (_) {
      // Fallback: just merge response data
      selectedGovernorAuthData = { ...selectedGovernorAuthData, ...(data.data || data) };
    }

    populateGovernorSignatures(selectedGovernorAuthData);
    renderGovernorLifecycle(selectedGovernorAuthData);

    const fullyApproved = (selectedGovernorAuthData.governance_status || '').toLowerCase() === 'approved';

    showGovernorResultModal({
      approved: fullyApproved,
      authCode,
      currentSigs:  selectedGovernorAuthData.current_signatures  || 0,
      requiredSigs: selectedGovernorAuthData.required_signatures || 2,
    });

    if (fullyApproved) {
      // Remove from queue
      governorAuths = governorAuths.filter(a => a.auth_code !== authCode);
      applyGovernorFilters();
      btn.innerHTML = '✅ Fully Approved';
    } else {
      btn.innerHTML = `✍ Signed (${selectedGovernorAuthData.current_signatures}/${selectedGovernorAuthData.required_signatures})`;
      btn.disabled  = false;
    }

  } catch (err) {
    showGovernorResultModal({ error: true, errorMessage: err.message });
    btn.disabled  = false;
    btn.innerHTML = origHTML;
  }
}

// ── Governor reject ─────────────────────────────────────────────────────────
async function governorRejectAuthorization() {
  if (!selectedGovernorAuthData) { await govAlert({ tag:'Error', title:'No Authorization Selected', message:'Please select an authorization from the queue first.', danger:true }); return; }
  const notes = (document.getElementById('governorDecisionNotes')?.value || '').trim();
  if (!notes) { await govAlert({ tag:'Error', title:'Reason Required', message:'Please enter a rejection reason in the Decision Notes field before rejecting.', danger:true }); return; }
  const confirmed = await govDialog({
    tag:   'Governor Action',
    title: 'Reject Authorization',
    danger: true,
    icon:  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#f87171" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`,
    body:  `<div style="display:grid;grid-template-columns:auto 1fr;gap:8px 16px;margin-bottom:16px;font-size:13px;">
              <span style="color:rgba(255,255,255,0.45);font-weight:600;">Auth ID</span>
              <span style="color:#ffffff;font-family:monospace;font-size:12px;">${selectedGovernorAuthData.auth_code}</span>
            </div>
            <div style="background:rgba(220,38,38,0.08);border:1px solid rgba(220,38,38,0.22);border-radius:10px;padding:12px 14px;">
              <div style="font-size:12px;color:rgba(255,255,255,0.65);line-height:1.55;">This will <strong style="color:#f87171;">block CVIB minting</strong> for this authorization. The action is permanent and will be recorded in the governance audit log.</div>
            </div>`,
    buttons: [
      { label: 'Cancel', value: false },
      { label: 'Reject Authorization', value: true, primary: true },
    ],
  });
  if (!confirmed) return;

  try {
    const res = await fetch(`/api/v2/issuance_authorizations/${selectedGovernorAuthData.auth_code}/governance_reject`, {
      method:  'POST',
      headers: getGovernorAuthHeaders(),
      body:    JSON.stringify({ notes, reason: notes })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);

    document.getElementById('govRejectionWarning').style.display = 'block';
    document.getElementById('btnGovernorApprove').disabled = true;
    document.getElementById('btnGovernorApprove').innerHTML = '⛔ Rejected';
    governorAuths = governorAuths.filter(a => a.auth_code !== selectedGovernorAuthData.auth_code);
    applyGovernorFilters();
  } catch (err) {
    alert('Error rejecting authorization: ' + err.message);
  }
}

