              <div style="font-size:13px;font-weight:600;color:#1d1d1f;">${inst}</div>
            </div>
          </div>
          ${notesHtml}
          <div style="margin-top:10px;padding:10px 12px;background:#f0f9ff;border:1px solid #bae6fd;border-radius:8px;font-size:11px;color:#0369a1;line-height:1.6;">
            ⚙ A <code>governance_signatures</code> record will be created.<br>
            If required signatures are reached, <strong>governance_status → approved</strong>.
          </div>
        </div>
        <div style="padding:20px 24px 24px;display:flex;gap:10px;">
          <button id="govConfirmCancel" style="flex:1;padding:13px;background:#f3f4f6;color:#374151;border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;">Cancel</button>
          <button id="govConfirmOK" style="flex:2;padding:13px;background:linear-gradient(135deg,#1e4d7b,#1a3a5c);color:white;border:none;border-radius:10px;font-size:14px;font-weight:700;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:8px;box-shadow:0 4px 14px rgba(30,77,123,0.35);">
            ✓ Sign &amp; Approve Issuance
          </button>
        </div>
      </div>
      <style>@keyframes slideUpFade{from{opacity:0;transform:translateY(16px) scale(0.97)}to{opacity:1;transform:translateY(0) scale(1)}}</style>`;

    document.body.appendChild(overlay);
    document.getElementById('govConfirmOK').onclick     = () => { overlay.remove(); resolve(true); };
    document.getElementById('govConfirmCancel').onclick = () => { overlay.remove(); resolve(false); };
    overlay.addEventListener('click', e => { if (e.target === overlay) { overlay.remove(); resolve(false); } });
    const kh = e => {
      if (e.key === 'Enter')  { document.removeEventListener('keydown', kh); overlay.remove(); resolve(true); }
      if (e.key === 'Escape') { document.removeEventListener('keydown', kh); overlay.remove(); resolve(false); }
    };
    document.addEventListener('keydown', kh);
  });
}

// ── Result modal ────────────────────────────────────────────────────────────
function showGovernorResultModal({ approved, authCode, currentSigs, requiredSigs, error, errorMessage }) {
  const existing = document.getElementById('governorResultOverlay');
  if (existing) existing.remove();

  let headerBg, headerIcon, headerTitle, headerSub, bodyHtml;

  if (error) {
    headerBg   = 'linear-gradient(135deg,#991b1b,#dc2626)';
    headerIcon = '⚠';
    headerTitle = 'Signature Failed';
    headerSub   = 'An unexpected error occurred.';
    bodyHtml    = `<div style="padding:20px 24px;background:#fef2f2;border-bottom:1px solid #fecaca;"><div style="font-size:13px;color:#991b1b;font-family:monospace;">${errorMessage}</div></div>`;
  } else if (approved) {
    headerBg   = 'linear-gradient(135deg,#065f46,#059669)';
    headerIcon = '🏦';
    headerTitle = 'Authorization Approved';
    headerSub   = `${authCode} has reached the required signatures. Qt6 Issuance Console is now enabled.`;
    bodyHtml    = `
      <div style="padding:20px 24px;">
        <div style="padding:14px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;font-size:13px;color:#166534;line-height:1.8;">
          ✓ governance_status → <strong>approved</strong><br>
          ✓ ${currentSigs} / ${requiredSigs} required signatures collected<br>
          ✓ Qt6 Issuance Console: <strong>btnAuthorizePackage ENABLED</strong><br>
          ✓ Audit log entry written
        </div>
      </div>`;
  } else {
    headerBg   = 'linear-gradient(135deg,#1a3a5c,#1e4d7b)';
    headerIcon = '✍';
    headerTitle = 'Signature Recorded';
    headerSub   = `${authCode} — ${currentSigs} of ${requiredSigs} required signatures collected.`;
    bodyHtml    = `
      <div style="padding:20px 24px;">
        <div style="padding:14px;background:#eff6ff;border:1px solid #bfdbfe;border-radius:10px;font-size:13px;color:#1e40af;line-height:1.8;">
          ✓ Signature recorded in governance_signatures<br>
          ⟳ Awaiting ${requiredSigs - currentSigs} more signature(s) before issuance is unlocked
        </div>
      </div>`;
  }

  const overlay = document.createElement('div');
  overlay.id = 'governorResultOverlay';
  overlay.style.cssText = 'position:fixed;inset:0;z-index:999999;background:rgba(0,0,0,0.55);backdrop-filter:blur(8px);display:flex;align-items:center;justify-content:center;padding:20px;font-family:-apple-system,BlinkMacSystemFont,sans-serif;';
  overlay.innerHTML = `
    <div style="background:#fff;border-radius:20px;width:100%;max-width:440px;box-shadow:0 32px 80px rgba(0,0,0,0.3);overflow:hidden;animation:slideUpFade 0.18s ease;">
      <div style="background:${headerBg};padding:22px 24px 18px;">
        <div style="font-size:11px;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Governor Approval Desk</div>
        <div style="font-size:19px;font-weight:700;color:#fff;">${headerIcon} ${headerTitle}</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.7);margin-top:4px;">${headerSub}</div>
      </div>
      ${bodyHtml}
      <div style="padding:16px 24px 22px;display:flex;justify-content:flex-end;">
        <button id="govResultClose" style="background:${approved?'#059669':error?'#dc2626':'#1e4d7b'};color:#fff;border:none;border-radius:10px;padding:12px 32px;font-size:14px;font-weight:700;cursor:pointer;">Done</button>
      </div>
    </div>
    <style>@keyframes slideUpFade{from{opacity:0;transform:translateY(16px) scale(0.97)}to{opacity:1;transform:translateY(0) scale(1)}}</style>`;

  document.body.appendChild(overlay);
  document.getElementById('govResultClose').onclick = () => overlay.remove();
  overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
  document.addEventListener('keydown', function esc(e) {
    if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', esc); }
  });
}

