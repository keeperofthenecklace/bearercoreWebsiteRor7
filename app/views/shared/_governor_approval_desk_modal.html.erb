<%#
  View: app/views/shared/_governor_approval_desk_modal.html.erb

  GOVERNOR APPROVAL DESK
  ======================
  Monetary-authority console for reviewing and signing issuance authorizations
  created after supervisor trade-claim approval.

  ROLES THAT USE THIS CONSOLE:
  - Deputy Governor  (must sign first)
  - Governor         (must sign second)
  - Monetary Committee (optional / quorum-based)

  GOVERNANCE MODEL:
  - Dual-signature: required_signatures = 2 (Deputy Governor + Governor)
  - governance_status transitions: pending → approved (once current_signatures >= required)
  - Rejection by any required signer sets governance_status = rejected immediately
  - Expiry checked by AuthorizationExpiryWorker (24 h after created_at)

  KEY RULES:
  - Supervisor approval does NOT grant Governor approval
  - governance_status starts as "pending" when authorization is created
  - Only governance_status = "approved" allows Qt6 to mint CVIB notes
  - All signature events written to governance_signatures + audit_logs

  API ENDPOINTS USED:
  - GET  /api/v2/issuance_authorizations?governance_status=pending
  - GET  /api/v2/issuance_authorizations/:auth_code
  - POST /api/v2/issuance_authorizations/:auth_code/governance_sign
  - POST /api/v2/issuance_authorizations/:auth_code/governance_reject
%>

<!-- Governor Approval Desk Modal Overlay -->
<div id="governorDeskModalOverlay" style="
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 10000;
  justify-content: center;
  align-items: center;
  padding: 20px;
">
  <div style="
    background: #f5f5f7;
    border-radius: 20px;
    width: 100%;
    max-width: 1100px;
    max-height: 92vh;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
    display: flex;
    flex-direction: column;
  ">

    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <div style="
      background: linear-gradient(135deg, #1a3a5c 0%, #1e4d7b 50%, #1a3a5c 100%);
      padding: 24px 28px;
      position: relative;
      overflow: hidden;
    ">
      <div style="
        position: absolute; top: 0; left: 0; right: 0; bottom: 0;
        background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.08) 1px, transparent 0);
        background-size: 24px 24px;
        pointer-events: none;
      "></div>

      <div style="display: flex; justify-content: space-between; align-items: center; position: relative; z-index: 1;">
        <div style="display: flex; align-items: center; gap: 16px;">
          <div style="
            width: 52px; height: 52px;
            background: rgba(255,255,255,0.15);
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            backdrop-filter: blur(10px);
          ">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5">
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
          </div>
          <div>
            <h2 style="margin: 0; font-size: 22px; font-weight: 600; color: #ffffff; letter-spacing: -0.3px;">
              Governor Approval Desk
            </h2>
            <p style="margin: 4px 0 0; font-size: 13px; color: rgba(255,255,255,0.75);">
              Sovereign liquidity management &amp; issuance authorization.
            </p>
          </div>
        </div>

        <button onclick="hideGovernorDeskModal()" style="
          width: 36px; height: 36px;
          border-radius: 50%; border: none;
          background: rgba(255,255,255,0.2);
          color: white; font-size: 20px; cursor: pointer;
          display: flex; align-items: center; justify-content: center;
        " onmouseover="this.style.background='rgba(255,255,255,0.3)'"
           onmouseout="this.style.background='rgba(255,255,255,0.2)'">×</button>
      </div>
    </div>

    <!-- ── Content Area ───────────────────────────────────────────────── -->
    <div style="flex: 1; overflow-y: auto; padding: 24px; background: #f5f5f7;">

      <!-- Search Bar -->
      <div style="display: flex; gap: 12px; margin-bottom: 24px;">
        <div style="
          flex: 1; display: flex; align-items: center;
          background: white; border: 1px solid #e5e7eb;
          border-radius: 12px; padding: 0 16px;
        ">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input id="governorSearchInput"
                 type="text"
                 placeholder="Search by authorization ID, claim ID, institution..."
                 oninput="applyGovernorFilters()"
                 style="
                   flex: 1; border: none; outline: none;
                   padding: 14px 12px; font-size: 14px; background: transparent;
                 ">
        </div>
        <button onclick="loadGovernorAuthorizations()" style="
          background: #1a3a5c; color: white; border: none;
          border-radius: 12px; padding: 0 20px;
          font-size: 14px; font-weight: 600; cursor: pointer;
        ">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </div>

      <!-- ── Sovereign Dashboard ────────────────────────────────────────── -->
      <div style="
        background: #0A192F; border-radius: 16px;
        margin-bottom: 20px; padding: 20px;
        border: 1px solid rgba(255,255,255,0.06);
      ">
        <!-- Title row -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
          <div>
            <div style="font-size:10px; color:#475569; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:3px;">
              Governor's Command Center
            </div>
            <div style="font-size:17px; font-weight:700; color:#f1f5f9;">
              Sovereign Dashboard
            </div>
          </div>
          <button onclick="loadGovCorridorLiquidity(); loadGovRecentEvents();" style="
            background:rgba(255,255,255,0.07); color:#94a3b8;
            border:1px solid rgba(255,255,255,0.12); border-radius:8px;
            padding:6px 14px; font-size:12px; cursor:pointer;
          ">↻ Refresh</button>
        </div>

        <!-- Top row: Corridor Selector (left) + Sovereign Status (right) -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">

          <!-- Top Left: Corridor Selector -->
          <div style="
            background:rgba(255,255,255,0.04);
            border:1px solid rgba(255,255,255,0.08);
            border-radius:12px; padding:14px;
          ">
            <div style="font-size:10px; color:#475569; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:10px;">
              Select Corridor
            </div>
            <input id="govCorridorSearch" type="text" placeholder="Search corridors…"
                   oninput="govFilterCorridors()"
                   style="
                     width:100%; box-sizing:border-box; margin-bottom:8px;
                     background:rgba(255,255,255,0.06); color:#e2e8f0;
                     border:1px solid rgba(255,255,255,0.12); border-radius:8px;
                     padding:6px 10px; font-size:12px; outline:none;
                   ">
            <select id="govCorridorSelect" size="5"
                    onchange="govSelectCorridor(this.value, this.options[this.selectedIndex]?.text)"
                    style="
                      width:100%;
                      background:rgba(255,255,255,0.06); color:#e2e8f0;
                      border:1px solid rgba(255,255,255,0.12); border-radius:8px;
                      padding:5px 8px; font-size:12px; cursor:pointer; outline:none;
                    ">
              <option value="" style="background:#0f2744;">⏳ Loading corridors…</option>
            </select>
          </div>

          <!-- Top Right: Sovereign Status -->
          <div style="
            background:rgba(255,255,255,0.04);
            border:1px solid rgba(255,255,255,0.08);
            border-radius:12px; padding:14px;
            display:flex; flex-direction:column; justify-content:center; align-items:center;
          ">
            <div style="font-size:10px; color:#475569; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:12px;">
              Sovereign Status
            </div>
            <div id="govSovereignStatusBadge" style="
              font-size:22px; font-weight:800; color:#2dd4bf;
              letter-spacing:1px; margin-bottom:8px;
            ">IN SYNC</div>
            <div style="
              background:rgba(13,148,136,0.2); color:#2dd4bf;
              border-radius:20px; padding:3px 14px; font-size:10px; font-weight:700;
              margin-bottom:14px;
            ">● OPERATIONAL</div>
            <div style="text-align:center;">
              <div style="font-size:9px; color:#475569; text-transform:uppercase; letter-spacing:0.8px; margin-bottom:3px;">Last Audit</div>
              <div id="govLastAuditTimestamp" style="font-size:11px; color:#94a3b8; font-family:monospace;">—</div>
            </div>
          </div>
        </div>

        <!-- Middle Row: Wide Fuel Gauge for selected corridor -->
        <div style="
          background:rgba(255,255,255,0.04);
          border:1px solid rgba(255,255,255,0.08);
          border-radius:12px; padding:16px; margin-bottom:14px;
        ">
          <div style="font-size:10px; color:#475569; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:12px;">
            Bulk Allotment Reservoir — Selected Corridor
          </div>
          <div id="govFuelGaugeContent">
            <div style="color:#475569; font-size:13px; text-align:center; padding:20px 0;">
              Select a corridor above to view the reservoir gauge
            </div>
          </div>
        </div>

        <!-- Bottom Row: Recent Events (left) + Quick Actions (right) -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">

          <!-- Bottom Left: Recent Bulk Allotments -->
          <div style="
            background:rgba(255,255,255,0.04);
            border:1px solid rgba(255,255,255,0.08);
            border-radius:12px; padding:14px;
          ">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
              <div style="font-size:10px; color:#475569; text-transform:uppercase; letter-spacing:1.2px;">
                Recent Bulk Allotments
              </div>
              <button onclick="loadGovRecentEvents()" style="
                background:none; color:#475569; border:none; font-size:13px; cursor:pointer; padding:2px 6px;
              ">↻</button>
            </div>
            <div id="govRecentEventsRows" style="display:flex; flex-direction:column; gap:6px; max-height:180px; overflow-y:auto;">
              <div style="color:#475569; font-size:12px; text-align:center; padding:20px;">
                ⏳ Loading…
              </div>
            </div>
          </div>

          <!-- Bottom Right: Quick Actions -->
          <div style="
            background:rgba(255,255,255,0.04);
            border:1px solid rgba(255,255,255,0.08);
            border-radius:12px; padding:14px;
          ">
            <div style="font-size:10px; color:#475569; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:10px;">
              Quick Actions
            </div>
            <div id="govQuickActionsCorridorLabel" style="
              font-size:11px; color:#64748b; margin-bottom:12px; min-height:16px;
            ">Select a corridor to enable actions</div>

            <div style="display:flex; gap:6px; margin-bottom:8px;">
              <button onclick="govCreateBulkAllotment(50000000)" style="
                flex:1; background:linear-gradient(135deg,#0d6e6e,#0d9488);
                color:white; border:none; border-radius:8px;
                padding:11px 0; font-size:12px; font-weight:700; cursor:pointer;
              ">Inject 50M</button>
              <button onclick="govCreateBulkAllotment(100000000)" style="
                flex:1; background:linear-gradient(135deg,#0d6e6e,#0d9488);
                color:white; border:none; border-radius:8px;
                padding:11px 0; font-size:12px; font-weight:700; cursor:pointer;
              ">Inject 100M</button>
            </div>

            <button onclick="govHaltCorridor()" style="
              width:100%; background:linear-gradient(135deg,#7f1d1d,#b91c1c);
              color:white; border:none; border-radius:8px;
              padding:11px 0; font-size:12px; font-weight:700; cursor:pointer;
              letter-spacing:0.3px; margin-bottom:8px;
            ">⚡ Halt Corridor</button>

            <button onclick="govAdjustDailyCap()" style="
              width:100%; background:rgba(255,255,255,0.07);
              color:#cbd5e1; border:1px solid rgba(255,255,255,0.12);
              border-radius:8px; padding:10px; font-size:12px;
              font-weight:600; cursor:pointer; text-align:center;
            ">📊 Adjust Daily Cap</button>
          </div>

        </div>
      </div>

      <!-- ── Section 1: Pending Issuance Queue ─────────────────────────── -->
      <div style="
        background: white; border-radius: 16px; overflow: hidden;
        margin-bottom: 20px; border: 1px solid #e5e7eb;
      ">
        <div onclick="toggleGovernorSection('governorQueueContent')" style="
          display: flex; align-items: center; justify-content: space-between;
          padding: 16px 20px; cursor: pointer;
          border-bottom: 1px solid #e5e7eb; background: #fafafa;
        ">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="
              width: 28px; height: 28px; background: #dbeafe;
              border-radius: 8px; display: flex; align-items: center; justify-content: center;
            ">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: #1d1d1f;">
              Pending Issuance Queue
            </h3>
            <span id="governorQueueCount" style="
              background: #fef3c7; color: #d97706;
              padding: 3px 10px; border-radius: 12px;
              font-size: 12px; font-weight: 600;
            ">0</span>
          </div>
          <svg id="governorQueueContentChevron" width="20" height="20" viewBox="0 0 24 24"
               fill="none" stroke="#9ca3af" stroke-width="2" style="transition: transform 0.2s;">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </div>

        <div id="governorQueueContent">
          <!-- Table Header -->
          <div style="
            display: grid;
            grid-template-columns: 40px 160px 180px 120px 140px 110px 120px;
            gap: 8px; padding: 12px 20px;
            background: #f9fafb; border-bottom: 1px solid #e5e7eb;
            font-size: 11px; font-weight: 600; color: #6b7280;
            text-transform: uppercase; letter-spacing: 0.5px;
          ">
            <span>#</span>
            <span>AUTH ID</span>
            <span>INSTITUTION</span>
            <span>CLAIM</span>
            <span>CORRIDOR</span>
            <span>ASSET</span>
            <span>AMOUNT</span>
          </div>

          <div id="governorAuthsLoading" style="
            display: flex; justify-content: center; align-items: center;
            padding: 40px; color: #6b7280; font-size: 14px;
          ">
            <span style="margin-right: 8px;">⏳</span> Loading authorizations...
          </div>

          <div id="governorAuthsRows"></div>

          <!-- Pagination -->
          <div style="display: flex; justify-content: center; padding: 16px; border-top: 1px solid #f3f4f6;">
            <div style="display: flex; gap: 4px; align-items: center;">
              <button onclick="governorPrevPage()" id="governorPrevBtn" style="
                padding: 6px 10px; background: white;
                border: 1px solid #e5e7eb; border-radius: 6px; cursor: pointer; color: #9ca3af;
              ">‹</button>
              <span id="governorPageNumbers" style="display: flex; gap: 4px;"></span>
              <button onclick="governorNextPage()" id="governorNextBtn" style="
                padding: 6px 10px; background: white;
                border: 1px solid #e5e7eb; border-radius: 6px; cursor: pointer; color: #9ca3af;
              ">›</button>
            </div>
          </div>
        </div>
      </div>

      <!-- ── Section 2: Review Issuance Authorization ───────────────────── -->
      <div id="governorReviewSection" style="
        background: white; border-radius: 16px; overflow: hidden;
        margin-bottom: 20px; border: 1px solid #e5e7eb; display: none;
      ">
        <div onclick="toggleGovernorSection('governorReviewContent')" style="
          display: flex; align-items: center; justify-content: space-between;
          padding: 16px 20px; cursor: pointer;
          border-bottom: 1px solid #e5e7eb; background: #fafafa;
        ">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="
              width: 28px; height: 28px; background: #dbeafe;
              border-radius: 8px; display: flex; align-items: center; justify-content: center;
            ">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: #1d1d1f;">
              Review Issuance Authorization
            </h3>
          </div>
          <svg id="governorReviewContentChevron" width="20" height="20" viewBox="0 0 24 24"
               fill="none" stroke="#9ca3af" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </div>

        <div id="governorReviewContent" style="padding: 24px;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">

            <!-- ── Left Column: Authorization Overview ──────────────────── -->
            <div>
              <div style="
                display: flex; align-items: center; gap: 12px;
                margin-bottom: 20px; padding-bottom: 16px;
                border-bottom: 1px solid #e5e7eb;
              ">
                <div id="govInstitutionFlag" style="
                  width: 44px; height: 44px; background: #f3f4f6;
                  border-radius: 10px; display: flex; align-items: center;
                  justify-content: center; font-size: 24px;
                ">🏦</div>
                <div>
                  <div id="govInstitutionName" style="font-size: 17px; font-weight: 600; color: #1d1d1f;">—</div>
                  <div id="govInstitutionType" style="font-size: 12px; color: #6b7280;">Authorized Dealer Bank</div>
                </div>
              </div>

              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div>
                  <div style="font-size: 12px; color: #9ca3af; margin-bottom: 4px;">Authorization ID</div>
                  <div id="govAuthCode" style="font-size: 13px; color: #1d1d1f; font-weight: 600; font-family: monospace;">—</div>
                </div>
                <div>
                  <div style="font-size: 12px; color: #9ca3af; margin-bottom: 4px;">Trade Claim</div>
                  <div id="govTradeClaimId" style="font-size: 13px; color: #1d1d1f; font-family: monospace;">—</div>
                </div>
                <div>
                  <div style="font-size: 12px; color: #9ca3af; margin-bottom: 4px;">Trade Claim</div>
                  <div id="govCorridorDisplay" style="font-size: 14px; color: #1d1d1f; font-weight: 500;">—</div>
                </div>
                <div>
                  <div style="font-size: 12px; color: #9ca3af; margin-bottom: 4px;">Corridor</div>
                  <div id="govCorridorDisplay2" style="font-size: 14px; color: #1d1d1f; font-weight: 500;">—</div>
                </div>
                <div>
                  <div style="font-size: 12px; color: #9ca3af; margin-bottom: 4px;">Asset</div>
                  <div id="govAssetCode" style="font-size: 20px; font-weight: 700; color: #1d1d1f;">—</div>
                </div>
                <div>
                  <div style="font-size: 12px; color: #9ca3af; margin-bottom: 4px;">Issuance Amount</div>
                  <div id="govAmount" style="font-size: 14px; font-weight: 600; color: #1d1d1f;">—</div>
                </div>
              </div>

              <!-- Beneficiary Info -->
              <div style="margin-top: 20px; padding-top: 16px; border-top: 1px solid #e5e7eb;">
                <div style="font-size: 13px; font-weight: 600; color: #1d1d1f; margin-bottom: 12px;">Beneficiary Info</div>
                <div style="background: #f9fafb; border-radius: 10px; padding: 14px;">
                  <div style="display: flex; align-items: center; gap: 10px;">
                    <div style="
                      width: 32px; height: 32px; background: #e5e7eb;
                      border-radius: 8px; display: flex; align-items: center; justify-content: center;
                    ">👤</div>
                    <div>
                      <div style="font-size: 12px; color: #9ca3af;">Beneficiary Name:</div>
                      <div id="govBeneficiaryName" style="font-size: 14px; color: #1d1d1f; font-weight: 500;">—</div>
                    </div>
                  </div>
                  <div style="margin-top: 10px; display: flex; gap: 20px;">
                    <div>
                      <div style="font-size: 11px; color: #9ca3af;">Bank</div>
                      <div id="govBeneficiaryBank" style="font-size: 13px; color: #374151;">—</div>
                    </div>
                    <div>
                      <div style="font-size: 11px; color: #9ca3af;">Country</div>
                      <div id="govBeneficiaryCountry" style="font-size: 13px; color: #374151;">—</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>

            <!-- ── Right Column: Governance Gating Conditions ────────────── -->
            <div>
              <!-- Governance Conditions (passed from supervisor stage) -->
              <div style="font-size: 13px; font-weight: 600; color: #1d1d1f; margin-bottom: 12px; display: flex; align-items: center; justify-content: space-between;">
                <span>Governance Conditions <span style="font-weight: 400; color: #6b7280; font-size: 11px; margin-left: 4px;">(System-Generated)</span></span>
              </div>

              <div style="background: #f9fafb; border-radius: 12px; padding: 12px; display: flex; flex-direction: column; gap: 8px; margin-bottom: 16px;">
                <% [
                  ['1. Supervisor Approval',   'Trade claim approved'],
                  ['2. Compliance Passed',      'AML / sanctions checks'],
                  ['3. Corridor Limits Available','Daily issuance quota available'],
                  ['4. Liquidity Locked',       'Reserve pool locked'],
                  ['5. Policy Compliance Met',  'Monetary rules satisfied'],
                ].each_with_index do |(label, desc), i| %>
                <div style="background: white; border-radius: 8px; border: 1px solid #a7f3d0; overflow: hidden;">
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 9px 12px;">
                    <div style="display: flex; align-items: center; gap: 9px;">
                      <span style="font-size: 15px;">✅</span>
                      <div>
                        <div style="font-size: 12px; font-weight: 600; color: #374151;"><%= label %></div>
                        <div style="font-size: 10px; color: #9ca3af;"><%= desc %></div>
                      </div>
                    </div>
                    <span style="padding: 3px 10px; border-radius: 10px; font-size: 11px; font-weight: 600; background: #d1fae5; color: #065f46;">Passed ✓</span>
                  </div>
                </div>
                <% end %>
              </div>

              <!-- Governance Signatures Section -->
              <div style="font-size: 13px; font-weight: 600; color: #1d1d1f; margin-bottom: 10px;">Governance Signatures</div>
              <div id="govSignaturesPanel" style="background: #f9fafb; border-radius: 12px; padding: 12px; display: flex; flex-direction: column; gap: 8px;">
                <!-- Deputy Governor -->
                <div id="govSigDeputy" style="background: white; border-radius: 8px; border: 1px solid #e5e7eb; padding: 10px 14px; display: flex; align-items: center; justify-content: space-between;">
