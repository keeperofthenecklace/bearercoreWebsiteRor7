    icon:  `<svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2L2 7l10 5 10-5-10-5z"/><path d="M2 17l10 5 10-5"/><path d="M2 12l10 5 10-5"/></svg>`,
    body:  `<div style="display:grid;grid-template-columns:auto 1fr;gap:9px 18px;margin-bottom:18px;font-size:13px;align-items:baseline;">
              <span style="color:rgba(255,255,255,0.42);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;">Proposal</span>
              <span style="color:#ffffff;font-family:monospace;font-size:12px;letter-spacing:0.04em;">${proposalRef}</span>
              <span style="color:rgba(255,255,255,0.42);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;">Corridor</span>
              <span style="color:#ffffff;font-weight:600;">${govSelectedCorridorLabel}</span>
              <span style="color:rgba(255,255,255,0.42);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.06em;">Amount</span>
              <span style="color:#C9A84C;font-weight:700;font-size:18px;letter-spacing:-0.01em;">${amtFormatted}</span>
            </div>
            <div style="background:rgba(201,168,76,0.07);border:1px solid rgba(201,168,76,0.2);border-radius:10px;padding:13px 15px;">
              <div style="font-size:10px;font-weight:700;color:#C9A84C;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:5px;">⚠ Multi-Sig Required</div>
              <div style="font-size:12px;color:rgba(255,255,255,0.6);line-height:1.6;">This will create a governance proposal requiring multi-signature approval before funds are allocated to the corridor.</div>
            </div>`,
    buttons: [
      { label: 'Cancel', value: false },
      { label: 'Confirm Allotment', value: true, primary: true },
    ],
  });
  if (!confirmed) return;

  try {
    const res = await fetch('/api/v2/governance/proposals', {
      method:  'POST',
      headers: getGovernorAuthHeaders(),
      body: JSON.stringify({
        proposal: {
          type:           'bulk_allotment',
          category:       'bulk_allotment',
          title:          proposalRef,
          corridor:       govSelectedCorridorLabel,
          corridor_id:    govSelectedCorridorId,
          new_cap:        amount.toString(),
          effective_date: new Date(Date.now() + 86400000).toISOString().split('T')[0],
          justification:  `Sovereign liquidity injection — ${amtFormatted} for ${govSelectedCorridorLabel} corridor`,
          rationale:      'Governor-initiated bulk allotment from Approval Desk',
        }
      })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);

    const propId = data?.data?.proposal_id || data?.data?.id || proposalRef;
    await govAlert({
      tag:     'Proposal Submitted',
      title:   'Allotment Queued',
      message: `Bulk allotment proposal <strong style="color:#C9A84C;font-family:monospace;">${propId}</strong> has been submitted and is pending multi-sig governance approval.`,
    });
    loadGovRecentEvents();
  } catch (err) {
    await govAlert({ tag:'Error', title:'Submission Failed', message:err.message, danger:true });
  }
}
</script>
