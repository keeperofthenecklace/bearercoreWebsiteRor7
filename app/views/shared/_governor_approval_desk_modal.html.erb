<%#
  View: app/views/shared/_governor_approval_desk_modal.html.erb

  MACRO-CORRIDOR MANAGEMENT CONSOLE
  ==================================
  Governor's sovereign infrastructure console — protocol-driven settlement.
  Issuance is authorized automatically by protocol conditions; the Governor
  manages corridor capacity, daily caps, halt authority, and multi-sig
  governance for corridor parameter changes.

  ROLES THAT USE THIS CONSOLE:
  - Governor
  - Deputy Governor
  - Monetary Committee (multi-sig on corridor proposals)

  GOVERNANCE MODEL:
  - Corridor caps and halt decisions require multi-sig proposals
  - Protocol conditions gate minting automatically (no manual approval queue)
  - All corridor interventions written to governance_proposals + audit_logs

  API ENDPOINTS USED:
  - GET  /api/v2/corridors?per_page=50
  - GET  /api/v2/corridors/:id/liquidity_position
  - POST /api/v2/corridors/:id/halt
  - POST /api/v2/governance/proposals           (cap change, halt)
  - GET  /api/v2/governance/proposals?status=pending
%>

<!-- Macro-Corridor Management Console Modal Overlay -->
<div id="governorDeskModalOverlay" style="
  display: none;
  position: fixed;
  top: 0; left: 0; right: 0; bottom: 0;
  background: rgba(0, 0, 0, 0.65);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 10000;
  justify-content: center;
  align-items: center;
  padding: 20px;
">
  <div style="
    background: #f0f2f5;
    border-radius: 20px;
    width: 100%;
    max-width: 1180px;
    max-height: 92vh;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    display: flex;
    flex-direction: column;
  ">

    <!-- ── Header ─────────────────────────────────────────────────────── -->
    <div style="
      background: linear-gradient(135deg, #0A192F 0%, #0d2240 50%, #0A192F 100%);
      padding: 22px 28px;
      position: relative;
      overflow: hidden;
      flex-shrink: 0;
    ">
      <div style="
        position: absolute; top: 0; left: 0; right: 0; bottom: 0;
        background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.06) 1px, transparent 0);
        background-size: 22px 22px;
        pointer-events: none;
      "></div>

      <div style="display: flex; justify-content: space-between; align-items: center; position: relative; z-index: 1;">
        <div style="display: flex; align-items: center; gap: 16px;">
          <div style="
            width: 50px; height: 50px;
            background: rgba(13,148,136,0.25);
            border: 1px solid rgba(13,148,136,0.4);
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
          ">
            <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="#2dd4bf" stroke-width="1.6">
              <rect x="1" y="3" width="15" height="13" rx="2"></rect>
              <path d="M16 8h6l2 6H16v-6z"></path>
              <circle cx="5.5" cy="18.5" r="2.5"></circle>
              <circle cx="18.5" cy="18.5" r="2.5"></circle>
            </svg>
          </div>
          <div>
            <div style="font-size: 10px; color: rgba(255,255,255,0.5); text-transform: uppercase; letter-spacing: 1.5px; margin-bottom: 3px;">
              Governor's Command Center
            </div>
            <h2 style="margin: 0; font-size: 20px; font-weight: 700; color: #ffffff; letter-spacing: -0.3px;">
              Macro-Corridor Management Console
            </h2>
            <p style="margin: 3px 0 0; font-size: 12px; color: rgba(255,255,255,0.55);">
              Sovereign corridor capacity · Halt authority · Protocol-driven settlement
            </p>
          </div>
        </div>

        <div style="display: flex; align-items: center; gap: 12px;">
          <button onclick="loadMacroConsole()" style="
            background: rgba(13,148,136,0.2); color: #2dd4bf;
            border: 1px solid rgba(13,148,136,0.35); border-radius: 8px;
            padding: 7px 14px; font-size: 12px; font-weight: 600; cursor: pointer;
          " onmouseover="this.style.background='rgba(13,148,136,0.35)'"
             onmouseout="this.style.background='rgba(13,148,136,0.2)'">↻ Refresh</button>
          <button onclick="hideGovernorDeskModal()" style="
            width: 34px; height: 34px;
            border-radius: 50%; border: none;
            background: rgba(255,255,255,0.12);
            color: white; font-size: 20px; cursor: pointer;
            display: flex; align-items: center; justify-content: center;
          " onmouseover="this.style.background='rgba(255,255,255,0.22)'"
             onmouseout="this.style.background='rgba(255,255,255,0.12)'">×</button>
        </div>
      </div>
    </div>

    <!-- ── Content Area ───────────────────────────────────────────────── -->
    <div style="flex: 1; overflow-y: auto; padding: 22px; background: #f0f2f5;">

      <!-- ── Network Status Bar ────────────────────────────────────────── -->
      <div id="govNetworkStatusBar" style="
        display: grid; grid-template-columns: repeat(4, 1fr);
        gap: 12px; margin-bottom: 18px;
      ">
        <div style="background:#0A192F;border-radius:12px;padding:14px 16px;border:1px solid rgba(255,255,255,0.06);">
          <div style="font-size:9px;color:#475569;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:6px;">Total Daily Volume</div>
          <div id="govNetVolume" style="font-size:20px;font-weight:800;color:#f1f5f9;">—</div>
          <div style="font-size:10px;color:#475569;margin-top:2px;">across all corridors</div>
        </div>
        <div style="background:#0A192F;border-radius:12px;padding:14px 16px;border:1px solid rgba(255,255,255,0.06);">
          <div style="font-size:9px;color:#475569;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:6px;">Active Corridors</div>
          <div id="govNetActiveCorridors" style="font-size:20px;font-weight:800;color:#2dd4bf;">—</div>
          <div style="font-size:10px;color:#475569;margin-top:2px;">of <span id="govNetTotalCorridors">—</span> total</div>
        </div>
        <div style="background:#0A192F;border-radius:12px;padding:14px 16px;border:1px solid rgba(255,255,255,0.06);">
          <div style="font-size:9px;color:#475569;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:6px;">Corridor Health</div>
          <div id="govNetHealth" style="font-size:20px;font-weight:800;color:#2dd4bf;">—</div>
          <div style="font-size:10px;color:#475569;margin-top:2px;">avg headroom</div>
        </div>
        <div style="background:#0A192F;border-radius:12px;padding:14px 16px;border:1px solid rgba(255,255,255,0.06);">
          <div style="font-size:9px;color:#475569;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:6px;">Last Updated</div>
          <div id="govNetLastUpdate" style="font-size:14px;font-weight:700;color:#94a3b8;font-family:monospace;">—</div>
          <div style="font-size:10px;color:#475569;margin-top:2px;">console refresh</div>
        </div>
      </div>

      <!-- ── Active System Intervention Alert ──────────────────────────── -->
      <div id="govInterventionPanel" style="display:none;margin-bottom:18px;"></div>

      <!-- ── Sovereign Dashboard ───────────────────────────────────────── -->
      <div style="
        background: #0A192F; border-radius: 16px;
        margin-bottom: 18px; padding: 20px;
        border: 1px solid rgba(255,255,255,0.06);
      ">
        <!-- Title row -->
        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:16px;">
          <div>
            <div style="font-size:10px; color:#475569; letter-spacing:1.5px; text-transform:uppercase; margin-bottom:3px;">
              Sovereign Dashboard
            </div>
            <div style="font-size:16px; font-weight:700; color:#f1f5f9;">
              Corridor Reservoir Control
            </div>
          </div>
          <button onclick="loadGovCorridorLiquidity(); loadGovRecentEvents();" style="
            background:rgba(255,255,255,0.07); color:#94a3b8;
            border:1px solid rgba(255,255,255,0.12); border-radius:8px;
            padding:6px 14px; font-size:12px; cursor:pointer;
          ">↻ Refresh</button>
        </div>

        <!-- Top row: Corridor Selector (left) + Sovereign Status (right) -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px; margin-bottom:14px;">

          <!-- Top Left: Corridor Selector -->
          <div style="
            background:rgba(255,255,255,0.04);
            border:1px solid rgba(255,255,255,0.08);
            border-radius:12px; padding:14px;
          ">
            <div style="font-size:10px; color:#475569; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:10px;">
              Select Corridor
            </div>
            <input id="govCorridorSearch" type="text" placeholder="Search corridors…"
                   oninput="govFilterCorridors()"
                   style="
                     width:100%; box-sizing:border-box; margin-bottom:8px;
                     background:rgba(255,255,255,0.06); color:#e2e8f0;
                     border:1px solid rgba(255,255,255,0.12); border-radius:8px;
                     padding:6px 10px; font-size:12px; outline:none;
                   ">
            <select id="govCorridorSelect" size="5"
                    onchange="govSelectCorridor(this.value, this.options[this.selectedIndex]?.text)"
                    style="
                      width:100%;
                      background:rgba(255,255,255,0.06); color:#e2e8f0;
                      border:1px solid rgba(255,255,255,0.12); border-radius:8px;
                      padding:5px 8px; font-size:12px; cursor:pointer; outline:none;
                    ">
              <option value="" style="background:#0f2744;">⏳ Loading corridors…</option>
            </select>
          </div>

          <!-- Top Right: Sovereign Status -->
          <div style="
            background:rgba(255,255,255,0.04);
            border:1px solid rgba(255,255,255,0.08);
            border-radius:12px; padding:14px;
            display:flex; flex-direction:column; justify-content:center; align-items:center;
          ">
            <div style="font-size:10px; color:#475569; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:12px;">
              Sovereign Status
            </div>
            <div id="govSovereignStatusBadge" style="
              font-size:22px; font-weight:800; color:#2dd4bf;
              letter-spacing:1px; margin-bottom:8px;
            ">IN SYNC</div>
            <div style="
              background:rgba(13,148,136,0.2); color:#2dd4bf;
              border-radius:20px; padding:3px 14px; font-size:10px; font-weight:700;
              margin-bottom:14px;
            ">● OPERATIONAL</div>
            <div style="text-align:center;">
              <div style="font-size:9px; color:#475569; text-transform:uppercase; letter-spacing:0.8px; margin-bottom:3px;">Last Audit</div>
              <div id="govLastAuditTimestamp" style="font-size:11px; color:#94a3b8; font-family:monospace;">—</div>
            </div>
          </div>
        </div>

        <!-- Middle Row: Wide Fuel Gauge for selected corridor -->
        <div style="
          background:rgba(255,255,255,0.04);
          border:1px solid rgba(255,255,255,0.08);
          border-radius:12px; padding:16px; margin-bottom:14px;
        ">
          <div style="font-size:10px; color:#475569; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:12px;">
            Bulk Allotment Reservoir — Selected Corridor
          </div>
          <div id="govFuelGaugeContent">
            <div style="color:#475569; font-size:13px; text-align:center; padding:20px 0;">
              Select a corridor above to view the reservoir gauge
            </div>
          </div>
        </div>

        <!-- Bottom Row: Recent Events (left) + Quick Actions (right) -->
        <div style="display:grid; grid-template-columns:1fr 1fr; gap:14px;">

          <!-- Bottom Left: Recent Bulk Allotments -->
          <div style="
            background:rgba(255,255,255,0.04);
            border:1px solid rgba(255,255,255,0.08);
            border-radius:12px; padding:14px;
          ">
            <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:10px;">
              <div style="font-size:10px; color:#475569; text-transform:uppercase; letter-spacing:1.2px;">
                Recent Bulk Allotments
              </div>
              <button onclick="loadGovRecentEvents()" style="
                background:none; color:#475569; border:none; font-size:13px; cursor:pointer; padding:2px 6px;
              ">↻</button>
            </div>
            <div id="govRecentEventsRows" style="display:flex; flex-direction:column; gap:6px; max-height:180px; overflow-y:auto;">
              <div style="color:#475569; font-size:12px; text-align:center; padding:20px;">
                ⏳ Loading…
              </div>
            </div>
          </div>

          <!-- Bottom Right: Quick Actions -->
          <div style="
            background:rgba(255,255,255,0.04);
            border:1px solid rgba(255,255,255,0.08);
            border-radius:12px; padding:14px;
          ">
            <div style="font-size:10px; color:#475569; text-transform:uppercase; letter-spacing:1.2px; margin-bottom:10px;">
              Quick Actions
            </div>
            <div id="govQuickActionsCorridorLabel" style="
              font-size:11px; color:#64748b; margin-bottom:12px; min-height:16px;
            ">Select a corridor to enable actions</div>

            <div style="display:flex; gap:6px; margin-bottom:8px;">
              <button onclick="govCreateBulkAllotment(50000000)" style="
                flex:1; background:linear-gradient(135deg,#0d6e6e,#0d9488);
                color:white; border:none; border-radius:8px;
                padding:11px 0; font-size:12px; font-weight:700; cursor:pointer;
              ">Inject 50M</button>
              <button onclick="govCreateBulkAllotment(100000000)" style="
                flex:1; background:linear-gradient(135deg,#0d6e6e,#0d9488);
                color:white; border:none; border-radius:8px;
                padding:11px 0; font-size:12px; font-weight:700; cursor:pointer;
              ">Inject 100M</button>
            </div>

            <button onclick="govHaltCorridor()" style="
              width:100%; background:linear-gradient(135deg,#7f1d1d,#b91c1c);
              color:white; border:none; border-radius:8px;
              padding:11px 0; font-size:12px; font-weight:700; cursor:pointer;
              letter-spacing:0.3px; margin-bottom:8px;
            ">⚡ Halt Corridor</button>

            <button onclick="govAdjustDailyCap()" style="
              width:100%; background:rgba(255,255,255,0.07);
              color:#cbd5e1; border:1px solid rgba(255,255,255,0.12);
              border-radius:8px; padding:10px; font-size:12px;
              font-weight:600; cursor:pointer; text-align:center;
            ">📊 Adjust Daily Cap</button>
          </div>

        </div>
      </div>

      <!-- ── Regional Corridor Reservoir Grid ──────────────────────────── -->
      <div style="
        background: white; border-radius: 16px;
        margin-bottom: 18px; border: 1px solid #e2e8f0; overflow: hidden;
      ">
        <div style="
          display: flex; align-items: center; justify-content: space-between;
          padding: 16px 20px; background: #fafafa;
          border-bottom: 1px solid #e5e7eb;
        ">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="
              width: 28px; height: 28px;
              background: rgba(13,148,136,0.12);
              border-radius: 8px; display: flex; align-items: center; justify-content: center;
            ">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#0d9488" stroke-width="2.5">
                <path d="M3 3v18h18"></path>
                <path d="M18.4 9.6L13 15l-4-4-5 5"></path>
              </svg>
            </div>
            <div>
              <h3 style="margin: 0; font-size: 15px; font-weight: 700; color: #0f172a;">
                Regional Corridor Reservoir Status
              </h3>
              <div style="font-size: 11px; color: #94a3b8; margin-top: 1px;">
                Live headroom · cap · intervention authority
              </div>
            </div>
          </div>
          <button onclick="loadCorridorReservoirGrid()" style="
            background: #f0fdf4; color: #059669;
            border: 1px solid #bbf7d0; border-radius: 8px;
            padding: 6px 14px; font-size: 12px; font-weight: 600; cursor: pointer;
          ">↻ Refresh</button>
        </div>

        <div id="govCorridorReservoirGrid" style="padding: 18px;">
          <div style="text-align:center;padding:40px;color:#94a3b8;font-size:14px;">
            ⏳ Loading corridor reservoirs…
          </div>
        </div>
      </div>

      <!-- ── Governance Signatures Required ────────────────────────────── -->
      <div style="
        background: white; border-radius: 16px;
        border: 1px solid #e2e8f0; overflow: hidden;
      ">
        <div style="
          display: flex; align-items: center; justify-content: space-between;
          padding: 16px 20px; background: #fafafa;
          border-bottom: 1px solid #e5e7eb;
        ">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="
              width: 28px; height: 28px;
              background: #eff6ff;
              border-radius: 8px; display: flex; align-items: center; justify-content: center;
            ">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#2563eb" stroke-width="2.5">
                <path d="M17 11H7m10 0a5 5 0 01-5 5 5 5 0 01-5-5m10 0a5 5 0 00-5-5 5 5 0 00-5 5"></path>
                <path d="M12 18v4M7 21h10"></path>
              </svg>
            </div>
            <div>
              <h3 style="margin: 0; font-size: 15px; font-weight: 700; color: #0f172a;">
                Governance Signatures Required
              </h3>
              <div style="font-size: 11px; color: #94a3b8; margin-top: 1px;">
                Pending corridor parameter proposals · multi-sig authorization
              </div>
            </div>
            <span id="govPendingProposalCount" style="
              background: #fef3c7; color: #d97706;
              padding: 3px 10px; border-radius: 12px;
              font-size: 12px; font-weight: 600;
            ">0</span>
          </div>
          <button onclick="loadGovernanceSignatures()" style="
            background: #eff6ff; color: #2563eb;
            border: 1px solid #bfdbfe; border-radius: 8px;
            padding: 6px 14px; font-size: 12px; font-weight: 600; cursor: pointer;
          ">↻ Refresh</button>
        </div>

        <div id="govSignaturesPanel" style="padding: 18px;">
          <div style="text-align:center;padding:40px;color:#94a3b8;font-size:14px;">
            ⏳ Loading governance proposals…
          </div>
        </div>
      </div>

    </div>

    <!-- ── Footer ─────────────────────────────────────────────────────── -->
    <div style="
      padding: 14px 24px; background: white; border-top: 1px solid #e5e7eb;
      display: flex; justify-content: space-between; align-items: center;
      flex-shrink: 0;
    ">
      <div style="display:flex;gap:24px;">
        <a href="#" style="color: #6b7280; text-decoration: none; font-size: 12px;">📖 Help &amp; Docs</a>
        <a href="#" style="color: #6b7280; text-decoration: none; font-size: 12px;">Contact Support</a>
        <a href="#" onclick="hideGovernorDeskModal(); return false;" style="color: #6b7280; text-decoration: none; font-size: 12px;">Dashboard</a>
      </div>
      <div style="font-size:11px;color:#cbd5e1;font-family:monospace;">bearerCORE™ Protocol · Sovereign Settlement Engine</div>
    </div>
  </div>
</div>

<!-- ── Governor Desk Custom Dialog ──────────────────────────────────────── -->
<div id="govCustomDialog" style="
  display:none; position:fixed; inset:0; z-index:10200;
  background:rgba(0,0,0,0.6); backdrop-filter:blur(4px);
  justify-content:center; align-items:center;
">
  <div style="
    background:#0f172a; border:1px solid rgba(45,212,191,0.2);
    border-radius:18px; padding:28px 30px; width:460px; max-width:92vw;
    box-shadow:0 24px 56px rgba(0,0,0,0.75);
  ">
    <div style="display:flex;align-items:center;gap:12px;margin-bottom:20px;">
      <div id="govDialogIconBox" style="
        width:40px;height:40px;border-radius:11px;
        display:flex;align-items:center;justify-content:center;font-size:20px;
        flex-shrink:0;
      "></div>
      <div>
        <div id="govDialogTitle" style="font-size:15px;font-weight:700;color:#f1f5f9;"></div>
        <div id="govDialogSubtitle" style="font-size:11px;color:#64748b;margin-top:3px;font-family:monospace;"></div>
      </div>
    </div>

    <div id="govDialogBody" style="margin-bottom:20px;font-size:13px;color:#94a3b8;line-height:1.6;"></div>

    <div id="govDialogInputWrap" style="margin-bottom:20px;">
      <label id="govDialogLabel" style="
        display:block;font-size:10px;font-weight:700;color:#64748b;
        text-transform:uppercase;letter-spacing:1px;margin-bottom:7px;
      "></label>
      <input id="govDialogInput" type="text" autocomplete="off" style="
        width:100%;box-sizing:border-box;
        background:rgba(255,255,255,0.05);color:#f1f5f9;
        border:1px solid rgba(45,212,191,0.25);border-radius:10px;
        padding:11px 14px;font-size:15px;font-family:monospace;outline:none;
        transition:border-color 0.15s;
      "
        onfocus="this.style.borderColor='rgba(45,212,191,0.6)'"
        onblur="this.style.borderColor='rgba(45,212,191,0.25)'"
        onkeydown="if(event.key==='Enter')govConfirmDialog();if(event.key==='Escape')govHideDialog();"
      >
    </div>

    <div style="display:flex;gap:10px;justify-content:flex-end;">
      <button onclick="govHideDialog()" style="
        padding:10px 22px;border-radius:10px;font-size:13px;font-weight:600;cursor:pointer;
        background:rgba(255,255,255,0.05);color:#94a3b8;border:1px solid rgba(255,255,255,0.1);
      " onmouseover="this.style.background='rgba(255,255,255,0.1)'"
         onmouseout="this.style.background='rgba(255,255,255,0.05)'">Cancel</button>
      <button id="govDialogConfirmBtn" onclick="govConfirmDialog()" style="
        padding:10px 26px;border-radius:10px;font-size:13px;font-weight:700;cursor:pointer;
        border:none;color:white;
      ">Confirm</button>
    </div>
  </div>
</div>

<!-- ── Governor Desk Toast ───────────────────────────────────────────────── -->
<div id="govToast" style="
  display:none; position:fixed; bottom:32px; left:50%; transform:translateX(-50%);
  z-index:10300; padding:12px 22px; border-radius:12px;
  font-size:13px; font-weight:600; font-family:system-ui,sans-serif;
  box-shadow:0 8px 24px rgba(0,0,0,0.4); pointer-events:none;
  white-space:nowrap; max-width:90vw; text-align:center;
"></div>

<style>
.gov-corridor-card:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.1); transform: translateY(-1px); transition: all 0.18s ease; }
.gov-corridor-card { transition: all 0.18s ease; }

.gov-proposal-row:hover { background: #f8fafc !important; }

@media (max-width: 900px) {
  #governorDeskModalOverlay { padding: 10px !important; align-items: flex-start !important; }
  #governorDeskModalOverlay > div { max-width: 100% !important; max-height: 95vh !important; border-radius: 16px !important; }
  #govNetworkStatusBar { grid-template-columns: 1fr 1fr !important; }
}
@media (max-width: 560px) {
  #governorDeskModalOverlay { padding: 0 !important; align-items: flex-end !important; }
  #governorDeskModalOverlay > div { border-radius: 20px 20px 0 0 !important; max-height: 96vh !important; height: 96vh !important; }
  #govNetworkStatusBar { grid-template-columns: 1fr !important; }
}
</style>

<script>
// ═══════════════════════════════════════════════════════════════════════════
// MACRO-CORRIDOR MANAGEMENT CONSOLE — STATE & FUNCTIONS
// ═══════════════════════════════════════════════════════════════════════════

let govCorridorLiquidityData = [];
let govSelectedCorridorId    = '';
let govSelectedCorridorLabel = '';

const GOV_BLOCS = {
  'ECOWAS': ['NGA','GHA','SEN','CIV','BEN','TGO','GIN','SLE','GMB','LBR','GNB','CPV'],
  'AES':    ['BFA','MLI','NER'],
  'EAC':    ['KEN','TZA','UGA','RWA','BDI','SSD'],
  'SADC':   ['ZAF','ZWE','ZMB','MOZ','MWI','BWA','NAM','LSO','SWZ','AGO','MDG','MUS'],
  'CEMAC':  ['CMR','CAF','COG','GAB','GNQ','TCD'],
  'AMU':    ['MAR','DZA','TUN','LBY','MRT'],
  'IGAD':   ['ETH','SOM','DJI','ERI','SDN'],
};

function govGetBloc(isoCode) {
  const code = (isoCode || '').toUpperCase().slice(0, 3);
  for (const [bloc, members] of Object.entries(GOV_BLOCS)) {
    if (members.includes(code)) return bloc;
  }
  return 'Other';
}

// ── Modal open / close ──────────────────────────────────────────────────────
function showGovernorDeskModal() {
  document.getElementById('governorDeskModalOverlay').style.display = 'flex';
  document.body.style.overflow = 'hidden';
  loadMacroConsole();
}

function hideGovernorDeskModal() {
  document.getElementById('governorDeskModalOverlay').style.display = 'none';
  document.body.style.overflow = '';
}

function loadMacroConsole() {
  loadNetworkStatus();
  loadGovCorridorLiquidity();
  loadGovRecentEvents();
  loadCorridorReservoirGrid();
  loadGovernanceSignatures();
}

// ── Auth headers ────────────────────────────────────────────────────────────
function getGovernorAuthHeaders() {
  const token = (typeof getSupervisorToken === 'function')
    ? getSupervisorToken()
    : (document.querySelector('meta[name="csrf-token"]')?.content || '');
  const headers = { 'Accept': 'application/json', 'Content-Type': 'application/json' };
  const csrf = document.querySelector('meta[name="csrf-token"]')?.content;
  if (csrf)  headers['X-CSRF-Token'] = csrf;
  headers['Authorization'] = `Bearer ${token}`;
  return headers;
}

// ═══════════════════════════════════════════════════════════════════════════
// NETWORK STATUS BAR
// ═══════════════════════════════════════════════════════════════════════════

async function loadNetworkStatus() {
  try {
    const res = await fetch('/api/v2/corridors?per_page=100', { headers: getGovernorAuthHeaders() });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();

    let corridors = [];
    if (Array.isArray(data))                                  corridors = data;
    else if (Array.isArray(data.data))                        corridors = data.data;
    else if (Array.isArray(data.corridors))                   corridors = data.corridors;
    else if (data.data && Array.isArray(data.data.corridors)) corridors = data.data.corridors;

    const total  = corridors.length;
    const active = corridors.filter(c => (c.status || 'active').toLowerCase() === 'active').length;

    // Compute average headroom from cached liquidity or corridor data
    let avgHeadroom = null;
    const withHeadroom = corridors.filter(c => {
      const lp = c.liquidity_position || c.liquidity_snapshot || {};
      const cap = parseFloat(lp.domestic_available || lp.total_liquidity || 0);
      const drawn = parseFloat(lp.linked_outstanding || lp.linked || 0);
      return cap > 0;
    });
    if (withHeadroom.length > 0) {
      const sum = withHeadroom.reduce((acc, c) => {
        const lp = c.liquidity_position || c.liquidity_snapshot || {};
        const cap = parseFloat(lp.domestic_available || lp.total_liquidity || 0);
        const drawn = parseFloat(lp.linked_outstanding || lp.linked || 0);
        return acc + Math.max(0, Math.round(((cap - drawn) / cap) * 100));
      }, 0);
      avgHeadroom = Math.round(sum / withHeadroom.length);
    }

    document.getElementById('govNetActiveCorridors').textContent = active;
    document.getElementById('govNetTotalCorridors').textContent  = total;
    document.getElementById('govNetLastUpdate').textContent      = new Date().toLocaleTimeString();

    if (avgHeadroom !== null) {
      const el = document.getElementById('govNetHealth');
      el.textContent = `${avgHeadroom}%`;
      el.style.color = avgHeadroom < 20 ? '#f87171' : avgHeadroom < 40 ? '#fbbf24' : '#2dd4bf';
    }

    // For volume, sum all corridor daily volumes if present
    let totalVol = 0;
    corridors.forEach(c => {
      const v = parseFloat(c.daily_volume || c.volume_today || 0);
      totalVol += v;
    });
    if (totalVol > 0) {
      document.getElementById('govNetVolume').textContent =
        totalVol >= 1e9 ? `${(totalVol/1e9).toFixed(2)}B`
        : totalVol >= 1e6 ? `${(totalVol/1e6).toFixed(1)}M`
        : totalVol.toLocaleString(undefined, { maximumFractionDigits: 0 });
    } else {
      document.getElementById('govNetVolume').textContent = 'N/A';
    }

    // Check for interventions
    updateInterventionPanel(corridors);

  } catch (err) {
    console.error('[MacroConsole] Network status error:', err);
    document.getElementById('govNetLastUpdate').textContent = 'Error';
  }
}

function updateInterventionPanel(corridors) {
  const panel = document.getElementById('govInterventionPanel');
  if (!panel) return;

  const issues = corridors.filter(c => {
    const status = (c.status || 'active').toLowerCase();
    if (status === 'halted' || status === 'suspended') return true;
    const lp  = c.liquidity_position || c.liquidity_snapshot || {};
    const cap = parseFloat(lp.domestic_available || lp.total_liquidity || 0);
    const drawn = parseFloat(lp.linked_outstanding || lp.linked || 0);
    if (cap > 0) {
      const headroom = (cap - drawn) / cap;
      return headroom < 0.1;
    }
    return false;
  });

  if (issues.length === 0) {
    panel.style.display = 'none';
    return;
  }

  panel.style.display = 'block';
  panel.innerHTML = `
    <div style="
      background: linear-gradient(135deg, #450a0a, #7f1d1d);
      border: 1px solid rgba(239,68,68,0.4);
      border-radius: 14px; padding: 16px 20px;
    ">
      <div style="display:flex;align-items:center;gap:10px;margin-bottom:12px;">
        <div style="
          width:32px;height:32px;background:rgba(239,68,68,0.3);border-radius:8px;
          display:flex;align-items:center;justify-content:center;font-size:16px;
        ">⚡</div>
        <div>
          <div style="font-size:13px;font-weight:700;color:#fca5a5;">
            ${issues.length} Corridor${issues.length > 1 ? 's' : ''} Require${issues.length === 1 ? 's' : ''} Immediate Attention
          </div>
          <div style="font-size:11px;color:rgba(252,165,165,0.7);">
            Intervention authority active — Governor action required
          </div>
        </div>
      </div>
      <div style="display:flex;flex-direction:column;gap:6px;">
        ${issues.map(c => {
          const name = c.corridor_display || c.code || `${c.source_country}→${c.target_country}`;
          const status = (c.status || 'active').toLowerCase();
          const lp = c.liquidity_position || c.liquidity_snapshot || {};
          const cap = parseFloat(lp.domestic_available || lp.total_liquidity || 0);
          const drawn = parseFloat(lp.linked_outstanding || lp.linked || 0);
          const headroomPct = cap > 0 ? Math.round(((cap - drawn) / cap) * 100) : 0;
          const reason = (status === 'halted' || status === 'suspended')
            ? `<span style="color:#fca5a5;font-weight:700;">HALTED</span>`
            : `<span style="color:#fbbf24;font-weight:700;">${headroomPct}% headroom — CRITICAL LOW</span>`;
          return `
            <div style="
              background:rgba(255,255,255,0.06);border:1px solid rgba(239,68,68,0.25);
              border-radius:8px;padding:9px 14px;
              display:flex;justify-content:space-between;align-items:center;
            ">
              <span style="font-size:12px;font-weight:600;color:#fde8e8;font-family:monospace;">${name}</span>
              <div style="display:flex;align-items:center;gap:10px;font-size:11px;">
                ${reason}
                <button onclick="govSelectedCorridorId='${c.id||c.code}';govSelectedCorridorLabel='${name}';govAdjustDailyCap()" style="
                  background:rgba(251,191,36,0.2);color:#fbbf24;border:1px solid rgba(251,191,36,0.3);
                  border-radius:6px;padding:3px 10px;font-size:11px;font-weight:600;cursor:pointer;
                ">Adjust Cap</button>
                <button onclick="govSelectedCorridorId='${c.id||c.code}';govSelectedCorridorLabel='${name}';govHaltCorridor()" style="
                  background:rgba(239,68,68,0.2);color:#fca5a5;border:1px solid rgba(239,68,68,0.3);
                  border-radius:6px;padding:3px 10px;font-size:11px;font-weight:600;cursor:pointer;
                ">Halt</button>
              </div>
            </div>`;
        }).join('')}
      </div>
    </div>`;
}

// ═══════════════════════════════════════════════════════════════════════════
// SOVEREIGN DASHBOARD — Reservoir Model
// ═══════════════════════════════════════════════════════════════════════════

function govBuildCorridorSelect(corridors) {
  const sel = document.getElementById('govCorridorSelect');
  if (!sel) return;

  const term     = (document.getElementById('govCorridorSearch')?.value || '').toLowerCase();
  const filtered = term
    ? corridors.filter(c => {
        const d = (c.corridor_display || c.code || `${c.source_country}→${c.target_country}`).toLowerCase();
        return d.includes(term);
      })
    : corridors;

  const groups = {};
  filtered.forEach(c => {
    const bloc = govGetBloc(c.source_country);
    if (!groups[bloc]) groups[bloc] = [];
    groups[bloc].push(c);
  });

  sel.innerHTML = '';

  if (filtered.length === 0) {
    const opt = document.createElement('option');
    opt.value = ''; opt.textContent = '— No corridors found —';
    opt.style.background = '#0f2744';
    sel.appendChild(opt);
    return;
  }

  const orderedBlocs = [...Object.keys(GOV_BLOCS), 'Other'].filter(b => groups[b]?.length > 0);
  orderedBlocs.forEach(bloc => {
    const group = document.createElement('optgroup');
    group.label = `— ${bloc} —`;
    groups[bloc].forEach(c => {
      const display = c.corridor_display || c.code || `${c.source_country} → ${c.target_country}`;
      const id      = c.id || c.code;
      const opt     = document.createElement('option');
      opt.value = id; opt.textContent = display;
      opt.style.background = '#0f2744';
      group.appendChild(opt);
    });
    sel.appendChild(group);
  });

  if (govSelectedCorridorId) sel.value = govSelectedCorridorId;
}

function govFilterCorridors() {
  govBuildCorridorSelect(govCorridorLiquidityData);
}

function govSelectCorridor(id, label) {
  if (!id) return;
  govSelectedCorridorId    = id;
  govSelectedCorridorLabel = (label || id).trim();
  const lbl = document.getElementById('govQuickActionsCorridorLabel');
  if (lbl) lbl.textContent = `Corridor: ${govSelectedCorridorLabel}`;
  loadCorridorGauge(id);
}

async function loadCorridorGauge(corridorId) {
  const content = document.getElementById('govFuelGaugeContent');
  if (!content) return;
  content.innerHTML = '<div style="color:#475569;font-size:13px;text-align:center;padding:20px;">⏳ Loading…</div>';

  let pos = null;
  try {
    const res = await fetch(`/api/v2/corridors/${corridorId}/liquidity_position`, {
      headers: getGovernorAuthHeaders()
    });
    if (res.ok) {
      const data = await res.json();
      pos = data.data || data.liquidity_position || data;
    }
  } catch (_) {}

  if (!pos || typeof pos !== 'object' || Object.keys(pos).length === 0) {
    const cached = govCorridorLiquidityData.find(c => String(c.id || c.code) === String(corridorId));
    pos = cached?.liquidity_position || cached?.liquidity_snapshot || cached || {};
  }

  renderSingleCorridorGauge(pos, govSelectedCorridorLabel);
}

function renderSingleCorridorGauge(pos, corridorLabel) {
  const content = document.getElementById('govFuelGaugeContent');
  if (!content) return;

  const total       = parseFloat(pos.domestic_available || pos.domestic || pos.total_liquidity || 0);
  const linked      = parseFloat(pos.linked_outstanding || pos.linked || 0);
  const headroom    = Math.max(0, total - linked);
  const drawdownPct = total > 0 ? Math.min(100, Math.round((linked / total) * 100)) : 0;
  const headroomPct = 100 - drawdownPct;
  const currency    = pos.asset_code || pos.currency || '';

  const barColor    = headroomPct < 10 ? '#dc2626' : headroomPct < 30 ? '#f59e0b' : '#0d9488';
  const statusText  = headroomPct < 10 ? '⚠ REPLENISH REQUIRED'
                    : headroomPct < 30 ? '⚡ LOW RESERVE' : '✓ HEALTHY';
  const statusColor = headroomPct < 10 ? '#fca5a5' : headroomPct < 30 ? '#fbbf24' : '#2dd4bf';
  const fmtNum      = n => n ? n.toLocaleString(undefined, { maximumFractionDigits: 0 }) : '—';
  const hasData     = total > 0;

  content.innerHTML = `
    <div style="display:flex;justify-content:space-between;align-items:flex-end;margin-bottom:10px;">
      <div>
        <div style="font-size:13px;font-weight:700;color:#e2e8f0;margin-bottom:2px;">${corridorLabel}</div>
        <div style="font-size:10px;font-weight:700;color:${statusColor};letter-spacing:0.5px;">${statusText}</div>
      </div>
      <div style="text-align:right;">
        <div style="font-size:22px;font-weight:800;color:${barColor};">${headroomPct}%</div>
        <div style="font-size:9px;color:#475569;text-transform:uppercase;">headroom</div>
      </div>
    </div>
    ${hasData ? `
    <div style="position:relative;height:18px;background:rgba(255,255,255,0.1);border-radius:9px;overflow:hidden;margin-bottom:12px;">
      <div style="position:absolute;top:0;left:0;bottom:0;width:${drawdownPct}%;background:${barColor};border-radius:9px;transition:width 0.6s ease;"></div>
      <div style="position:absolute;inset:0;display:flex;align-items:center;justify-content:center;font-size:10px;font-weight:700;color:rgba(255,255,255,0.9);">${drawdownPct}% drawn</div>
    </div>
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:10px;">
      <div style="text-align:center;background:rgba(255,255,255,0.04);border-radius:8px;padding:10px 6px;">
        <div style="font-size:9px;color:#475569;text-transform:uppercase;margin-bottom:4px;">Allotted</div>
        <div style="font-size:13px;font-weight:700;color:#e2e8f0;">${currency} ${fmtNum(total)}</div>
      </div>
      <div style="text-align:center;background:rgba(255,255,255,0.04);border-radius:8px;padding:10px 6px;">
        <div style="font-size:9px;color:#475569;text-transform:uppercase;margin-bottom:4px;">Drawn</div>
        <div style="font-size:13px;font-weight:700;color:${barColor};">${currency} ${fmtNum(linked)}</div>
      </div>
      <div style="text-align:center;background:rgba(0,212,192,0.08);border-radius:8px;padding:10px 6px;border:1px solid rgba(13,148,136,0.2);">
        <div style="font-size:9px;color:#475569;text-transform:uppercase;margin-bottom:4px;">Free</div>
        <div style="font-size:13px;font-weight:700;color:#2dd4bf;">${currency} ${fmtNum(headroom)}</div>
      </div>
    </div>` : `
    <div style="color:#475569;font-size:12px;text-align:center;padding:16px 0;background:rgba(255,255,255,0.03);border-radius:8px;">
      No liquidity data available for this corridor
    </div>`}`;
}

async function loadGovCorridorLiquidity() {
  try {
    const res  = await fetch('/api/v2/corridors?per_page=50', { headers: getGovernorAuthHeaders() });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();

    let corridors = [];
    if (Array.isArray(data))                                  corridors = data;
    else if (Array.isArray(data.data))                        corridors = data.data;
    else if (Array.isArray(data.corridors))                   corridors = data.corridors;
    else if (data.data && Array.isArray(data.data.corridors)) corridors = data.data.corridors;
    else if (data.data && Array.isArray(data.data.data))      corridors = data.data.data;

    govCorridorLiquidityData = corridors;
    govBuildCorridorSelect(corridors);

    const tsEl = document.getElementById('govLastAuditTimestamp');
    if (tsEl) tsEl.textContent = new Date().toLocaleTimeString();
  } catch (err) {
    console.error('[MacroConsole] corridor load error:', err);
    const sel = document.getElementById('govCorridorSelect');
    if (sel) sel.innerHTML = '<option value="" style="background:#0f2744;">⚠ Could not load corridors</option>';
  }
}

async function loadGovRecentEvents() {
  const rows = document.getElementById('govRecentEventsRows');
  if (!rows) return;
  rows.innerHTML = '<div style="color:#475569;font-size:12px;text-align:center;padding:20px;">⏳ Loading…</div>';

  try {
    const res = await fetch('/api/v2/governance/proposals?category=bulk_allotment&per_page=5', {
      headers: getGovernorAuthHeaders()
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();

    let proposals = [];
    if (Array.isArray(data))                                  proposals = data;
    else if (Array.isArray(data.data))                        proposals = data.data;
    else if (data.data && Array.isArray(data.data.proposals)) proposals = data.data.proposals;
    else if (Array.isArray(data.proposals))                   proposals = data.proposals;

    renderGovRecentEvents(proposals);
  } catch (err) {
    if (rows) rows.innerHTML = `<div style="color:#f87171;font-size:12px;padding:12px;">⚠ ${err.message}</div>`;
  }
}

function renderGovRecentEvents(proposals) {
  const rows = document.getElementById('govRecentEventsRows');
  if (!rows) return;

  if (proposals.length === 0) {
    rows.innerHTML = '<div style="color:#475569;font-size:12px;text-align:center;padding:20px;">No bulk allotments on record.</div>';
    return;
  }

  rows.innerHTML = proposals.slice(0, 5).map(p => {
    const propId   = p.proposal_id || p.title || ('ALOT-' + (p.id || '').toString().slice(0, 8).toUpperCase());
    const amount   = parseFloat(p.new_cap || p.amount || 0);
    const corridor = p.corridor || p.corridor_name || '—';
    const status   = (p.status || 'pending').toLowerCase();
    const ts       = p.created_at || p.submitted_at || '';
    const dateStr  = ts ? new Date(ts).toLocaleDateString() : '—';
    const amtStr   = amount ? amount.toLocaleString(undefined, { maximumFractionDigits: 0 }) : '—';
    const statusColor = status === 'approved' ? '#2dd4bf' : status === 'rejected' ? '#f87171' : '#fbbf24';

    return `
      <div style="background:rgba(255,255,255,0.04);border:1px solid rgba(255,255,255,0.07);border-radius:8px;padding:9px 12px;">
        <div style="display:flex;justify-content:space-between;align-items:flex-start;margin-bottom:3px;">
          <span style="font-size:11px;font-weight:700;color:#e2e8f0;font-family:monospace;">${propId}</span>
          <span style="font-size:10px;font-weight:700;color:${statusColor};">${status.toUpperCase()}</span>
        </div>
        <div style="display:flex;justify-content:space-between;font-size:10px;color:#64748b;">
          <span>${corridor}</span>
          <span>${amtStr} · ${dateStr}</span>
        </div>
      </div>`;
  }).join('');
}

// ═══════════════════════════════════════════════════════════════════════════
// REGIONAL CORRIDOR RESERVOIR GRID
// ═══════════════════════════════════════════════════════════════════════════

async function loadCorridorReservoirGrid() {
  const grid = document.getElementById('govCorridorReservoirGrid');
  if (!grid) return;
  grid.innerHTML = '<div style="text-align:center;padding:40px;color:#94a3b8;font-size:14px;">⏳ Loading corridor reservoirs…</div>';

  try {
    const res = await fetch('/api/v2/corridors?per_page=50', { headers: getGovernorAuthHeaders() });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();

    let corridors = [];
    if (Array.isArray(data))                                  corridors = data;
    else if (Array.isArray(data.data))                        corridors = data.data;
    else if (Array.isArray(data.corridors))                   corridors = data.corridors;
    else if (data.data && Array.isArray(data.data.corridors)) corridors = data.data.corridors;

    if (corridors.length === 0) {
      grid.innerHTML = '<div style="text-align:center;padding:40px;color:#94a3b8;font-size:14px;">No corridors configured.</div>';
      return;
    }

    renderCorridorReservoirGrid(corridors);
  } catch (err) {
    grid.innerHTML = `<div style="text-align:center;padding:40px;color:#f87171;font-size:13px;">⚠ Error loading corridors: ${err.message}</div>`;
  }
}

function renderCorridorReservoirGrid(corridors) {
  const grid = document.getElementById('govCorridorReservoirGrid');
  if (!grid) return;

  // Group by bloc
  const groups = {};
  corridors.forEach(c => {
    const bloc = govGetBloc(c.source_country);
    if (!groups[bloc]) groups[bloc] = [];
    groups[bloc].push(c);
  });

  const orderedBlocs = [...Object.keys(GOV_BLOCS), 'Other'].filter(b => groups[b]?.length > 0);

  grid.innerHTML = orderedBlocs.map(bloc => {
    const cards = groups[bloc].map(c => {
      const id       = c.id || c.code;
      const display  = c.corridor_display || c.code || `${c.source_country} → ${c.target_country}`;
      const status   = (c.status || 'active').toLowerCase();
      const isHalted = status === 'halted' || status === 'suspended';

      const lp      = c.liquidity_position || c.liquidity_snapshot || {};
      const cap     = parseFloat(lp.domestic_available || lp.total_liquidity || 0);
      const drawn   = parseFloat(lp.linked_outstanding || lp.linked || 0);
      const free    = Math.max(0, cap - drawn);
      const hPct    = cap > 0 ? Math.min(100, Math.round(((cap - drawn) / cap) * 100)) : null;
      const currency = lp.asset_code || lp.currency || c.asset_code || '';
      const fmtNum   = n => n ? n.toLocaleString(undefined, { maximumFractionDigits: 0 }) : '—';

      let barColor, statusLabel, badgeBg, badgeColor;
      if (isHalted) {
        barColor = '#6b7280'; statusLabel = 'HALTED'; badgeBg = '#fef2f2'; badgeColor = '#dc2626';
      } else if (hPct === null) {
        barColor = '#475569'; statusLabel = 'NO DATA'; badgeBg = '#f3f4f6'; badgeColor = '#9ca3af';
      } else if (hPct < 10) {
        barColor = '#dc2626'; statusLabel = 'CRITICAL'; badgeBg = '#fef2f2'; badgeColor = '#dc2626';
      } else if (hPct < 30) {
        barColor = '#f59e0b'; statusLabel = 'LOW'; badgeBg = '#fffbeb'; badgeColor = '#d97706';
      } else {
        barColor = '#059669'; statusLabel = 'HEALTHY'; badgeBg = '#f0fdf4'; badgeColor = '#059669';
      }

      const drawdownPct = cap > 0 ? Math.min(100, Math.round((drawn / cap) * 100)) : 0;

      return `
        <div class="gov-corridor-card" style="
          background: white; border: 1px solid #e2e8f0;
          border-radius: 14px; padding: 16px;
          display: flex; flex-direction: column; gap: 12px;
          ${isHalted ? 'opacity:0.75;border-color:#fecaca;' : ''}
        ">
          <!-- Card Header -->
          <div style="display:flex;justify-content:space-between;align-items:flex-start;">
            <div>
              <div style="font-size:13px;font-weight:700;color:#0f172a;font-family:monospace;margin-bottom:3px;">
                ${display}
              </div>
              <div style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:0.5px;">${bloc}</div>
            </div>
            <span style="
              padding:3px 10px;border-radius:20px;font-size:10px;font-weight:700;
              background:${badgeBg};color:${badgeColor};
            ">${statusLabel}</span>
          </div>

          <!-- Headroom % — large display -->
          <div style="text-align:center;">
            <div style="font-size:36px;font-weight:800;color:${isHalted ? '#9ca3af' : barColor};line-height:1;">
              ${hPct !== null ? hPct + '%' : '—'}
            </div>
            <div style="font-size:10px;color:#94a3b8;text-transform:uppercase;letter-spacing:0.5px;margin-top:2px;">headroom</div>
          </div>

          <!-- Bar -->
          ${cap > 0 ? `
          <div style="position:relative;height:8px;background:#f1f5f9;border-radius:4px;overflow:hidden;">
            <div style="position:absolute;top:0;left:0;bottom:0;width:${drawdownPct}%;background:${barColor};border-radius:4px;transition:width 0.5s ease;"></div>
          </div>` : ''}

          <!-- Cap / Free stats -->
          <div style="display:grid;grid-template-columns:1fr 1fr;gap:8px;">
            <div style="background:#f8fafc;border-radius:8px;padding:8px 10px;">
              <div style="font-size:9px;color:#94a3b8;text-transform:uppercase;margin-bottom:2px;">Cap</div>
              <div style="font-size:12px;font-weight:700;color:#0f172a;">${cap > 0 ? currency + ' ' + fmtNum(cap) : '—'}</div>
            </div>
            <div style="background:#f0fdf4;border-radius:8px;padding:8px 10px;border:1px solid #bbf7d0;">
              <div style="font-size:9px;color:#94a3b8;text-transform:uppercase;margin-bottom:2px;">Free</div>
              <div style="font-size:12px;font-weight:700;color:#059669;">${cap > 0 ? currency + ' ' + fmtNum(free) : '—'}</div>
            </div>
          </div>

          <!-- Action Buttons -->
          <div style="display:flex;gap:6px;">
            <button onclick="govSelectedCorridorId='${id}';govSelectedCorridorLabel='${display.replace(/'/g,"\\'")}';govAdjustDailyCap()" style="
              flex:1;padding:8px 0;font-size:11px;font-weight:600;cursor:pointer;
              background:#f8fafc;color:#475569;border:1px solid #e2e8f0;border-radius:8px;
            " onmouseover="this.style.background='#f1f5f9'" onmouseout="this.style.background='#f8fafc'">
              📊 Adjust Cap
            </button>
            <button onclick="govSelectedCorridorId='${id}';govSelectedCorridorLabel='${display.replace(/'/g,"\\'")}';govHaltCorridor()" style="
              flex:1;padding:8px 0;font-size:11px;font-weight:600;cursor:pointer;
              background:${isHalted ? '#fef2f2' : '#fff7f7'};
              color:${isHalted ? '#dc2626' : '#ef4444'};
              border:1px solid ${isHalted ? '#fecaca' : '#fee2e2'};border-radius:8px;
            " onmouseover="this.style.background='#fef2f2'" onmouseout="this.style.background='${isHalted ? '#fef2f2' : '#fff7f7'}'">
              ⚡ ${isHalted ? 'Halted' : 'Halt'}
            </button>
          </div>
        </div>`;
    }).join('');

    return `
      <div style="margin-bottom:20px;">
        <div style="
          font-size:10px;font-weight:700;color:#64748b;
          text-transform:uppercase;letter-spacing:1.5px;margin-bottom:10px;
          display:flex;align-items:center;gap:8px;
        ">
          <span>${bloc}</span>
          <span style="font-size:11px;color:#cbd5e1;font-weight:400;">(${groups[bloc].length} corridor${groups[bloc].length !== 1 ? 's' : ''})</span>
        </div>
        <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:12px;">
          ${cards}
        </div>
      </div>`;
  }).join('');
}

// ═══════════════════════════════════════════════════════════════════════════
// GOVERNANCE SIGNATURES REQUIRED
// ═══════════════════════════════════════════════════════════════════════════

async function loadGovernanceSignatures() {
  const panel = document.getElementById('govSignaturesPanel');
  if (!panel) return;
  panel.innerHTML = '<div style="text-align:center;padding:40px;color:#94a3b8;font-size:14px;">⏳ Loading governance proposals…</div>';

  try {
    const res = await fetch('/api/v2/governance/proposals?status=pending&per_page=20', {
      headers: getGovernorAuthHeaders()
    });
    if (!res.ok) throw new Error(`HTTP ${res.status}`);
    const data = await res.json();

    let proposals = [];
    if (Array.isArray(data))                                  proposals = data;
    else if (Array.isArray(data.data))                        proposals = data.data;
    else if (data.data && Array.isArray(data.data.proposals)) proposals = data.data.proposals;
    else if (Array.isArray(data.proposals))                   proposals = data.proposals;

    const count = document.getElementById('govPendingProposalCount');
    if (count) count.textContent = proposals.length;

    renderGovernanceSignatures(proposals);
  } catch (err) {
    panel.innerHTML = `<div style="text-align:center;padding:40px;color:#f87171;font-size:13px;">⚠ ${err.message}</div>`;
  }
}

function renderGovernanceSignatures(proposals) {
  const panel = document.getElementById('govSignaturesPanel');
  if (!panel) return;

  if (proposals.length === 0) {
    panel.innerHTML = `
      <div style="text-align:center;padding:40px;">
        <div style="font-size:32px;margin-bottom:10px;">✓</div>
        <div style="font-size:14px;font-weight:600;color:#374151;margin-bottom:4px;">No pending governance proposals</div>
        <div style="font-size:12px;color:#94a3b8;">All corridor parameter proposals have been resolved.</div>
      </div>`;
    return;
  }

  const typeLabel = t => {
    if (!t) return 'Proposal';
    const map = {
      'bulk_allotment': 'Bulk Allotment',
      'cap_change':     'Cap Change',
      'corridor_cap_change': 'Cap Change',
      'halt':           'Corridor Halt',
      'rate_adjustment':'Rate Adjustment',
      'deactivate':     'Deactivation',
    };
    return map[t.toLowerCase()] || t.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
  };

  const typeBadge = t => {
    const label = typeLabel(t);
    const tl = (t || '').toLowerCase();
    if (tl.includes('halt') || tl.includes('deactivate')) return { bg:'#fef2f2',color:'#dc2626',border:'#fecaca' };
    if (tl.includes('cap')) return { bg:'#fffbeb',color:'#d97706',border:'#fde68a' };
    return { bg:'#eff6ff',color:'#2563eb',border:'#bfdbfe' };
  };

  panel.innerHTML = `
    <div style="overflow-x:auto;">
      <table style="width:100%;border-collapse:collapse;font-size:13px;">
        <thead>
          <tr style="background:#f8fafc;border-bottom:2px solid #e2e8f0;">
            <th style="padding:10px 14px;text-align:left;font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;">Proposal</th>
            <th style="padding:10px 14px;text-align:left;font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;">Corridor</th>
            <th style="padding:10px 14px;text-align:left;font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;">Type</th>
            <th style="padding:10px 14px;text-align:left;font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;">Multi-Sig</th>
            <th style="padding:10px 14px;text-align:left;font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;">Submitted</th>
            <th style="padding:10px 14px;text-align:left;font-size:10px;font-weight:700;color:#64748b;text-transform:uppercase;letter-spacing:0.5px;"></th>
          </tr>
        </thead>
        <tbody>
          ${proposals.map(p => {
            const propId   = p.proposal_id || p.title || ('PROP-' + (p.id || '').toString().slice(0,8).toUpperCase());
            const corridor = p.corridor || p.corridor_name || '—';
            const pType    = p.type || p.category || '';
            const badge    = typeBadge(pType);
            const current  = parseInt(p.current_signatures || p.votes_count || 0);
            const required = parseInt(p.required_signatures || p.votes_required || 2);
            const ts       = p.created_at || p.submitted_at || '';
            const dateStr  = ts ? new Date(ts).toLocaleDateString(undefined, { month:'short', day:'numeric', year:'numeric' }) : '—';
            const sigPct   = required > 0 ? Math.round((current / required) * 100) : 0;
            const sigColor = current >= required ? '#059669' : current > 0 ? '#d97706' : '#94a3b8';

            return `
              <tr class="gov-proposal-row" style="border-bottom:1px solid #f1f5f9;cursor:pointer;" onclick="govReviewProposal('${p.id || propId}')">
                <td style="padding:12px 14px;">
                  <div style="font-family:monospace;font-size:12px;font-weight:700;color:#1e40af;">${propId}</div>
                </td>
                <td style="padding:12px 14px;">
                  <div style="font-size:12px;color:#374151;">${corridor}</div>
                </td>
                <td style="padding:12px 14px;">
                  <span style="
                    padding:3px 10px;border-radius:10px;font-size:10px;font-weight:700;
                    background:${badge.bg};color:${badge.color};border:1px solid ${badge.border};
                  ">${typeLabel(pType)}</span>
                </td>
                <td style="padding:12px 14px;">
                  <div style="display:flex;align-items:center;gap:8px;">
                    <div style="flex:1;background:#e2e8f0;border-radius:4px;height:6px;overflow:hidden;min-width:50px;">
                      <div style="height:100%;background:${sigColor};width:${sigPct}%;border-radius:4px;transition:width 0.3s;"></div>
                    </div>
                    <span style="font-size:11px;font-weight:700;color:${sigColor};white-space:nowrap;">${current} / ${required}</span>
                  </div>
                </td>
                <td style="padding:12px 14px;">
                  <div style="font-size:11px;color:#94a3b8;">${dateStr}</div>
                </td>
                <td style="padding:12px 14px;">
                  <button onclick="event.stopPropagation();govSignProposal('${p.id || propId}')" style="
                    background:#1e4d7b;color:white;border:none;border-radius:8px;
                    padding:6px 14px;font-size:11px;font-weight:700;cursor:pointer;white-space:nowrap;
                  " onmouseover="this.style.background='#1a3a5c'" onmouseout="this.style.background='#1e4d7b'">
                    ✍ Sign
                  </button>
                </td>
              </tr>`;
          }).join('')}
        </tbody>
      </table>
    </div>`;
}

function govReviewProposal(proposalId) {
  // Expand row or show detail — placeholder for full implementation
  console.log('[MacroConsole] Review proposal:', proposalId);
}

async function govSignProposal(proposalId) {
  if (!confirm(`Sign governance proposal ${proposalId}?\n\nThis vote will be permanently recorded in the audit trail.`)) return;
  try {
    const res = await fetch(`/api/v2/governance/proposals/${proposalId}/vote`, {
      method:  'POST',
      headers: getGovernorAuthHeaders(),
      body:    JSON.stringify({ vote: 'approve', role: 'governor' })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
    alert(`✓ Signature recorded for proposal ${proposalId}.`);
    loadGovernanceSignatures();
  } catch (err) {
    alert(`Error signing proposal: ${err.message}`);
  }
}

// ═══════════════════════════════════════════════════════════════════════════
// CORRIDOR INTERVENTIONS (Halt / Adjust Cap / Bulk Allotment)
// ═══════════════════════════════════════════════════════════════════════════

// ── Custom dialog engine ────────────────────────────────────────────────────
let _govDialogCb = null;

function govShowDialog({ icon, iconBg, iconBorder, title, subtitle, body, label, placeholder, confirmLabel, confirmBg, hasInput = true, onConfirm }) {
  const iconBox = document.getElementById('govDialogIconBox');
  iconBox.textContent = icon || '';
  iconBox.style.background = iconBg || 'rgba(13,148,136,0.2)';
  iconBox.style.border = `1px solid ${iconBorder || 'rgba(13,148,136,0.3)'}`;
  document.getElementById('govDialogTitle').textContent = title || '';
  document.getElementById('govDialogSubtitle').textContent = subtitle || '';
  document.getElementById('govDialogBody').innerHTML = body || '';
  document.getElementById('govDialogBody').style.display = body ? 'block' : 'none';
  document.getElementById('govDialogLabel').textContent = label || '';
  const inp = document.getElementById('govDialogInput');
  inp.placeholder = placeholder || '';
  inp.value = '';
  document.getElementById('govDialogInputWrap').style.display = hasInput ? 'block' : 'none';
  const btn = document.getElementById('govDialogConfirmBtn');
  btn.textContent = confirmLabel || 'Confirm';
  btn.style.background = confirmBg || 'linear-gradient(135deg,#0d9488,#0d6e6e)';
  _govDialogCb = onConfirm;
  document.getElementById('govCustomDialog').style.display = 'flex';
  if (hasInput) setTimeout(() => inp.focus(), 60);
}

function govHideDialog() {
  document.getElementById('govCustomDialog').style.display = 'none';
  _govDialogCb = null;
}

function govConfirmDialog() {
  const val = document.getElementById('govDialogInput').value.trim();
  if (_govDialogCb) _govDialogCb(val);
}

function govShowToast(message, type = 'info') {
  const toast = document.getElementById('govToast');
  const styles = {
    success: { bg: '#0d9488', color: '#fff', border: 'none' },
    error:   { bg: '#dc2626', color: '#fff', border: 'none' },
    warn:    { bg: '#1e293b', color: '#fbbf24', border: '1px solid rgba(251,191,36,0.4)' },
    info:    { bg: '#1e293b', color: '#e2e8f0', border: '1px solid rgba(255,255,255,0.1)' },
  };
  const s = styles[type] || styles.info;
  toast.style.background = s.bg;
  toast.style.color = s.color;
  toast.style.border = s.border;
  toast.textContent = message;
  toast.style.display = 'block';
  clearTimeout(toast._timer);
  toast._timer = setTimeout(() => { toast.style.display = 'none'; }, 4000);
}

// ── Corridor Interventions ──────────────────────────────────────────────────
function govHaltCorridor() {
  if (!govSelectedCorridorId) {
    govShowToast('Select a corridor before halting.', 'warn');
    return;
  }
  govShowDialog({
    icon: '⚡', iconBg: 'rgba(239,68,68,0.15)', iconBorder: 'rgba(239,68,68,0.3)',
    title: 'Halt Corridor',
    subtitle: govSelectedCorridorLabel,
    body: `<span style="color:#fca5a5;">This will immediately suspend <strong style="color:#fde8e8;">${govSelectedCorridorLabel}</strong>.<br>No further minting or settlement will be permitted.<br>Type <code style="background:rgba(239,68,68,0.2);padding:1px 6px;border-radius:4px;color:#fca5a5;">HALT</code> to confirm.</span>`,
    label: 'Confirmation code',
    placeholder: 'Type HALT to confirm',
    confirmLabel: '⚡ Halt Corridor',
    confirmBg: 'linear-gradient(135deg,#7f1d1d,#b91c1c)',
    hasInput: true,
    onConfirm: async (code) => {
      if (code.toUpperCase() !== 'HALT') {
        govShowToast('Halt cancelled — confirmation code did not match.', 'warn');
        govHideDialog();
        return;
      }
      govHideDialog();
      try {
        const res = await fetch(`/api/v2/corridors/${govSelectedCorridorId}/halt`, {
          method: 'POST',
          headers: getGovernorAuthHeaders(),
          body: JSON.stringify({ corridor_id: govSelectedCorridorId, initiated_by: 'governor', reason: 'Governor halt via Macro-Corridor Console' })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
        govShowToast(`⚡ ${govSelectedCorridorLabel} halted — settlement suspended. Audit log recorded.`, 'success');
        loadCorridorReservoirGrid();
        loadNetworkStatus();
      } catch (err) {
        govShowToast(`Halt error: ${err.message}`, 'error');
      }
    }
  });
}

function govAdjustDailyCap() {
  if (!govSelectedCorridorId) {
    govShowToast('Select a corridor first.', 'warn');
    return;
  }
  govShowDialog({
    icon: '📊', iconBg: 'rgba(13,148,136,0.15)', iconBorder: 'rgba(13,148,136,0.3)',
    title: 'Adjust Daily Cap',
    subtitle: govSelectedCorridorLabel,
    label: 'New daily cap amount',
    placeholder: 'e.g. 50000000',
    confirmLabel: 'Queue Proposal',
    confirmBg: 'linear-gradient(135deg,#0d9488,#0d6e6e)',
    hasInput: true,
    onConfirm: (val) => {
      const amt = parseFloat(val.replace(/,/g, ''));
      if (!val || isNaN(amt) || amt <= 0) {
        govShowToast('Invalid amount — enter a positive number.', 'error');
        return;
      }
      govHideDialog();
      govShowToast(`Cap adjustment proposal queued: ${govSelectedCorridorLabel} → ${amt.toLocaleString()}`, 'success');
    }
  });
}

async function govCreateBulkAllotment(amount) {
  if (!govSelectedCorridorId) {
    govShowToast('Select a corridor before creating a bulk allotment.', 'warn');
    return;
  }
  const year         = new Date().getFullYear();
  const corridorCode = govSelectedCorridorLabel.replace(/\s*→\s*/g, '-').replace(/\s+/g, '');
  const proposalRef  = `ALOT-${year}-${corridorCode}-001`;
  const amtFormatted = amount.toLocaleString();

  govShowDialog({
    icon: '💧', iconBg: 'rgba(13,148,136,0.15)', iconBorder: 'rgba(13,148,136,0.3)',
    title: `Inject ${amtFormatted}`,
    subtitle: govSelectedCorridorLabel,
    body: `<div style="color:#94a3b8;">
      <div style="margin-bottom:6px;">Proposal: <span style="color:#e2e8f0;font-family:monospace;">${proposalRef}</span></div>
      <div>This creates a governance proposal requiring multi-sig approval before funds are injected.</div>
    </div>`,
    hasInput: false,
    confirmLabel: 'Submit Proposal',
    confirmBg: 'linear-gradient(135deg,#0d9488,#0d6e6e)',
    onConfirm: async () => {
      govHideDialog();
      try {
        const res = await fetch('/api/v2/governance/proposals', {
          method:  'POST',
          headers: getGovernorAuthHeaders(),
          body: JSON.stringify({
            proposal: {
              type: 'bulk_allotment', category: 'bulk_allotment',
              title: proposalRef, corridor: govSelectedCorridorLabel,
              corridor_id: govSelectedCorridorId, new_cap: amount.toString(),
              effective_date: new Date(Date.now() + 86400000).toISOString().split('T')[0],
              justification: `Sovereign liquidity injection — ${amtFormatted} for ${govSelectedCorridorLabel}`,
              rationale: 'Governor-initiated bulk allotment from Macro-Corridor Console',
            }
          })
        });
        const data = await res.json();
        if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);
        const propId = data?.data?.proposal_id || data?.data?.id || proposalRef;
        govShowToast(`✓ Proposal ${propId} submitted — pending multi-sig approval.`, 'success');
        loadGovRecentEvents();
        loadGovernanceSignatures();
      } catch (err) {
        govShowToast(`Error: ${err.message}`, 'error');
      }
    }
  });
}

// ── Keyboard shortcut ───────────────────────────────────────────────────────
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    if (document.getElementById('govCustomDialog')?.style.display === 'flex') {
      govHideDialog();
    } else if (document.getElementById('governorDeskModalOverlay')?.style.display === 'flex') {
      hideGovernorDeskModal();
    }
  }
});
</script>
