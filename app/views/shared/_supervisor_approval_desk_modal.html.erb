const GATE_STATUS_CONFIG = {
  passed:  { icon: '✅', badge: 'Passed',       bg: '#d1fae5', color: '#065f46', border: '#a7f3d0' },
  failed:  { icon: '❌', badge: 'Failed',        bg: '#fee2e2', color: '#991b1b', border: '#fca5a5' },
  pending: { icon: '⏳', badge: 'Pending',       bg: '#f3f4f6', color: '#6b7280', border: '#e5e7eb' },
  skipped: { icon: '⊘',  badge: 'N/A',           bg: '#f3f4f6', color: '#9ca3af', border: '#e5e7eb' },
  warning: { icon: '⚠️', badge: 'Review',        bg: '#fef3c7', color: '#92400e', border: '#fde68a' },
};

function populateReviewChecks(claim) {
  const rawGates   = claim.gating_conditions || claim.eligibility?.gates || {};
  const compStatus  = resolveComplianceStatus(claim);
  const claimStatus = claim.status || 'pending';

  // Gating conditions are only meaningful AFTER the supervisor has approved the claim.
  // For pre-approval states (submitted, pre_cleared, under_review, manual_review, pending),
  // the gates have never been evaluated — they are all PENDING, not failed.
  const PRE_APPROVAL_STATUSES = ['submitted','under_review','pre_cleared','manual_review','pending','pending_clarification','draft'];
  const isPreApproval = PRE_APPROVAL_STATUSES.includes(claimStatus);

  // Real gate data: only trust gating_conditions that came from the backend service
  // (non-empty object). If empty {}, gates have never been evaluated.
  const hasRealGates = Object.keys(rawGates).length > 0;

  // For pre-approval claims, synthesise compliance sub-check info for display
  // but force all gate-level passed values to null (pending) so nothing shows as Failed.
  const syntheticGates = synthesiseGates(claim, compStatus, claimStatus, isPreApproval);
  const effectiveGates = hasRealGates ? rawGates : syntheticGates;

  let allPassed  = true;
  let anyFailed  = false;

  // Only count real failures — i.e. from the backend service, not synthetic pre-approval state
  const realFailures = hasRealGates && !isPreApproval;

  GATE_DEFINITIONS.forEach(def => {
    const gate = effectiveGates[def.key] || {};

    // Determine display state:
    // - Pre-approval + no real gates: always show as pending (never failed)
    // - Post-approval with real gates: show actual pass/fail from service
    let state;
    if (!realFailures) {
      // Pre-approval or no gate data: everything is pending
      state = gate.passed === true ? 'passed' : 'pending';
    } else {
      state = gate.passed === true  ? 'passed'
            : gate.passed === false ? 'failed'
            : 'pending';
    }

    if (state !== 'passed') allPassed = false;
    if (state === 'failed')  anyFailed = true;

    const conf = GATE_STATUS_CONFIG[state];

    // Update icon + badge
    const iconEl  = document.getElementById(`gateIcon_${def.key}`);
    const badgeEl = document.getElementById(`gateBadge_${def.key}`);
    const rowEl   = document.getElementById(`gateRow_${def.key}`);
    if (iconEl)  iconEl.textContent  = conf.icon;
    if (badgeEl) {
      badgeEl.textContent       = conf.badge;
      badgeEl.style.background  = conf.bg;
      badgeEl.style.color       = conf.color;
    }
    if (rowEl) rowEl.style.borderColor = conf.border;

    // Populate sub-check detail text
    const detailEl = document.getElementById(`gateDetailText_${def.key}`);
    if (detailEl) {
      const details = gate.details || {};

      // Pre-approval: show informational note instead of pass/fail sub-checks
      if (isPreApproval && !hasRealGates && def.key === 'supervisor_approval') {
        detailEl.innerHTML = '<span style="color:#6b7280;">⏳ Awaiting supervisor approval — evaluation will begin after approval</span>';
      } else if (isPreApproval && !hasRealGates) {
        detailEl.innerHTML = '<span style="color:#9ca3af;">Will be evaluated automatically after supervisor approves</span>';
      } else {
        const lines = def.subChecks
          .filter(sc => !sc.infoOnly || details[sc.field] !== undefined)
          .map(sc => {
            const raw = details[sc.field];
            if (sc.infoOnly) {
              return raw === false
                ? `<span style="color:#9ca3af;">⊘ ${sc.label}: Not required</span>`
                : `<span style="color:#059669;">● ${sc.label}</span>`;
            }
            const passed = sc.invert ? !raw : !!raw;
            const tick   = passed ? '✓' : '✗';
            const color  = passed ? '#059669' : '#dc2626';
            const extra  = sc.format ? ` — ${sc.format(raw, details)}` : '';
            return `<span style="color:${color};">${tick} ${sc.label}${extra}</span>`;
          });
        detailEl.innerHTML = lines.join('<br>') || '<span style="color:#9ca3af;">No detail available</span>';
      }
    }
  });

  // Overall badge
  const overallBadge = document.getElementById('gatingOverallBadge');
  if (overallBadge) {
    if (claimStatus === 'issuance_eligible' || allPassed) {
      overallBadge.textContent      = 'ALL PASSED';
      overallBadge.style.background = '#d1fae5';
      overallBadge.style.color      = '#065f46';
    } else if (anyFailed) {
      overallBadge.textContent      = 'GATES FAILED';
      overallBadge.style.background = '#fee2e2';
      overallBadge.style.color      = '#991b1b';
    } else if (isPreApproval && !hasRealGates) {
      overallBadge.textContent      = 'PENDING APPROVAL';
      overallBadge.style.background = '#fef3c7';
      overallBadge.style.color      = '#92400e';
    } else {
      overallBadge.textContent      = 'EVALUATING';
      overallBadge.style.background = '#f3f4f6';
      overallBadge.style.color      = '#6b7280';
    }
  }

  // Block Approve button ONLY when there are real service-returned gate failures.
  // Pre-approval pending state must NEVER block the Approve button.
  const warning = document.getElementById('blockedClaimWarning');
  const btn     = document.getElementById('btnApprove');
  const shouldBlock = anyFailed && realFailures;
  if (warning) warning.style.display = shouldBlock ? 'block' : 'none';
  if (btn) {
    btn.disabled      = shouldBlock;
    btn.style.opacity = shouldBlock ? '0.5' : '1';
  }

  // Lifecycle tracking table
  renderLifecycleTable(claim, effectiveGates);
  updateApprovalUpdates(claim);
}

// Synthesise gate states from existing compliance fields (no gating_conditions yet)
// isPreApproval: when true, gates that require approval are shown as null (pending), never false
function synthesiseGates(claim, compStatus, claimStatus, isPreApproval) {
  const checks    = claim.compliance_checks || {};
  const docStatus = checks.document_status || (compStatus === 'pre_cleared' ? 'validated' : 'pending');
  const amlStatus = checks.aml_status      || (compStatus === 'manual_review' ? 'flagged' : compStatus === 'pre_cleared' ? 'clear' : 'pending');
  const limitOk   = checks.limit_status !== 'exceeded';
  const benefOk   = checks.beneficiary_status === 'verified' || compStatus === 'pre_cleared';
  const isApproved = ['approved','issuance_eligible'].includes(claimStatus);

  // Gate 1: supervisor_approval
  // Pre-approval → null (pending). Post-approval → true. Never false via synthesis.
  const gate1Passed = isPreApproval ? null : (isApproved ? true : null);

  // Gate 2: compliance
  // Show real compliance info if we have it, but only mark failed if post-approval
  const compPassed = compStatus === 'pre_cleared' && docStatus === 'validated' && amlStatus === 'clear';
  const gate2Passed = isPreApproval
    ? (compPassed ? true : null)   // pre-approval: show green if already pre-cleared, else pending
    : compPassed;

  // Gate 3: corridor limits — safe to show even pre-approval (no approval required to check)
  const gate3Passed = limitOk ? true : (isPreApproval ? null : false);

  // Gate 4: liquidity — only confirmed after LiquidityLockJob runs post-approval
  // Pre-approval → always pending (null)
  const gate4Passed = isPreApproval ? null : (isApproved || compStatus === 'pre_cleared' ? true : null);

  // Gate 5: governance — auto-passes for standard claims regardless of approval state
  const gate5Passed = true;

  return {
    supervisor_approval: {
      passed:  gate1Passed,
      details: { status_ok: isApproved, four_eyes_ok: isApproved, audit_trail_ok: isApproved }
    },
    compliance: {
      passed:  gate2Passed,
      details: {
        compliance_status: compStatus,
        aml_status:        amlStatus,
        sanctions_ok:      amlStatus !== 'flagged',
        risk_score:        claim.aml_risk_score || claim.risk_score || 0,
        documents_ok:      ['validated','verified'].includes(docStatus)
      }
    },
    corridor_limits: {
      passed:  gate3Passed,
      details: { limit_ok: limitOk, suspended: false, velocity_ok: true }
    },
    liquidity: {
      passed:  gate4Passed,
      details: {
        backing_asset_exists:    isApproved,
        reserve_pool_sufficient: isApproved,
        dlt_lock_confirmed:      isApproved
      }
    },
    governance: {
      passed:  gate5Passed,
      details: { required: false, reason: 'Below large-value threshold' }
    }
  };
}

// ── Lifecycle tracking table ────────────────────────────────────────────────
const LIFECYCLE_STAGES = [
  { key: 'submitted',         label: 'Submitted',                icon: '📤', gateKey: null },
  { key: 'under_review',      label: 'Under Review',             icon: '🔍', gateKey: null },
  { key: 'pre_cleared',       label: 'Compliance Pre-Cleared',   icon: '✅', gateKey: 'compliance' },
  { key: 'approved',          label: 'Supervisor Approved',      icon: '🧑‍⚖️', gateKey: 'supervisor_approval' },
  { key: 'issuance_eligible', label: 'Issuance-Eligible',        icon: '🏦', gateKey: null },
  { key: 'locked',            label: 'Liquidity Locked',         icon: '🔒', gateKey: 'liquidity' },
];

const STATUS_ORDER = LIFECYCLE_STAGES.map(s => s.key);

function claimStageIndex(status) {
  return STATUS_ORDER.indexOf(status) ?? -1;
}

function renderLifecycleTable(claim, gates) {
  const section  = document.getElementById('lifecycleTrackingSection');
  const tbody    = document.getElementById('lifecycleTableBody');
  if (!section || !tbody) return;

  section.style.display = 'block';

  const currentIdx = claimStageIndex(claim.status || '');

  const rows = LIFECYCLE_STAGES.map((stage, idx) => {
    const isReached  = idx <= currentIdx;
    const isCurrent  = idx === currentIdx;
    const gateResult = stage.gateKey ? (gates[stage.gateKey] || {}) : null;
    const gatePassed = gateResult ? gateResult.passed : isReached;

    // Status column
    let statusHtml;
    if (isCurrent) {
      statusHtml = `<span style="background:#dbeafe;color:#1d4ed8;padding:2px 8px;border-radius:8px;font-size:10px;font-weight:700;">CURRENT</span>`;
    } else if (claim.status === 'issuance_eligible' && stage.key === 'issuance_eligible') {
      statusHtml = `<span style="background:#d1fae5;color:#065f46;padding:2px 8px;border-radius:8px;font-size:10px;font-weight:700;">✓ REACHED</span>`;
    } else if (isReached) {
      statusHtml = `<span style="background:#f0fdf4;color:#16a34a;padding:2px 8px;border-radius:8px;font-size:10px;font-weight:600;">✓ Done</span>`;
    } else {
      statusHtml = `<span style="color:#d1d5db;font-size:11px;">—</span>`;
    }

    // Gating condition column
    let conditionHtml = '—';
    if (stage.gateKey && gateResult && typeof gateResult.passed === 'boolean') {
      conditionHtml = gateResult.passed
        ? `<span style="color:#059669;font-size:11px;">✓ ${(gateResult.label || stage.gateKey)}</span>`
        : `<span style="color:#dc2626;font-size:11px;">✗ ${(gateResult.label || stage.gateKey)}</span>`;
    } else if (stage.gateKey && !isReached) {
      conditionHtml = `<span style="color:#d1d5db;font-size:11px;">Not yet evaluated</span>`;
    }

    // Satisfied column
    let satisfiedHtml;
    if (!isReached && !isCurrent) {
      satisfiedHtml = `<span style="color:#d1d5db;">—</span>`;
    } else if (gatePassed === true || (isReached && !stage.gateKey)) {
      satisfiedHtml = `<span style="color:#059669;font-weight:600;">✓ Yes</span>`;
    } else if (gatePassed === false) {
      satisfiedHtml = `<span style="color:#dc2626;font-weight:600;">✗ No</span>`;
    } else {
      satisfiedHtml = `<span style="color:#f59e0b;font-weight:600;">⟳ Pending</span>`;
    }

    const rowBg = isCurrent ? '#eff6ff' : (claim.status === 'issuance_eligible' && stage.key === 'issuance_eligible') ? '#f0fdf4' : '';

    return `
      <tr style="border-bottom: 1px solid #f3f4f6; ${rowBg ? `background:${rowBg};` : ''}">
        <td style="padding: 9px 12px; font-size: 12px; font-weight: ${isCurrent ? '600' : '400'}; color: ${isReached ? '#374151' : '#9ca3af'};">
          ${stage.icon} ${stage.label}
        </td>
        <td style="padding: 9px 12px;">${statusHtml}</td>
        <td style="padding: 9px 12px;">${conditionHtml}</td>
        <td style="padding: 9px 12px;">${satisfiedHtml}</td>
      </tr>
    `;
  });

  tbody.innerHTML = rows.join('');
}

function updateApprovalUpdates(claim) {
  const el = document.getElementById('approvalUpdates');
  const issuanceEl = document.getElementById('issuanceEligibleUpdate');
  const cs = resolveComplianceStatus(claim);
  const status = claim.status || '';

  // Already issuance-eligible
  if (status === 'issuance_eligible') {
    el.innerHTML = '<div>✓ status → approved</div><div>✓ liquidity_lock created</div><div>✓ issuance_authorization created</div>';
    el.style.background = '#f0fdf4'; el.style.color = '#166534'; el.style.borderColor = '#bbf7d0';
    if (issuanceEl) issuanceEl.style.display = 'block';
    return;
  }

  if (issuanceEl) issuanceEl.style.display = 'none';

  if (cs === 'pre_cleared') {
    el.innerHTML = `
      <div>⟳ Awaiting supervisor approval</div>
      <div style="font-size:11px;color:#6b7280;margin-top:4px;">On approval, the system will automatically evaluate all 5 gating conditions.</div>
      <div style="font-size:11px;color:#059669;margin-top:4px;">✓ Compliance pre-cleared — ready for supervisor decision</div>
    `;
    el.style.background = '#f9fafb'; el.style.color = '#374151'; el.style.borderColor = '#e5e7eb';
  } else if (cs === 'manual_review') {
    el.innerHTML = '<div>⚠ Requires manual compliance review</div><div>○ liquidity_lock pending</div>';
    el.style.background = '#fffbeb'; el.style.color = '#92400e'; el.style.borderColor = '#fde68a';
  } else {
    el.innerHTML = '<div>○ status → pending approval</div><div>○ liquidity_lock not created</div>';
    el.style.background = '#f9fafb'; el.style.color = '#6b7280'; el.style.borderColor = '#e5e7eb';
  }
}

// ── Post-approval result modal (replaces browser alert) ─────────────────────
// Shows either an all-pass "Issuance-Eligible" celebration, a gates-failed
// breakdown with the exact failure reason per gate, or an error state.
function showApprovalResultModal({ issuanceEligible, reference, failedConditions = [], gates = {}, error = false, errorMessage = '' }) {
  const existing = document.getElementById('approvalResultOverlay');
  if (existing) existing.remove();

  let headerBg, headerIcon, headerTitle, headerSub, bodyHtml, footerBtnLabel, footerBtnColor;

  if (error) {
    headerBg      = 'linear-gradient(135deg,#991b1b,#dc2626)';
    headerIcon    = '⚠';
    headerTitle   = 'Approval Failed';
    headerSub     = 'An unexpected error occurred. The claim was not changed.';
    bodyHtml      = `
      <div style="padding:20px 24px;background:#fef2f2;border-bottom:1px solid #fecaca;">
        <div style="font-size:13px;color:#991b1b;font-family:monospace;line-height:1.5;">${errorMessage}</div>
      </div>`;
    footerBtnLabel = 'Close';
    footerBtnColor = '#dc2626';

  } else if (issuanceEligible) {
    headerBg      = 'linear-gradient(135deg,#065f46,#059669)';
    headerIcon    = '🏦';
    headerTitle   = 'Claim Approved & Issuance-Eligible';
    headerSub     = `${reference} has passed all 5 gating conditions and is ready for CVIB minting.`;
    const gateRows = ['supervisor_approval','compliance','corridor_limits','liquidity','governance']
      .map(key => {
        const g = gates[key] || {};
        return `<div style="display:flex;align-items:center;justify-content:space-between;padding:9px 0;border-bottom:1px solid #f0fdf4;">
          <span style="font-size:13px;color:#1d1d1f;">${g.label || key}</span>
          <span style="background:#d1fae5;color:#065f46;padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;">✓ Passed</span>
        </div>`;
      }).join('');
    bodyHtml = `
      <div style="padding:20px 24px 4px;">
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;">Gate Results</div>
        ${gateRows}
        <div style="margin-top:16px;padding:12px 14px;background:#f0fdf4;border:1px solid #bbf7d0;border-radius:10px;font-size:12px;color:#166534;line-height:1.6;">
          ✓ IssuanceAuthorization created<br>
          ✓ Liquidity lock confirmed<br>
          ✓ Ready for Qt6 CVIB minting
        </div>
      </div>`;
    footerBtnLabel = 'Done';
    footerBtnColor = '#059669';

  } else {
    // Approved but gates pending — show which ones failed and why
    headerBg   = 'linear-gradient(135deg,#92400e,#d97706)';
    headerIcon = '✅';
    headerTitle = 'Claim Approved — Eligibility Pending';
    headerSub   = `${reference} is approved. One or more issuance gates need resolution.`;

    const GATE_ORDER = ['supervisor_approval','compliance','corridor_limits','liquidity','governance'];
    const gateRows = GATE_ORDER.map(key => {
      const g = gates[key];
      if (!g) return '';
      const passed   = g.passed === true;
      const badgeBg  = passed ? '#d1fae5' : '#fee2e2';
      const badgeCol = passed ? '#065f46' : '#991b1b';
      const badgeTxt = passed ? '✓ Passed' : '✗ Failed';
      const label    = g.label || key;

      // Build human-readable failure reason from gate details
      let reason = '';
      if (!passed && g.details) {
        const d = g.details;
        if (key === 'compliance') {
          const parts = [];
          if (!['pre_cleared','comp_pre_cleared','cleared','comp_cleared','approved'].includes(d.compliance_status))
            parts.push(`Status: ${d.compliance_status || 'not cleared'}`);
          if (d.aml_status && !['clear','ok','passed'].includes(d.aml_status))
            parts.push(`AML: ${d.aml_status}`);
          if (d.risk_score >= 50)
            parts.push(`Risk score: ${d.risk_score}`);
          if (d.documents_ok === false)
            parts.push('Documents not validated');
          if (d.sanctions_ok === false)
            parts.push('Sanctions flagged');
          reason = parts.join(' · ') || 'AML check pending — run AML screening to clear';
        } else if (key === 'corridor_limits') {
          const parts = [];
          if (d.suspended)    parts.push('Corridor suspended');
          if (!d.limit_ok)    parts.push(`Daily limit exceeded`);
          if (!d.per_tx_ok)   parts.push(`Per-transaction limit exceeded`);
          if (!d.velocity_ok) parts.push('Velocity limit exceeded');
          reason = parts.join(' · ');
        } else if (key === 'liquidity') {
          const parts = [];
          if (!d.backing_asset_exists)    parts.push('No backing asset');
          if (!d.reserve_pool_sufficient) parts.push('Reserve pool insufficient');
          if (!d.dlt_lock_confirmed)      parts.push('DLT lock pending');
          reason = parts.join(' · ');
        } else if (key === 'supervisor_approval') {
          const parts = [];
          if (!d.status_ok)       parts.push(`Status: ${d.claim_status}`);
          if (!d.four_eyes_ok)    parts.push('4-eyes not satisfied');
          if (!d.audit_trail_ok)  parts.push('Audit trail missing');
          reason = parts.join(' · ');
        }
      }

      return `<div style="display:flex;align-items:flex-start;justify-content:space-between;gap:12px;padding:10px 0;border-bottom:1px solid #f3f4f6;">
        <div>
          <div style="font-size:13px;font-weight:600;color:#1d1d1f;">${label}</div>
          ${!passed && reason ? `<div style="font-size:11px;color:#92400e;margin-top:2px;">${reason}</div>` : ''}
        </div>
        <span style="flex-shrink:0;background:${badgeBg};color:${badgeCol};padding:3px 10px;border-radius:20px;font-size:11px;font-weight:700;">${badgeTxt}</span>
      </div>`;
    }).join('');

    bodyHtml = `
      <div style="padding:20px 24px 4px;">
        <div style="font-size:11px;font-weight:700;color:#9ca3af;text-transform:uppercase;letter-spacing:0.5px;margin-bottom:10px;">Gate Results</div>
        ${gateRows}
        <div style="margin-top:14px;padding:12px 14px;background:#fffbeb;border:1px solid #fde68a;border-radius:10px;font-size:12px;color:#92400e;line-height:1.6;">
          ⟳ The claim will transition to <strong>Issuance-Eligible</strong> automatically once all failed gates are resolved.<br>
          Use the <strong>Re-Evaluate</strong> button after corrections are made.
        </div>
      </div>`;
    footerBtnLabel = 'Got it';
    footerBtnColor = '#d97706';
  }

  const overlay = document.createElement('div');
  overlay.id = 'approvalResultOverlay';
  overlay.style.cssText = `
    position:fixed;inset:0;z-index:999999;
    background:rgba(0,0,0,0.55);backdrop-filter:blur(8px);
    display:flex;align-items:center;justify-content:center;padding:20px;
    font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;
  `;
  overlay.innerHTML = `
    <div style="background:#fff;border-radius:20px;width:100%;max-width:480px;max-height:85vh;overflow-y:auto;box-shadow:0 32px 80px rgba(0,0,0,0.3);animation:slideUpFade 0.18s ease;">
      <div style="background:${headerBg};padding:22px 24px 18px;border-radius:20px 20px 0 0;position:sticky;top:0;">
        <div style="font-size:11px;color:rgba(255,255,255,0.6);text-transform:uppercase;letter-spacing:1px;margin-bottom:4px;">Supervisor Approval Desk</div>
        <div style="font-size:18px;font-weight:700;color:#fff;">${headerIcon} ${headerTitle}</div>
        <div style="font-size:12px;color:rgba(255,255,255,0.75);margin-top:4px;line-height:1.4;">${headerSub}</div>
      </div>
      ${bodyHtml}
      <div style="padding:16px 24px 22px;display:flex;justify-content:flex-end;">
        <button id="approvalResultClose" style="
          background:${footerBtnColor};color:#fff;border:none;border-radius:10px;
          padding:12px 32px;font-size:14px;font-weight:700;cursor:pointer;
        ">${footerBtnLabel}</button>
      </div>
    </div>`;

  document.body.appendChild(overlay);
  document.getElementById('approvalResultClose').onclick = () => overlay.remove();
  overlay.addEventListener('click', e => { if (e.target === overlay) overlay.remove(); });
  document.addEventListener('keydown', function esc(e) {
    if (e.key === 'Escape') { overlay.remove(); document.removeEventListener('keydown', esc); }
  });
}

