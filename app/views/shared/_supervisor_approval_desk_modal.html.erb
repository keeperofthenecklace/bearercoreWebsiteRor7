<%#
  View: app/views/shared/_supervisor_approval_desk_modal.html.erb
  
  SUPERVISOR APPROVAL DESK
  ========================
  A regulator-grade interface for reviewing and authorizing trade claims.
  
  KEY PRINCIPLES:
  - Review checks are SYSTEM-DRIVEN, not manual judgments
  - Supervisor reviews automated outputs, not raw data
  - Supervisor cannot modify or override compliance results
  - All decisions are audit-logged
  
  AUTOMATED CHECK PIPELINE:
  1. DocumentValidationService → document_status
  2. AMLCheckService → aml_status
  3. LimitCheckService → limit_status
  4. BeneficiaryVerificationService → beneficiary_status
  5. ComplianceStatusAggregator → compliance_status (pre_cleared/manual_review/blocked)
%>

<!-- Supervisor Approval Desk Modal Overlay -->
<div id="supervisorDeskModalOverlay" style="
  display: none;
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  z-index: 10000;
  justify-content: center;
  align-items: center;
  padding: 20px;
">
  <div style="
    background: #f5f5f7;
    border-radius: 20px;
    width: 100%;
    max-width: 980px;
    max-height: 90vh;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.4);
    display: flex;
    flex-direction: column;
  ">
    <!-- Header -->
    <div style="
      background: linear-gradient(135deg, #1a4d3e 0%, #2d6a4f 50%, #1a4d3e 100%);
      padding: 24px 28px;
      position: relative;
      overflow: hidden;
    ">
      <!-- Subtle pattern overlay -->
      <div style="
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-image: radial-gradient(circle at 2px 2px, rgba(255,255,255,0.08) 1px, transparent 0);
        background-size: 24px 24px;
        pointer-events: none;
      "></div>
      
      <div style="display: flex; justify-content: space-between; align-items: center; position: relative; z-index: 1;">
        <div style="display: flex; align-items: center; gap: 16px;">
          <div style="
            width: 52px;
            height: 52px;
            background: rgba(255,255,255,0.15);
            border-radius: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            backdrop-filter: blur(10px);
          ">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="1.5">
              <circle cx="12" cy="12" r="10"></circle>
              <path d="M12 6v6l4 2"></path>
              <path d="M16.24 7.76l1.42-1.42"></path>
              <path d="M18 12h2"></path>
            </svg>
          </div>
          <div>
            <h2 style="
              margin: 0;
              font-size: 22px;
              font-weight: 600;
              color: #ffffff;
              letter-spacing: -0.3px;
            ">Supervisor Approval Desk</h2>
            <p style="
              margin: 4px 0 0;
              font-size: 13px;
              color: rgba(255, 255, 255, 0.75);
            ">Review and authorize trade claims and governance proposals.</p>
          </div>
        </div>
        
        <button onclick="hideSupervisorDeskModal()" style="
          width: 36px;
          height: 36px;
          border-radius: 50%;
          border: none;
          background: rgba(255, 255, 255, 0.2);
          color: white;
          font-size: 20px;
          cursor: pointer;
          display: flex;
          align-items: center;
          justify-content: center;
          transition: background 0.2s;
        " onmouseover="this.style.background='rgba(255,255,255,0.3)'"
           onmouseout="this.style.background='rgba(255,255,255,0.2)'">×</button>
      </div>
    </div>

    <!-- Content Area -->
    <div style="
      flex: 1;
      overflow-y: auto;
      padding: 24px;
      background: #f5f5f7;
    ">
      <!-- Search Bar -->
      <div style="
        display: flex;
        gap: 12px;
        margin-bottom: 24px;
      ">
        <div style="
          flex: 1;
          display: flex;
          align-items: center;
          background: white;
          border: 1px solid #e5e7eb;
          border-radius: 12px;
          padding: 0 16px;
        ">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input id="supervisorSearchInput" 
                 type="text" 
                 placeholder="Search by ID, institution or invoice ref..."
                 oninput="applySupervisorFilters()"
                 style="
                   flex: 1;
                   border: none;
                   outline: none;
                   padding: 14px 12px;
                   font-size: 14px;
                   background: transparent;
                 ">
        </div>
        <button onclick="loadSupervisorClaims()" style="
          background: #1a4d3e;
          color: white;
          border: none;
          border-radius: 12px;
          padding: 0 20px;
          font-size: 14px;
          font-weight: 600;
          cursor: pointer;
        ">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
        </button>
      </div>

      <!-- Section 1: Pending Items Queue -->
      <div style="
        background: white;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 20px;
        border: 1px solid #e5e7eb;
      ">
        <div onclick="toggleSupervisorSection('pendingQueueContent')" style="
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: 16px 20px;
          cursor: pointer;
          border-bottom: 1px solid #e5e7eb;
          background: #fafafa;
        ">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="
              width: 28px;
              height: 28px;
              background: #d1fae5;
              border-radius: 8px;
              display: flex;
              align-items: center;
              justify-content: center;
            ">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: #1d1d1f;">
              Pending Items Queue
            </h3>
            <span id="pendingQueueCount" style="
              background: #fef3c7;
              color: #d97706;
              padding: 3px 10px;
              border-radius: 12px;
              font-size: 12px;
              font-weight: 600;
            ">0</span>
          </div>
          <svg id="pendingQueueContentChevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2" style="transition: transform 0.2s;">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </div>
        
        <div id="pendingQueueContent">
          <div style="
            display: grid;
            grid-template-columns: 40px 180px 140px 120px 140px 130px 90px;
            gap: 8px;
            padding: 12px 20px;
            background: #f9fafb;
            border-bottom: 1px solid #e5e7eb;
            font-size: 11px;
            font-weight: 600;
            color: #6b7280;
            text-transform: uppercase;
            letter-spacing: 0.5px;
          ">
            <span>#</span>
            <span>Claim ID</span>
            <span>Institution</span>
            <span>Amount</span>
            <span>Corridor</span>
            <span>Compliance Status</span>
            <span>Submitted</span>
          </div>
          
          <div id="supervisorClaimsLoading" style="
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 40px;
            color: #6b7280;
            font-size: 14px;
          ">
            <span style="margin-right: 8px;">⏳</span> Loading claims...
          </div>
          
          <div id="supervisorClaimsRows"></div>
          
          <div style="
            display: flex;
            justify-content: center;
            padding: 16px;
            border-top: 1px solid #f3f4f6;
          ">
            <div style="display: flex; gap: 4px; align-items: center;">
              <button onclick="supervisorPrevPage()" id="supervisorPrevBtn" style="
                padding: 6px 10px;
                background: white;
                border: 1px solid #e5e7eb;
                border-radius: 6px;
                cursor: pointer;
                color: #9ca3af;
              ">‹</button>
              <span id="supervisorPageNumbers" style="display: flex; gap: 4px;"></span>
              <button onclick="supervisorNextPage()" id="supervisorNextBtn" style="
                padding: 6px 10px;
                background: white;
                border: 1px solid #e5e7eb;
                border-radius: 6px;
                cursor: pointer;
                color: #9ca3af;
              ">›</button>
            </div>
          </div>
        </div>
      </div>

      <!-- Section 2: Approve Trade Claim -->
      <div id="approvalSection" style="
        background: white;
        border-radius: 16px;
        overflow: hidden;
        margin-bottom: 20px;
        border: 1px solid #e5e7eb;
        display: none;
      ">
        <div onclick="toggleSupervisorSection('approvalContent')" style="
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: 16px 20px;
          cursor: pointer;
          border-bottom: 1px solid #e5e7eb;
          background: #fafafa;
        ">
          <div style="display: flex; align-items: center; gap: 12px;">
            <div style="
              width: 28px;
              height: 28px;
              background: #d1fae5;
              border-radius: 8px;
              display: flex;
              align-items: center;
              justify-content: center;
            ">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#059669" stroke-width="2.5">
                <polyline points="20 6 9 17 4 12"></polyline>
              </svg>
            </div>
            <h3 style="margin: 0; font-size: 16px; font-weight: 600; color: #1d1d1f;">
              Approve Trade Claim
            </h3>
          </div>
          <svg id="approvalContentChevron" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="#9ca3af" stroke-width="2">
            <polyline points="6 9 12 15 18 9"></polyline>
          </svg>
        </div>
        
        <div id="approvalContent" style="padding: 24px;">
          <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
            <!-- Left Column: Claim Details -->
            <div>
              <div style="
                display: flex;
                align-items: center;
                gap: 12px;
                margin-bottom: 20px;
                padding-bottom: 16px;
                border-bottom: 1px solid #e5e7eb;
              ">
                <div id="approvalInstitutionFlag" style="
                  width: 44px;
                  height: 44px;
                  background: #f3f4f6;
                  border-radius: 10px;
                  display: flex;
                  align-items: center;
                  justify-content: center;
                  font-size: 24px;
                ">🏦</div>
                <div>
                  <div id="approvalInstitutionName" style="font-size: 17px; font-weight: 600; color: #1d1d1f;">—</div>
                  <div id="approvalInstitutionType" style="font-size: 12px; color: #6b7280;">Authorized Dealer Bank</div>
                </div>
              </div>
              
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 16px;">
                <div>
                  <div style="font-size: 12px; color: #9ca3af; margin-bottom: 4px;">Trade Direction</div>
                  <div id="approvalDirection" style="font-size: 14px; color: #1d1d1f; font-weight: 500;">—</div>
                </div>
                <div>
                  <div style="font-size: 12px; color: #9ca3af; margin-bottom: 4px;">Corridor</div>
                  <div id="approvalCorridor" style="font-size: 14px; color: #1d1d1f; font-weight: 500;">—</div>
                </div>
                <div>
                  <div style="font-size: 12px; color: #9ca3af; margin-bottom: 4px;">Trade Amount</div>
                  <div id="approvalAmount" style="font-size: 14px; color: #1d1d1f; font-weight: 600;">—</div>
                </div>
                <div>
                  <div style="font-size: 12px; color: #9ca3af; margin-bottom: 4px;">Invoice Reference</div>
                  <div id="approvalInvoiceRef" style="font-size: 14px; color: #1d1d1f; font-weight: 500;">—</div>
                </div>
              </div>
              
              <div style="margin-top: 20px; padding-top: 16px; border-top: 1px solid #e5e7eb;">
                <div style="font-size: 13px; font-weight: 600; color: #1d1d1f; margin-bottom: 12px;">Beneficiary Info</div>
                <div style="background: #f9fafb; border-radius: 10px; padding: 14px;">
                  <div style="display: flex; align-items: center; gap: 10px;">
                    <div style="
                      width: 32px;
                      height: 32px;
                      background: #e5e7eb;
                      border-radius: 8px;
                      display: flex;
                      align-items: center;
                      justify-content: center;
                    ">👤</div>
                    <div>
                      <div style="font-size: 12px; color: #9ca3af;">Beneficiary Name:</div>
                      <div id="approvalBeneficiaryName" style="font-size: 14px; color: #1d1d1f; font-weight: 500;">—</div>
                    </div>
                  </div>
                  <div style="margin-top: 10px; display: flex; gap: 20px;">
                    <div>
                      <div style="font-size: 11px; color: #9ca3af;">Bank</div>
                      <div id="approvalBeneficiaryBank" style="font-size: 13px; color: #374151;">—</div>
                    </div>
                    <div>
                      <div style="font-size: 11px; color: #9ca3af;">Country</div>
                      <div id="approvalBeneficiaryCountry" style="font-size: 13px; color: #374151;">—</div>
                    </div>
                  </div>
                </div>
              </div>
            </div>
            
            <!-- Right Column: Gating Conditions & Updates -->
            <div>
              <div style="font-size: 13px; font-weight: 600; color: #1d1d1f; margin-bottom: 12px; display: flex; align-items: center; justify-content: space-between;">
                <span>Gating Conditions <span style="font-weight: 400; color: #6b7280; font-size: 11px; margin-left: 4px;">(System-Generated)</span></span>
                <span id="gatingOverallBadge" style="padding: 3px 10px; border-radius: 10px; font-size: 10px; font-weight: 700; background: #f3f4f6; color: #6b7280;">EVALUATING</span>
              </div>

              <div style="background: #f9fafb; border-radius: 12px; padding: 12px; display: flex; flex-direction: column; gap: 8px;">

                <!-- Gate 1: Supervisor Approval -->
                <div id="gateRow_supervisor_approval" style="background: white; border-radius: 8px; border: 1px solid #e5e7eb; overflow: hidden;">
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 9px 12px; cursor: pointer;" onclick="toggleGateDetail('supervisor_approval')">
                    <div style="display: flex; align-items: center; gap: 9px;">
                      <span id="gateIcon_supervisor_approval" style="font-size: 15px;">⏳</span>
                      <div>
                        <div style="font-size: 12px; font-weight: 600; color: #374151;">1. Supervisor Approval</div>
                        <div style="font-size: 10px; color: #9ca3af;">Status approved · 4-eyes · Audit trail</div>
                      </div>
                    </div>
                    <span id="gateBadge_supervisor_approval" style="padding: 3px 10px; border-radius: 10px; font-size: 11px; font-weight: 600; background: #f3f4f6; color: #6b7280;">Pending</span>
                  </div>
                  <div id="gateDetail_supervisor_approval" style="display: none; padding: 8px 12px 10px; border-top: 1px solid #f3f4f6; background: #fafafa;">
                    <div id="gateDetailText_supervisor_approval" style="font-size: 11px; color: #6b7280; line-height: 1.6;"></div>
                  </div>
                </div>

                <!-- Gate 2: Compliance -->
                <div id="gateRow_compliance" style="background: white; border-radius: 8px; border: 1px solid #e5e7eb; overflow: hidden;">
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 9px 12px; cursor: pointer;" onclick="toggleGateDetail('compliance')">
                    <div style="display: flex; align-items: center; gap: 9px;">
                      <span id="gateIcon_compliance" style="font-size: 15px;">⏳</span>
                      <div>
                        <div style="font-size: 12px; font-weight: 600; color: #374151;">2. Compliance Passed</div>
                        <div style="font-size: 10px; color: #9ca3af;">AML · Sanctions · Risk score · Docs</div>
                      </div>
                    </div>
                    <span id="gateBadge_compliance" style="padding: 3px 10px; border-radius: 10px; font-size: 11px; font-weight: 600; background: #f3f4f6; color: #6b7280;">Pending</span>
                  </div>
                  <div id="gateDetail_compliance" style="display: none; padding: 8px 12px 10px; border-top: 1px solid #f3f4f6; background: #fafafa;">
                    <div id="gateDetailText_compliance" style="font-size: 11px; color: #6b7280; line-height: 1.6;"></div>
                  </div>
                </div>

                <!-- Gate 3: Corridor Limits -->
                <div id="gateRow_corridor_limits" style="background: white; border-radius: 8px; border: 1px solid #e5e7eb; overflow: hidden;">
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 9px 12px; cursor: pointer;" onclick="toggleGateDetail('corridor_limits')">
                    <div style="display: flex; align-items: center; gap: 9px;">
                      <span id="gateIcon_corridor_limits" style="font-size: 15px;">⏳</span>
                      <div>
                        <div style="font-size: 12px; font-weight: 600; color: #374151;">3. Corridor Limits Available</div>
                        <div style="font-size: 10px; color: #9ca3af;">Daily limit · Not suspended · Velocity</div>
                      </div>
                    </div>
                    <span id="gateBadge_corridor_limits" style="padding: 3px 10px; border-radius: 10px; font-size: 11px; font-weight: 600; background: #f3f4f6; color: #6b7280;">Pending</span>
                  </div>
                  <div id="gateDetail_corridor_limits" style="display: none; padding: 8px 12px 10px; border-top: 1px solid #f3f4f6; background: #fafafa;">
                    <div id="gateDetailText_corridor_limits" style="font-size: 11px; color: #6b7280; line-height: 1.6;"></div>
                  </div>
                </div>

                <!-- Gate 4: Liquidity -->
                <div id="gateRow_liquidity" style="background: white; border-radius: 8px; border: 1px solid #e5e7eb; overflow: hidden;">
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 9px 12px; cursor: pointer;" onclick="toggleGateDetail('liquidity')">
                    <div style="display: flex; align-items: center; gap: 9px;">
                      <span id="gateIcon_liquidity" style="font-size: 15px;">⏳</span>
                      <div>
                        <div style="font-size: 12px; font-weight: 600; color: #374151;">4. Liquidity Confirmed</div>
                        <div style="font-size: 10px; color: #9ca3af;">Backing asset · Reserve pool · DLT lock</div>
                      </div>
                    </div>
                    <span id="gateBadge_liquidity" style="padding: 3px 10px; border-radius: 10px; font-size: 11px; font-weight: 600; background: #f3f4f6; color: #6b7280;">Pending</span>
                  </div>
                  <div id="gateDetail_liquidity" style="display: none; padding: 8px 12px 10px; border-top: 1px solid #f3f4f6; background: #fafafa;">
                    <div id="gateDetailText_liquidity" style="font-size: 11px; color: #6b7280; line-height: 1.6;"></div>
                  </div>
                </div>

                <!-- Gate 5: Governance -->
                <div id="gateRow_governance" style="background: white; border-radius: 8px; border: 1px solid #e5e7eb; overflow: hidden;">
                  <div style="display: flex; align-items: center; justify-content: space-between; padding: 9px 12px; cursor: pointer;" onclick="toggleGateDetail('governance')">
                    <div style="display: flex; align-items: center; gap: 9px;">
                      <span id="gateIcon_governance" style="font-size: 15px;">⏳</span>
                      <div>
                        <div style="font-size: 12px; font-weight: 600; color: #374151;">5. Governance Rules Met</div>
                        <div style="font-size: 10px; color: #9ca3af;">Dual approval · Supermajority · Sovereign</div>
                      </div>
                    </div>
                    <span id="gateBadge_governance" style="padding: 3px 10px; border-radius: 10px; font-size: 11px; font-weight: 600; background: #f3f4f6; color: #6b7280;">Pending</span>
                  </div>
                  <div id="gateDetail_governance" style="display: none; padding: 8px 12px 10px; border-top: 1px solid #f3f4f6; background: #fafafa;">
                    <div id="gateDetailText_governance" style="font-size: 11px; color: #6b7280; line-height: 1.6;"></div>
                  </div>
                </div>

              </div><!-- end gate rows -->

              <!-- Updates Section -->
              <div style="margin-top: 14px;">
                <div style="font-size: 13px; font-weight: 600; color: #1d1d1f; margin-bottom: 10px;">
                  Updates
                  <span style="font-weight: 400; color: #6b7280; font-size: 11px; margin-left: 6px;">(On Approval)</span>
                </div>
                <div id="approvalUpdates" style="
                  background: #f9fafb;
                  border: 1px solid #e5e7eb;
                  border-radius: 10px;
                  padding: 12px 14px;
                  font-size: 12px;
                  color: #6b7280;
                  display: flex;
                  flex-direction: column;
                  gap: 6px;
                ">
                  <div>○ status → pending approval</div>
                  <div>○ liquidity_lock not created</div>
                  <div id="issuanceEligibleUpdate" style="display:none; margin-top:6px; padding-top:6px; border-top:1px solid #bbf7d0;">
                    <span style="color: #059669; font-weight:600;">🏦 status → issuance_eligible</span>
                    <div style="font-size:11px; color:#166534; margin-top:2px;">All 5 gating conditions satisfied. Ready for CVIB minting.</div>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- ── Lifecycle Tracking Table ─────────────────────────────────── -->
          <div id="lifecycleTrackingSection" style="margin-top: 20px; padding-top: 18px; border-top: 1px solid #f3f4f6; display: none;">
            <div style="font-size: 13px; font-weight: 600; color: #1d1d1f; margin-bottom: 12px;">
              Claim Lifecycle Tracking
              <span style="font-weight: 400; color: #6b7280; font-size: 11px; margin-left: 6px;">(follows claim until Issuance-Eligible)</span>
            </div>
            <div style="overflow-x: auto;">
              <table style="width: 100%; border-collapse: collapse; font-size: 12px;">
                <thead>
                  <tr style="background: #f9fafb; border-bottom: 1px solid #e5e7eb;">
                    <th style="padding: 8px 12px; text-align: left; font-weight: 600; color: #6b7280; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Stage</th>
                    <th style="padding: 8px 12px; text-align: left; font-weight: 600; color: #6b7280; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Status</th>
                    <th style="padding: 8px 12px; text-align: left; font-weight: 600; color: #6b7280; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Condition</th>
                    <th style="padding: 8px 12px; text-align: left; font-weight: 600; color: #6b7280; font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px;">Satisfied</th>
                  </tr>
                </thead>
                <tbody id="lifecycleTableBody">
                </tbody>
              </table>
            </div>
          </div>

          <!-- Decision Notes & Actions -->
          <div style="
            margin-top: 24px;
            padding-top: 20px;
            border-top: 1px solid #e5e7eb;
