// Resolve corridor country value (ISO-2, ISO-3, alias, or full name) to its ISO 4217 currency code
function resolveCorridorCurrency(countryRaw) {
  if (!countryRaw) return null;
  const v = countryRaw.toString().trim();
  return supervisorCountryToCurrency[v]
    || supervisorCountryToCurrency[v.toUpperCase()]
    || null;
}

function showSupervisorDeskModal() {
  document.getElementById('supervisorDeskModalOverlay').style.display = 'flex';
  document.body.style.overflow = 'hidden';
  loadSupervisorClaims();
}

function hideSupervisorDeskModal() {
  document.getElementById('supervisorDeskModalOverlay').style.display = 'none';
  document.body.style.overflow = '';
}

function toggleSupervisorSection(sectionId) {
  const section = document.getElementById(sectionId);
  section.style.display = section.style.display === 'none' ? 'block' : 'none';
}

function getSupervisorToken() {
  if (typeof getAccessToken === 'function') return getAccessToken();
  const envToken = '<%= ENV["ADMIN_API_TOKEN"] || "" %>';
  return envToken || localStorage.getItem('access_token') || localStorage.getItem('accessToken') || 'wOJLHO7nXlO7IOqUI8mX9nfYMQi_S8EmqKMwUOh-FO8';
}

function getSupervisorAuthHeaders() {
  const headers = { 'Accept': 'application/json', 'Content-Type': 'application/json' };
  const csrfToken = document.querySelector('meta[name="csrf-token"]')?.content;
  if (csrfToken) headers['X-CSRF-Token'] = csrfToken;
  headers['Authorization'] = `Bearer ${getSupervisorToken()}`;
  return headers;
}

async function loadSupervisorClaims() {
  const loading = document.getElementById('supervisorClaimsLoading');
  const rows = document.getElementById('supervisorClaimsRows');
  loading.style.display = 'flex';
  rows.innerHTML = '';
  
  try {
    const response = await fetch('/api/v2/trade_claims', {
      headers: {
        'Authorization': `Bearer ${getSupervisorToken()}`,
        'Content-Type': 'application/json'
      }
    });
    
    if (!response.ok) throw new Error(`Failed: ${response.status}`);
    
    const data = await response.json();
    supervisorClaims = data.data || data || [];
    
    // ── Lifecycle filter: include ALL active claims through issuance_eligible ──
    // Claims are only removed from this view once fully settled, rejected, or cancelled.
    supervisorClaims = supervisorClaims.filter(claim => {
      const status = claim.status || '';

      // Always exclude terminal statuses
      if (['rejected', 'cancelled', 'completed', 'settled'].includes(status)) return false;

      // Keep every non-terminal status so the lifecycle tracking table stays visible
      // This includes: submitted, under_review, pending, pre_cleared, manual_review,
      //                approved, issuance_eligible, locked
      return true;
    });
    
    console.log('Supervisor claims loaded:', supervisorClaims.length, 'claims needing review');
    
    applySupervisorFilters();
    document.getElementById('pendingQueueCount').textContent = filteredSupervisorClaims.length;
  } catch (error) {
    console.error('Error:', error);
    loading.style.display = 'none';
    rows.innerHTML = '<div style="padding: 40px; text-align: center; color: #ef4444;">Error loading claims</div>';
  }
}

function applySupervisorFilters() {
  const searchTerm = document.getElementById('supervisorSearchInput')?.value?.toLowerCase() || '';
  filteredSupervisorClaims = supervisorClaims.filter(c => {
    const ref = (c.reference || '').toLowerCase();
    const inst = (c.institution?.name || '').toLowerCase();
    return ref.includes(searchTerm) || inst.includes(searchTerm);
  });
  supervisorCurrentPage = 1;
  renderSupervisorClaims();
}

function renderSupervisorClaims() {
  const loading = document.getElementById('supervisorClaimsLoading');
  const rows = document.getElementById('supervisorClaimsRows');
  loading.style.display = 'none';
  
  if (filteredSupervisorClaims.length === 0) {
    rows.innerHTML = '<div style="padding: 40px; text-align: center; color: #6b7280;">No claims pending review</div>';
    return;
  }
  
  const start = (supervisorCurrentPage - 1) * supervisorPageSize;
  const pageClaims = filteredSupervisorClaims.slice(start, start + supervisorPageSize);
  
  rows.innerHTML = pageClaims.map((claim, i) => {
    const rowNum = start + i + 1;
    const ref = claim.reference || `TC-${(claim.id || '').toString().slice(0, 8)}`;
    const inst = claim.institution?.name || 'Unknown';
    const amt = claim.trade_details?.amount || claim.amount || 0;
    
    // Extract corridor info
    let fromCountry = claim.corridor?.source_country || claim.corridor?.from_country || '';
    let toCountry = claim.corridor?.target_country || claim.corridor?.to_country || '';

    // Fall back to parsing corridor name string (e.g. "Morocco-Tanzania Corridor")
    if ((!fromCountry || !toCountry) && claim.corridor?.name) {
      const stripped = claim.corridor.name.replace(/\s*corridor\s*$/i, '').trim();
      const parts = stripped.split(/\s*[→\-]\s*/);
      if (parts.length >= 2) {
        if (!fromCountry) fromCountry = parts[0].trim();
        if (!toCountry)   toCountry   = parts[1].trim();
      }
    }

    // Try beneficiary country for target
    if (!toCountry) {
      toCountry = claim.beneficiary_country || claim.beneficiary?.country || '';
    }
    
    // Derive source from institution if not set - sort by length for accurate matching
    if (!fromCountry && inst) {
      const instUpper = inst.toUpperCase();
      const sortedInstitutions = Object.entries(supervisorInstitutionToCountry)
        .sort((a, b) => b[0].length - a[0].length);
      
      for (const [bankName, code] of sortedInstitutions) {
        if (instUpper.includes(bankName)) {
          fromCountry = code;
          break;
        }
      }
      if (!fromCountry) {
        for (const [countryName, code] of Object.entries(supervisorCountryNameToCode)) {
          if (instUpper.includes(countryName)) {
            fromCountry = code;
              break;
          }
        }
      }
    }

    // Always derive currency from destination country — ignore API's currency_code which may be USD
    const curr = resolveCorridorCurrency(toCountry) || resolveCorridorCurrency(fromCountry) || 'USD';

    const fromFlag = resolveSupervisorFlag(fromCountry);
    const toFlag   = resolveSupervisorFlag(toCountry);
    
    const compStatus = resolveComplianceStatus(claim);
    const conf = complianceStatusConfig[compStatus] || complianceStatusConfig['pending'];
    const isSelected = selectedSupervisorClaim === claim.id;
    const timeAgo = claim.created_at ? getTimeAgo(new Date(claim.created_at)) : '—';
    
    return `
      <div class="supervisor-claim-row ${isSelected ? 'selected' : ''}" 
           onclick="selectSupervisorClaim('${claim.id}')"
           style="
             display: grid;
             grid-template-columns: 40px 180px 140px 120px 140px 130px 90px;
             gap: 8px;
             padding: 14px 20px;
             border-bottom: 1px solid #f3f4f6;
             cursor: pointer;
             background: ${isSelected ? '#d1fae5' : 'white'};
           ">
        <div style="font-size: 13px; color: #6b7280;">${fromFlag} ${rowNum}</div>
        <div style="font-size: 12px; font-weight: 500; font-family: monospace;">${ref}</div>
        <div style="font-size: 12px; color: #374151; overflow: hidden; text-overflow: ellipsis;">${inst.substring(0,18)}</div>
        <div style="font-size: 13px; font-weight: 500;">${curr} ${parseFloat(amt).toLocaleString()}</div>
        <div style="font-size: 12px;">${fromFlag} ${fromCountry || '—'} → ${toFlag} ${toCountry || '—'}</div>
        <div>
          <span style="
            padding: 4px 10px;
            border-radius: 12px;
            font-size: 10px;
            font-weight: 600;
            background: ${conf.bg};
            color: ${conf.color};
            border: 1px solid ${conf.border};
          ">${conf.icon} ${conf.label}</span>
        </div>
        <div style="font-size: 11px; color: #9ca3af;">${timeAgo}</div>
      </div>
    `;
  }).join('');
  
  updateSupervisorPagination();
}

function getTimeAgo(date) {
  const diffMs = new Date() - date;
  const mins = Math.floor(diffMs / 60000);
  const hrs = Math.floor(diffMs / 3600000);
  if (mins < 60) return `${mins}m ago`;
  if (hrs < 24) return `${hrs}h ago`;
  return `${Math.floor(diffMs / 86400000)}d ago`;
}

function updateSupervisorPagination() {
  const total = Math.ceil(filteredSupervisorClaims.length / supervisorPageSize);
  let html = '';
  for (let i = 1; i <= Math.min(total, 5); i++) {
    html += `<button onclick="goToSupervisorPage(${i})" style="
      padding: 6px 12px;
      background: ${i === supervisorCurrentPage ? '#1a4d3e' : 'white'};
      color: ${i === supervisorCurrentPage ? 'white' : '#374151'};
      border: 1px solid ${i === supervisorCurrentPage ? '#1a4d3e' : '#e5e7eb'};
      border-radius: 6px;
      cursor: pointer;
    ">${i}</button>`;
  }
  document.getElementById('supervisorPageNumbers').innerHTML = html;
}

function goToSupervisorPage(p) { supervisorCurrentPage = p; renderSupervisorClaims(); }
function supervisorPrevPage() { if (supervisorCurrentPage > 1) { supervisorCurrentPage--; renderSupervisorClaims(); } }
function supervisorNextPage() { 
  if (supervisorCurrentPage < Math.ceil(filteredSupervisorClaims.length / supervisorPageSize)) { 
    supervisorCurrentPage++; 
    renderSupervisorClaims(); 
  } 
}

function selectSupervisorClaim(claimId) {
  selectedSupervisorClaim = claimId;
  selectedSupervisorClaimData = supervisorClaims.find(c => c.id === claimId);
  if (!selectedSupervisorClaimData) return;
  
  document.getElementById('approvalSection').style.display = 'block';
  populateApprovalDetails(selectedSupervisorClaimData);
  populateReviewChecks(selectedSupervisorClaimData);
  renderSupervisorClaims();
  document.getElementById('approvalSection').scrollIntoView({ behavior: 'smooth' });
}

function populateApprovalDetails(claim) {
  const inst = claim.institution?.name || 'Unknown';
  const dir = claim.trade_details?.direction || claim.trade_direction || 'import';
  const amt = claim.trade_details?.amount || claim.amount || 0;
  
  // Extract corridor info - check multiple possible locations
  let fromCountry = '';
  let toCountry = '';
  
  // Try corridor object first
  if (claim.corridor) {
    fromCountry = claim.corridor.source_country || claim.corridor.from_country || '';
    toCountry = claim.corridor.target_country || claim.corridor.to_country || '';
  }

  // Fall back to parsing corridor name string (e.g. "Morocco-Tanzania Corridor")
  if ((!fromCountry || !toCountry) && claim.corridor?.name) {
    const stripped = claim.corridor.name.replace(/\s*corridor\s*$/i, '').trim();
    const parts = stripped.split(/\s*[→\-]\s*/);
    if (parts.length >= 2) {
      if (!fromCountry) fromCountry = parts[0].trim();
      if (!toCountry)   toCountry   = parts[1].trim();
    }
  }
  
  // Try beneficiary country for target
  if (!toCountry) {
    toCountry = claim.beneficiary_country || claim.beneficiary?.country || '';
  }
  
  // Try to derive source country from institution name
  if (!fromCountry && inst) {
    const instUpper = inst.toUpperCase();
    
    // Check institution mapping - sort by key length (longer matches first) to avoid partial matches
    const sortedInstitutions = Object.entries(supervisorInstitutionToCountry)
      .sort((a, b) => b[0].length - a[0].length);
    
    for (const [bankName, code] of sortedInstitutions) {
      if (instUpper.includes(bankName)) {
        fromCountry = code;
        break;
      }
    }
    
    // Check for country name in institution name
    if (!fromCountry) {
      for (const [countryName, code] of Object.entries(supervisorCountryNameToCode)) {
        if (instUpper.includes(countryName)) {
          fromCountry = code;
          break;
        }
      }
    }
  }
  
  // Currency: trust the claim's own currency_code first.
  // Only use country-derived currency as fallback when currency_code is blank.
  const rawCurr = claim.currency_code || claim.trade_details?.currency || '';
  const curr = rawCurr || resolveCorridorCurrency(toCountry) || resolveCorridorCurrency(fromCountry) || 'USD';
  
  // Get flags
  const fromFlag = resolveSupervisorFlag(fromCountry);
  const toFlag   = resolveSupervisorFlag(toCountry);
  
  // Populate fields
  document.getElementById('approvalInstitutionName').textContent = inst;
  document.getElementById('approvalInstitutionFlag').textContent = fromFlag;
  
  // Trade direction with country name
  const directionText = dir === 'import' 
    ? `Import into ${fromCountry || 'Unknown'}`
    : `Export from ${fromCountry || 'Unknown'}`;
  document.getElementById('approvalDirection').textContent = directionText;
  
  // Corridor with flags and country codes
  document.getElementById('approvalCorridor').innerHTML = `${fromFlag} ${fromCountry || '—'} → ${toFlag} ${toCountry || '—'}`;
  
  document.getElementById('approvalAmount').textContent = `${curr} ${parseFloat(amt).toLocaleString()}`;
  document.getElementById('approvalInvoiceRef').textContent = claim.trade_details?.invoice_ref || claim.invoice_ref || '—';
  document.getElementById('approvalBeneficiaryName').textContent = claim.beneficiary?.name || claim.beneficiary_name || '—';
  document.getElementById('approvalBeneficiaryBank').textContent = claim.beneficiary?.bank || claim.beneficiary_bank_name || '—';
  document.getElementById('approvalBeneficiaryCountry').textContent = claim.beneficiary?.country || claim.beneficiary_country || '—';
  document.getElementById('supervisorDecisionNotes').value = '';
}

