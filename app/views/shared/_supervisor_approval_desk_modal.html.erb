            border:none;border-radius:10px;font-size:14px;font-weight:600;cursor:pointer;
          ">Cancel</button>
          <button id="approvalConfirmOK" style="
            flex:2;padding:13px;
            background:linear-gradient(135deg,#059669,#1a4d3e);
            color:white;border:none;border-radius:10px;
            font-size:14px;font-weight:700;cursor:pointer;
            display:flex;align-items:center;justify-content:center;gap:8px;
            box-shadow:0 4px 14px rgba(5,150,105,0.35);
          ">✓ Approve Trade Claim</button>
        </div>
      </div>
      <style>
        @keyframes slideUpFade {
          from { opacity:0; transform:translateY(16px) scale(0.97); }
          to   { opacity:1; transform:translateY(0)    scale(1); }
        }
      </style>
    `;

    document.body.appendChild(overlay);

    const cleanup = (result) => {
      overlay.remove();
      resolve(result);
    };

    document.getElementById('approvalConfirmOK').onclick     = () => cleanup(true);
    document.getElementById('approvalConfirmCancel').onclick = () => cleanup(false);
    overlay.addEventListener('click', e => { if (e.target === overlay) cleanup(false); });

    // Keyboard: Enter = confirm, Escape = cancel
    const keyHandler = e => {
      if (e.key === 'Enter')  { document.removeEventListener('keydown', keyHandler); cleanup(true); }
      if (e.key === 'Escape') { document.removeEventListener('keydown', keyHandler); cleanup(false); }
    };
    document.addEventListener('keydown', keyHandler);
  });
}

async function supervisorApproveClaim() {
  if (!selectedSupervisorClaimData) { alert('Please select a claim first'); return; }
  const notes = document.getElementById('supervisorDecisionNotes').value;

  // ── Styled confirmation modal (replaces browser confirm()) ───────────────
  const confirmed = await showApprovalConfirmModal(selectedSupervisorClaimData, notes);
  if (!confirmed) return;

  const btn = document.getElementById('btnApprove');
  const originalText = btn.innerHTML;
  btn.disabled = true;
  btn.innerHTML = '⏳ Approving...';

  try {
    const res = await fetch(`/api/v2/trade_claims/${selectedSupervisorClaimData.id}/approve`, {
      method: 'POST',
      headers: getSupervisorAuthHeaders(),
      body: JSON.stringify({ notes })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.message || data.error || `Failed: ${res.status}`);

    const issuanceEligible = data.issuance_eligible === true;
    const finalStatus      = data.status || 'approved';

    // ── Merge gating results back into the claim object and re-render ──
    selectedSupervisorClaimData = {
      ...selectedSupervisorClaimData,
      status:             finalStatus,
      gating_conditions:  data.eligibility?.gates || {},
      eligibility:        data.eligibility || {}
    };

    // Re-render gating conditions panel and lifecycle table with real results
    populateReviewChecks(selectedSupervisorClaimData);

    // ── Update the "Updates" panel ──
    const updatesEl    = document.getElementById('approvalUpdates');
    const issuanceEl   = document.getElementById('issuanceEligibleUpdate');

    if (issuanceEligible) {
      updatesEl.innerHTML = `
        <div><span style="color:#22c55e;">✓</span> status → issuance_eligible</div>
        <div><span style="color:#22c55e;">✓</span> liquidity_lock created</div>
        <div><span style="color:#22c55e;">✓</span> issuance_authorization created</div>
      `;
      updatesEl.style.background   = '#f0fdf4';
      updatesEl.style.color        = '#166534';
      updatesEl.style.borderColor  = '#bbf7d0';
      if (issuanceEl) issuanceEl.style.display = 'block';
      btn.innerHTML = '🏦 Approved → Issuance-Eligible';
    } else {
      const failedConditions = data.eligibility?.failed_conditions || [];
      updatesEl.innerHTML = `
        <div><span style="color:#22c55e;">✓</span> status → approved</div>
        <div><span style="color:#f59e0b;">⟳</span> Eligibility evaluation: ${failedConditions.length} gate(s) pending</div>
        ${failedConditions.map(f => `<div style="font-size:11px;color:#92400e;padding-left:12px;">• ${f}</div>`).join('')}
      `;
      updatesEl.style.background   = '#fffbeb';
      updatesEl.style.color        = '#92400e';
      updatesEl.style.borderColor  = '#fde68a';
      if (issuanceEl) issuanceEl.style.display = 'none';
      btn.innerHTML = '✅ Approved (eligibility pending)';
    }

    // ── Reload queue but do NOT hide the panel — claim stays visible ──
    // Update the in-memory claims list with the new status so the queue row
    // reflects approved/issuance_eligible without disappearing.
    const idx = supervisorClaims.findIndex(c => c.id === selectedSupervisorClaimData.id);
    if (idx !== -1) supervisorClaims[idx] = { ...supervisorClaims[idx], status: finalStatus };
    applySupervisorFilters();

    // ── Styled result modal (replaces browser alert) ─────────────────────────
    showApprovalResultModal({
      issuanceEligible,
      reference:        selectedSupervisorClaimData.reference || finalStatus,
      failedConditions: data.eligibility?.failed_conditions || [],
      gates:            data.eligibility?.gates || {}
    });

  } catch (e) {
    showApprovalResultModal({ error: true, errorMessage: e.message });
    btn.disabled = false;
    btn.innerHTML = originalText;
  }
}

// ── Re-Evaluate Eligibility ──────────────────────────────────────────────────
// Called when the supervisor clicks "Re-Evaluate" after a gate was previously
// failed and the underlying issue has since been corrected (e.g. compliance
// team cleared an AML flag in the back-office system).
//
// Maps to: POST /api/v2/trade_claims/:id/re_evaluate
// The backend runs Claims::IssuanceEligibilityService.re_evaluate(claim)
// which re-runs all 5 gates and transitions to issuance_eligible if all pass.
async function supervisorReEvaluateClaim() {
  if (!selectedSupervisorClaimData) return;

  const btn = document.getElementById('btnReEvaluate');
  if (btn) { btn.disabled = true; btn.innerHTML = '⏳ Evaluating...'; }

  try {
    const res = await fetch(`/api/v2/trade_claims/${selectedSupervisorClaimData.id}/re_evaluate`, {
      method:  'POST',
      headers: getSupervisorAuthHeaders(),
      body:    JSON.stringify({})
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.message || data.error || `HTTP ${res.status}`);

    const issuanceEligible = data.issuance_eligible === true;
    const finalStatus      = data.status || selectedSupervisorClaimData.status;

    // ── Merge new gate results back into claim object ──
    selectedSupervisorClaimData = {
      ...selectedSupervisorClaimData,
      status:            finalStatus,
      gating_conditions: data.eligibility?.gates || selectedSupervisorClaimData.gating_conditions || {},
      eligibility:       data.eligibility || {}
    };

    // Re-render the gating panel + lifecycle table with fresh results
    populateReviewChecks(selectedSupervisorClaimData);

    // ── Update the "Updates" panel ──
    const updatesEl = document.getElementById('approvalUpdates');
    const issuanceEl = document.getElementById('issuanceEligibleUpdate');

    if (issuanceEligible) {
      // All gates now pass — claim has transitioned to issuance_eligible
      updatesEl.innerHTML = `
        <div><span style="color:#22c55e;">✓</span> Re-evaluation complete</div>
        <div><span style="color:#22c55e;">✓</span> status → issuance_eligible</div>
        <div><span style="color:#22c55e;">✓</span> All 5 gates passed</div>
        <div><span style="color:#22c55e;">✓</span> issuance_authorization created</div>
      `;
      updatesEl.style.background  = '#f0fdf4';
      updatesEl.style.color       = '#166534';
      updatesEl.style.borderColor = '#bbf7d0';
      if (issuanceEl) issuanceEl.style.display = 'block';

      // Update queue row to reflect new status
      const idx = supervisorClaims.findIndex(c => c.id === selectedSupervisorClaimData.id);
      if (idx !== -1) supervisorClaims[idx] = { ...supervisorClaims[idx], status: finalStatus };
      applySupervisorFilters();

      // Swap button state — Approve is no longer needed
      const approveBtn = document.getElementById('btnApprove');
      if (approveBtn) { approveBtn.innerHTML = '🏦 Issuance-Eligible'; approveBtn.disabled = true; }
      if (btn) { btn.style.display = 'none'; }

    } else {
      // Some gates still failing — show which ones remain blocked
      const failedConditions = data.eligibility?.failed_conditions || [];
      updatesEl.innerHTML = `
        <div><span style="color:#f59e0b;">⟳</span> Re-evaluation complete — still blocked</div>
        ${failedConditions.map(f =>
          `<div style="font-size:11px;color:#92400e;padding-left:12px;">• ${f}</div>`
        ).join('')}
        <div style="font-size:11px;color:#6b7280;margin-top:6px;padding-left:12px;">
          Re-evaluate again once those conditions are corrected.
        </div>
      `;
      updatesEl.style.background  = '#fffbeb';
      updatesEl.style.color       = '#92400e';
      updatesEl.style.borderColor = '#fde68a';
      if (issuanceEl) issuanceEl.style.display = 'none';
      if (btn) { btn.disabled = false; btn.innerHTML = '⟳ Re-Evaluate'; }
    }

  } catch (e) {
    const failMsg = `Re-evaluation failed: ${e.message}`;
    const updatesEl = document.getElementById('approvalUpdates');
    if (updatesEl) {
      updatesEl.innerHTML = `<div style="color:#dc2626;">⚠ ${failMsg}</div>`;
      updatesEl.style.background = '#fef2f2';
    }
    if (btn) { btn.disabled = false; btn.innerHTML = '⟳ Re-Evaluate'; }
    console.error('[supervisorReEvaluateClaim]', e);
  }
}

async function supervisorRejectClaim() {
  if (!selectedSupervisorClaimData) { alert('Please select a claim first'); return; }
  const notes = document.getElementById('supervisorDecisionNotes').value;
  if (!notes.trim()) { alert('Please provide a reason in Decision Notes.'); return; }
  if (!confirm('Reject this trade claim?')) return;
  
  try {
    const res = await fetch(`/api/v2/trade_claims/${selectedSupervisorClaimData.id}/reject`, {
      method: 'POST',
      headers: getSupervisorAuthHeaders(),
      body: JSON.stringify({ notes, reason: notes })
    });
    const data = await res.json();
    if (!res.ok) throw new Error(data.message || data.error || `Failed: ${res.status}`);
    alert('⛔ Claim rejected successfully.');
    loadSupervisorClaims();
    document.getElementById('approvalSection').style.display = 'none';
    selectedSupervisorClaim = null;
    selectedSupervisorClaimData = null;
  } catch (e) { alert('Error rejecting claim: ' + e.message); }
}

