  ZAR: { notes:[200,100,50,20,10,5],            coins:[2,1,0.50,0.20,0.10,0.05], coin_name:'Cents',      coin_decimals:2 },
  BWP: { notes:[200,100,50,20,10,5],            coins:[2,1,0.50,0.25,0.10,0.05], coin_name:'Thebe',      coin_decimals:2 },
  UGX: { notes:[50000,20000,10000,5000,2000,1000,500,200], coins:[100],           coin_name:'Cents',      coin_decimals:0 },
  TZS: { notes:[10000,5000,2000,1000,500,200],  coins:[100,50],                   coin_name:'Senti',      coin_decimals:0 },
  XOF: { notes:[10000,5000,2000,1000,500,200,100,50], coins:[25,10,5],            coin_name:'Centimes',   coin_decimals:0 },
  XAF: { notes:[10000,5000,2000,1000,500,200,100,50], coins:[25,10,5],            coin_name:'Centimes',   coin_decimals:0 },
  EGP: { notes:[200,100,50,20,10,5],            coins:[1,0.50,0.25,0.10,0.05],   coin_name:'Piastres',   coin_decimals:2 },
  MAD: { notes:[200,100,50,20,10,5],            coins:[1,0.50,0.20,0.10,0.05],   coin_name:'Centimes',   coin_decimals:2 },
  ETB: { notes:[1000,500,200,100,50,10,5],      coins:[1,0.50,0.25,0.10,0.05],   coin_name:'Santim',     coin_decimals:2 },
  ZMW: { notes:[500,100,50,20,10,5],            coins:[2,1,0.50,0.10,0.05],      coin_name:'Ngwe',       coin_decimals:2 },
  RWF: { notes:[5000,2000,1000,500,200,100],    coins:[],                         coin_name:'',           coin_decimals:0 },
  MWK: { notes:[5000,2000,1000,500,200,100,50], coins:[],                         coin_name:'',           coin_decimals:0 },
  MZN: { notes:[1000,500,200,100,50,20,10],     coins:[5,2,1,0.50,0.20,0.10],    coin_name:'Centavos',   coin_decimals:2 },
  SZL: { notes:[200,100,50,20,10,5],            coins:[2,1,0.50,0.20,0.10,0.05], coin_name:'Cents',      coin_decimals:2 },
  NAD: { notes:[200,100,50,20,10,5],            coins:[2,1,0.50,0.20,0.10,0.05], coin_name:'Cents',      coin_decimals:2 },
  _fallback: { notes:[1000,500,200,100,50,20,10,5], coins:[], coin_name:'', coin_decimals:0 },
};

function normCcyCode(raw) {
  const m = (raw || '').toUpperCase().trim().match(/^([A-Z]{3})/);
  return m ? m[1] : '';
}

// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// computeDenomMix  вЂ” auto-scale GCP engine
// Returns: { noteItems, coinItems, totalNotes, totalCoins, layerSums, ccy, profile }
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
function computeDenomMix(total, currencyCode) {
  const ccy     = normCcyCode(currencyCode);
  const profile = CURRENCY_PROFILES[ccy] || CURRENCY_PROFILES._fallback;
  const notes   = profile.notes;  // already sorted high в†’ low
  const coins   = profile.coins;  // fractional, high в†’ low

  // Auto-scale: position-based layer assignment
  const bulkNotes  = notes.slice(0, 2);
  const tradeNotes = notes.slice(2, 5);
  const microNotes = notes.slice(5);

  // Round total to nearest coin (fractional precision)
  const minUnit  = coins.length > 0 ? coins[coins.length - 1] : 1;
  const rounded  = Math.round(total / minUnit) * minUnit;

  const bulkTarget  = Math.round(rounded * 0.60);
  const tradeTarget = Math.round(rounded * 0.30);
  const microTarget = rounded - bulkTarget - tradeTarget;

  const noteItems = [];

  function greedyFill(denomArr, budget, layerKey) {
    let rem = budget;
    for (const face of denomArr) {
      if (rem < face) continue;
      const cnt = Math.floor(rem / face);
      if (cnt > 0) {
        noteItems.push({ face, layer: layerKey, count: cnt, subtotal: cnt * face });
        rem -= cnt * face;
      }
    }
    return rem; // unspent
  }

  let rem = greedyFill(bulkNotes,  bulkTarget,  'bulk');
      rem += greedyFill(tradeNotes, tradeTarget, 'transactional');
      rem += greedyFill(microNotes, microTarget, 'micro');

  // Cascade any note-level remainder to smallest available note
  if (rem > 0) {
    const fallbackNote = [...notes].reverse().find(f => f <= rem);
    if (fallbackNote) {
      const cnt = Math.floor(rem / fallbackNote);
      if (cnt > 0) {
        const ex = noteItems.find(i => i.face === fallbackNote);
        if (ex) { ex.count += cnt; ex.subtotal += cnt * fallbackNote; }
        else noteItems.push({ face: fallbackNote, layer: 'micro', count: cnt, subtotal: cnt * fallbackNote });
        rem -= cnt * fallbackNote;
      }
    }
  }

  // Fill residual with fractional coins
  const coinItems = [];
  if (coins.length > 0 && rem > 0) {
    for (const face of coins) {
      if (rem < face - 0.0001) continue;
      const cnt = Math.floor((rem + 0.0001) / face);
      if (cnt > 0) {
        coinItems.push({ face, layer: 'coins', count: cnt, subtotal: +(cnt * face).toFixed(4) });
        rem = +(rem - cnt * face).toFixed(4);
      }
    }
  }

  // Layer sums
  const layerSums = { bulk: 0, transactional: 0, micro: 0, coins: 0 };
  noteItems.forEach(i => { layerSums[i.layer] = +(layerSums[i.layer] + i.subtotal).toFixed(4); });
  coinItems.forEach(i => { layerSums.coins    = +(layerSums.coins    + i.subtotal).toFixed(4); });

  const totalNotes = noteItems.reduce((s, i) => s + i.count, 0);
  const totalCoins = coinItems.reduce((s, i) => s + i.count, 0);

  return { noteItems, coinItems, totalNotes, totalCoins, layerSums, ccy, profile, rounded };
}

function denomFmtNum(n, decimals) {
  return n.toLocaleString('en-US', {
    minimumFractionDigits:  decimals ?? 0,
    maximumFractionDigits:  decimals ?? 0
  });
}

function renderDenomMixPanel() {
  const panel = document.getElementById('denomMixPanel');
  const total = getNumericAmount();
  const ccy   = document.getElementById('tc_currency_code')?.value || '';

  if (!total || total <= 0) { panel.style.display = 'none'; return; }

  const mix  = computeDenomMix(total, ccy);
  const p    = mix.profile;
  const sym  = ccy ? ccy + ' ' : '';
  const dec  = p.coin_decimals || 0;

  panel.style.display = 'block';

  // Header currency label
  document.getElementById('denomMixCurrencyLabel').textContent =
    ccy ? `${ccy} Currency Profile` : 'Standard Liquidity';

  // Total pill
  const pillParts = [`${denomFmtNum(mix.totalNotes)} notes`];
  if (mix.totalCoins > 0)
    pillParts.push(`${denomFmtNum(mix.totalCoins)} ${p.coin_name || 'coins'}`);
  document.getElementById('denomMixTotalNotes').textContent = pillParts.join(' + ');

  // Layer amount spans
  document.getElementById('denomMixBulkAmt').textContent  = sym + denomFmtNum(mix.layerSums.bulk || 0);
  document.getElementById('denomMixTradeAmt').textContent = sym + denomFmtNum(mix.layerSums.transactional || 0);
  document.getElementById('denomMixMicroAmt').textContent = sym + denomFmtNum(mix.layerSums.micro || 0);

  // Coin row
  const coinRow = document.getElementById('denomMixCoinRow');
  if (mix.totalCoins > 0 && p.coin_name) {
    coinRow.style.display = 'flex';
    document.getElementById('denomMixCoinLabel').textContent =
      `Digital ${p.coin_name}`;
    const coinPct = Math.round((mix.layerSums.coins / mix.rounded) * 100);
    document.getElementById('denomMixCoinBar').style.width = Math.max(coinPct, 2) + '%';
    document.getElementById('denomMixCoinAmt').textContent =
      sym + denomFmtNum(mix.layerSums.coins, dec);
  } else {
    coinRow.style.display = 'none';
  }

  // Breakdown table
  const layerColor = { bulk:'#10b981', transactional:'#3b82f6', micro:'#f59e0b', coins:'#8b5cf6' };
  const layerLabel = { bulk:'рџџұ Bulk', transactional:'рџ”µ Trade', micro:'рџџҰ Micro', coins:'рџҒ™ Coin' };

  const allItems = [
    ...mix.noteItems,
    ...mix.coinItems
  ];

  document.getElementById('denomMixTable').innerHTML =
    `<table style="width:100%; border-collapse:collapse; font-size:11px;">
      <thead>
        <tr style="color:#6b7280; border-bottom:1px solid #d1fae5;">
          <th style="text-align:left;padding:4px 0;font-weight:600;">Denomination</th>
          <th style="text-align:center;padding:4px 0;font-weight:600;">Layer</th>
          <th style="text-align:right;padding:4px 0;font-weight:600;">Count</th>
          <th style="text-align:right;padding:4px 0;font-weight:600;">Subtotal</th>
        </tr>
      </thead>
      <tbody>
        ${allItems.map(i => {
          const isCoin = i.layer === 'coins';
          const faceStr = isCoin
            ? sym + denomFmtNum(i.face, dec) + (p.coin_name ? ` ${p.coin_name.slice(0,-1)}` : '')
            : sym + denomFmtNum(i.face);
          return `<tr style="border-bottom:1px solid #f0fdf4;">
            <td style="padding:3px 0;font-weight:700;color:${isCoin ? '#5b21b6' : '#065f46'};">${faceStr}</td>
            <td style="padding:3px 0;text-align:center;color:${layerColor[i.layer]};font-weight:600;font-size:10px;">${layerLabel[i.layer]}</td>
            <td style="padding:3px 0;text-align:right;color:#374151;">Г— ${denomFmtNum(i.count)}</td>
            <td style="padding:3px 0;text-align:right;font-weight:700;color:${isCoin ? '#5b21b6' : '#065f46'};">${sym}${denomFmtNum(i.subtotal, dec)}</td>
          </tr>`;
        }).join('')}
      </tbody>
    </table>`;
}

// Re-used by confirm + success modals
function getCurrentDenomMix() {
  const total = getNumericAmount();
  const ccy   = document.getElementById('tc_currency_code')?.value || '';
  return total > 0 ? computeDenomMix(total, ccy) : null;
}

function getNumericAmount() {
  const amountStr = document.getElementById('tc_amount').value;
  return parseFloat(amountStr.replace(/,/g, '')) || 0;
}

function showError(message) {
