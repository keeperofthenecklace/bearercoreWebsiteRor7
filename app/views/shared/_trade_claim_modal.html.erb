//  Actual API submission вЂ” called only after user confirms
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

async function confirmAndSubmitTradeClaim() {
  cancelTradeClaimConfirm();

  const submitBtn   = document.getElementById('submitClaimBtn');
  const originalText = submitBtn.textContent;

  const payload = {
    trade_claim: {
      institution_id:      selectedInstitution ? selectedInstitution.id : document.getElementById('tc_institution_id').value,
      corridor_id:         document.getElementById('tc_corridor_id').value,
      trade_direction:     document.getElementById('tc_trade_direction').value,
      currency_code:       document.getElementById('tc_currency_code').value,
      amount:              getNumericAmount(),
      invoice_ref:         document.getElementById('tc_invoice_ref').value,
      // Holder IDs вЂ” CVIB note ownership roles
      // central_bank_holder_id  в†’ Qt6 "Initial Holder" (issuing central bank)
      // commercial_bank_holder_id в†’ Qt6 "Holder ID"    (receiving commercial bank)
      central_bank_holder_id:   document.getElementById('tc_central_bank_holder_id')?.value || '',
      commercial_bank_holder_id: document.getElementById('tc_commercial_bank_holder_id')?.value || '',
      description:         document.getElementById('tc_description').value,
      beneficiary_name:    document.getElementById('tc_beneficiary_name').value,
      beneficiary_country: document.getElementById('tc_beneficiary_country').value.toUpperCase(),
      document_hash:       documentHash,
      declarations: {
        trade_authenticity: true,
        aml_kyc_compliance: true
      }
    }
  };

  submitBtn.textContent = 'Submitting...';
  submitBtn.disabled    = true;

  try {
    // Step 1: Create the trade claim
    const response = await fetch('/api/v2/trade_claims', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${getAccessToken()}`,
        'Content-Type':  'application/json',
        'Accept':        'application/json'
      },
      body: JSON.stringify(payload)
    });

    const data = await response.json();

    if (!response.ok) {
      throw new Error(data.message || data.error || 'Submission failed');
    }

    // Step 2: Upload documents if any
    if (uploadedFiles.length > 0) {
      submitBtn.textContent = 'Uploading documents...';
      await uploadDocuments(data.id);
    }

    // Advance session invoice sequence so next modal open gets the next number
    const submittedRef = document.getElementById('tc_invoice_ref')?.value || '';
    if (submittedRef) {
      const parts = submittedRef.split('-');  // ["INV","2026","080","001"]
      if (parts.length === 4) {
        const usedPrefix = `${parts[0]}-${parts[1]}-${parts[2]}-`;
        const usedSeq    = parseInt(parts[3], 10);
        if (!isNaN(usedSeq))
          _invoiceSeqCache[usedPrefix] = Math.max(_invoiceSeqCache[usedPrefix] || 0, usedSeq);
      }
    }

    // Show success modal
    showSuccessModal(data);
    hideTradeClaimModal();

  } catch (error) {
    console.error('Submission error:', error);
    showError(error.message);
  } finally {
    submitBtn.textContent = originalText;
    submitBtn.disabled    = false;
  }
}

