// SUCCESS MODAL
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

// Country code to name mapping for display
const countryCodeToName = {
  'KEN': 'Kenyan', 'NGA': 'Nigerian', 'GHA': 'Ghanaian', 'ZAF': 'South African',
  'TZA': 'Tanzanian', 'UGA': 'Ugandan', 'RWA': 'Rwandan', 'ETH': 'Ethiopian',
  'EGY': 'Egyptian', 'MAR': 'Moroccan', 'DZA': 'Algerian', 'TUN': 'Tunisian',
  'BWA': 'Botswanan', 'ZMB': 'Zambian', 'ZWE': 'Zimbabwean', 'MOZ': 'Mozambican',
  'SEN': 'Senegalese', 'CIV': 'Ivorian', 'CMR': 'Cameroonian', 'COD': 'Congolese',
};

function showSuccessModal(data) {
  const modal = document.getElementById('tradeClaimSuccessModal');
  
  // Get form values for display
  const currencyCode = document.getElementById('tc_currency_code').value;
  const amount = document.getElementById('tc_amount').value;
  const direction = document.getElementById('tc_trade_direction').value;
  const beneficiaryName = document.getElementById('tc_beneficiary_name').value;
  const beneficiaryCountry = document.getElementById('tc_beneficiary_country').value;
  const institutionName = selectedInstitution ? selectedInstitution.name : 'Institution';
  
  // Determine regulator country from the corridor target
  const corridorId = document.getElementById('tc_corridor_id').value;
  const corridor = corridorsData.find(c => String(c.id) === String(corridorId));
  const targetCountry = corridor ? (corridor.to_country || corridor.target_country || '') : '';
  const regulatorName = countryCodeToName[targetCountry] || targetCountry;
  
  // Generate reference from ID or use provided reference
  // Format: TC-YYYYMMDD-XXXXXX (last 6 chars of UUID)
  let reference = data.reference;
  if (!reference && data.id) {
    const today = new Date();
    const dateStr = today.getFullYear().toString() + 
                    String(today.getMonth() + 1).padStart(2, '0') + 
                    String(today.getDate()).padStart(2, '0');
    const idSuffix = String(data.id).replace(/-/g, '').slice(-6).toUpperCase();
    reference = `TC-${dateStr}-${idSuffix}`;
  }
  
  // Update modal content
  document.getElementById('successClaimId').textContent = reference || `TC-${Date.now()}`;
  document.getElementById('successRegulator').textContent = `${regulatorName} regulators`;
  document.getElementById('successRegulator2').textContent = `${regulatorName} regulators`;
  document.getElementById('successAmount').textContent = `${currencyCode} ${amount}`;
  
  // Format direction
  const directionText = direction === 'import' 
    ? `Import into ${countryCodeToName[beneficiaryCountry] || beneficiaryCountry}` 
    : `Export from ${countryCodeToName[selectedCountry?.code] || 'origin'}`;
  document.getElementById('successDirection').textContent = directionText;
  
  // Format beneficiary with institution
  const beneficiaryFlag = countryFlags[beneficiaryCountry] || 'рџЏ¦';
  document.getElementById('successBeneficiary').innerHTML = `${beneficiaryName} ${beneficiaryFlag} ${institutionName.split(' ').slice(0,2).join(' ')}`;

  // Denomination mix
  const successMix = getCurrentDenomMix();
  const notesMintedEl  = document.getElementById('successNotesMinted');
  const breakdownEl    = document.getElementById('successDenomBreakdown');
  const denomTableEl   = document.getElementById('successDenomTable');
  if (successMix && successMix.totalNotes > 0) {
    const sParts = [`${denomFmtNum(successMix.totalNotes)} notes`];
    if (successMix.totalCoins > 0)
      sParts.push(`${denomFmtNum(successMix.totalCoins)} ${successMix.profile.coin_name || 'coins'}`);
    notesMintedEl.textContent = sParts.join(' + ');
    breakdownEl.style.display = 'block';
    const sym = currencyCode ? currencyCode + ' ' : '';
    const dec = successMix.profile.coin_decimals || 0;
    const layerColor = { bulk:'#10b981', transactional:'#3b82f6', micro:'#f59e0b', coins:'#8b5cf6' };
    const layerLabel = { bulk:'рџџұ Bulk', transactional:'рџ”µ Trade', micro:'рџџҰ Micro', coins:'рџҒ™ Coin' };
    const allSuccessItems = [...(successMix.noteItems || []), ...(successMix.coinItems || [])];
    denomTableEl.innerHTML =
      `<table style="width:100%; border-collapse:collapse; font-size:11px;">
        <thead><tr style="color:#6b7280; border-bottom:1px solid #d1fae5;">
          <th style="text-align:left;padding:3px 0;font-weight:600;">Denomination</th>
          <th style="text-align:center;padding:3px 0;font-weight:600;">Layer</th>
          <th style="text-align:right;padding:3px 0;font-weight:600;">Count</th>
          <th style="text-align:right;padding:3px 0;font-weight:600;">Subtotal</th>
        </tr></thead>
        <tbody>
          ${allSuccessItems.map(i => {
            const isCoin = i.layer === 'coins';
            const faceStr = sym + denomFmtNum(i.face, isCoin ? dec : 0);
            return `<tr style="border-bottom:1px solid #f0fdf4;">
              <td style="padding:3px 0;font-weight:700;color:${isCoin ? '#5b21b6' : '#065f46'};">${faceStr}</td>
              <td style="padding:3px 0;text-align:center;font-size:10px;color:${layerColor[i.layer]};font-weight:600;">${layerLabel[i.layer]}</td>
              <td style="padding:3px 0;text-align:right;color:#374151;">Г— ${denomFmtNum(i.count)}</td>
              <td style="padding:3px 0;text-align:right;font-weight:700;color:${isCoin ? '#5b21b6' : '#065f46'};">${sym}${denomFmtNum(i.subtotal, isCoin ? dec : 0)}</td>
            </tr>`;
          }).join('')}
        </tbody>
      </table>`;
  } else {
    notesMintedEl.textContent = 'вЂ”';
    breakdownEl.style.display = 'none';
  }

  // Show modal
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeSuccessModal() {
  const modal = document.getElementById('tradeClaimSuccessModal');
  modal.style.display = 'none';
  document.body.style.overflow = '';
}

function closeSuccessAndGoToDesk() {
  closeSuccessModal();
  // Show the issuance desk modal
  if (typeof showIssuanceDeskModal === 'function') {
    showIssuanceDeskModal();
  } else {
    // Fallback to URL navigation if modal not available
    window.location.href = '/issuance/desk';
  }
}

function closeSuccessAndSubmitAnother() {
  closeSuccessModal();
  // Re-open the trade claim modal
  showTradeClaimModal();
}

// Close success modal when clicking outside
document.getElementById('tradeClaimSuccessModal')?.addEventListener('click', function(e) {
  if (e.target === this) {
    closeSuccessModal();
  }
});

