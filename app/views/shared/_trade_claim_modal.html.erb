// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
// CORRIDORS
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

async function loadCorridors() {
  const select = document.getElementById('tc_corridor_id');
  
  try {
    const response = await fetch('/api/v2/corridors', {
      headers: {
        'Authorization': `Bearer ${getAccessToken()}`,
        'Accept': 'application/json'
      }
    });
    
    if (!response.ok) throw new Error('Failed to load corridors');
    
    const raw = await response.json();
    // Unwrap common envelope shapes: { data: [...] } or { corridors: [...] } or plain array
    corridorsData = Array.isArray(raw)             ? raw
                 : Array.isArray(raw.data)          ? raw.data
                 : (raw.data && Array.isArray(raw.data.corridors)) ? raw.data.corridors
                 : Array.isArray(raw.corridors)     ? raw.corridors
                 : raw.results || [];

    console.log('[Corridors] Loaded', corridorsData.length, 'corridors');
    if (corridorsData.length > 0) {
      console.log('[Corridors] Sample fields:', Object.keys(corridorsData[0]));
    }

    // If user already selected a country before corridors finished loading, filter now
    if (selectedCountry) {
      filterCorridorsForCountry(selectedCountry);
    } else {
      select.innerHTML = '<option value="">Select Country first...</option>';
      select.disabled = true;
      select.style.background = '#f3f4f6';
      select.style.cursor = 'not-allowed';
    }

  } catch (error) {
    console.error('[Corridors] Error loading:', error);
    select.innerHTML = '<option value="">Error loading corridors</option>';
  }
}

// Filter corridors based on selected country
function filterCorridorsForCountry(country) {
  const select = document.getElementById('tc_corridor_id');

  if (!country) {
    select.innerHTML = '<option value="">Select Country first...</option>';
    select.disabled = true;
    select.style.background = '#f3f4f6';
    select.style.cursor = 'not-allowed';
    return;
  }

  // If corridors not loaded yet, wait вЂ” loadCorridors will call us again
  if (!corridorsData || corridorsData.length === 0) {
    select.innerHTML = '<option value="">Loading corridors...</option>';
    select.disabled = true;
    select.style.background = '#f3f4f6';
    select.style.cursor = 'not-allowed';
    console.log('[Corridors] Not loaded yet, will retry when loadCorridors completes');
    return;
  }

  // в”Ђв”Ђ Build identifier set for this country в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  const iso2to3 = {
    'DZ':'DZA','AO':'AGO','BJ':'BEN','BW':'BWA','BF':'BFA','BI':'BDI',
    'CV':'CPV','CM':'CMR','CF':'CAF','TD':'TCD','KM':'COM','CG':'COG',
    'CD':'COD','DJ':'DJI','EG':'EGY','GQ':'GNQ','ER':'ERI','SZ':'SWZ',
    'ET':'ETH','GA':'GAB','GM':'GMB','GH':'GHA','GN':'GIN','GW':'GNB',
    'CI':'CIV','KE':'KEN','LS':'LSO','LR':'LBR','LY':'LBY','MG':'MDG',
    'MW':'MWI','ML':'MLI','MR':'MRT','MU':'MUS','MA':'MAR','MZ':'MOZ',
    'NA':'NAM','NE':'NER','NG':'NGA','RW':'RWA','ST':'STP','SN':'SEN',
    'SC':'SYC','SL':'SLE','SO':'SOM','ZA':'ZAF','SS':'SSD','SD':'SDN',
    'TZ':'TZA','TG':'TGO','TN':'TUN','UG':'UGA','ZM':'ZMB','ZW':'ZWE'
  };
  const iso3to2 = Object.fromEntries(Object.entries(iso2to3).map(([k,v])=>[v,k]));
  const nameToAlpha3 = {
    'GHANA':'GHA','NIGERIA':'NGA','KENYA':'KEN','SOUTH AFRICA':'ZAF',
    'TANZANIA':'TZA','UGANDA':'UGA','RWANDA':'RWA','ETHIOPIA':'ETH',
    'EGYPT':'EGY','MOROCCO':'MAR','SENEGAL':'SEN','TOGO':'TGO',
    "COTE D'IVOIRE":'CIV',"CГ”TE D'IVOIRE":'CIV','IVORY COAST':'CIV',
    'ZAMBIA':'ZMB','ZIMBABWE':'ZWE','BOTSWANA':'BWA','CAMEROON':'CMR',
    'ANGOLA':'AGO','MOZAMBIQUE':'MOZ','NAMIBIA':'NAM','MALI':'MLI',
    'NIGER':'NER','BURKINA FASO':'BFA','GUINEA':'GIN','BENIN':'BEN',
    'SIERRA LEONE':'SLE','LIBERIA':'LBR','GAMBIA':'GMB','MALAWI':'MWI',
    'GUINEA-BISSAU':'GNB','EQUATORIAL GUINEA':'GNQ','GABON':'GAB',
    'REPUBLIC OF THE CONGO':'COG','DEMOCRATIC REPUBLIC OF THE CONGO':'COD',
    'MADAGASCAR':'MDG','MAURITIUS':'MUS','CAPE VERDE':'CPV',
    'DJIBOUTI':'DJI','SOMALIA':'SOM','ERITREA':'ERI','SUDAN':'SDN',
    'SOUTH SUDAN':'SSD','MAURITANIA':'MRT','COMOROS':'COM',
    'SAO TOME AND PRINCIPE':'STP','SEYCHELLES':'SYC','LESOTHO':'LSO',
    'ESWATINI':'SWZ','SWAZILAND':'SWZ','LIBYA':'LBY','ALGERIA':'DZA',
    'TUNISIA':'TUN','CHAD':'TCD','CENTRAL AFRICAN REPUBLIC':'CAF',
    'CONGO':'COG','DRC':'COD'
  };

  const ids = new Set();

  // Collect every possible code field
  [country.code, country.iso_code, country.country_code,
   country.alpha2, country.alpha3, country.iso2, country.iso3,
   country.cb_code, country.central_bank_code, country.iso_alpha2, country.iso_alpha3
  ].forEach(f => {
    if (!f) return;
    const v = f.toString().toUpperCase().trim();
    if (!v) return;
    ids.add(v);
    if (v.length === 2 && iso2to3[v]) ids.add(iso2to3[v]);
    if (v.length === 3 && iso3to2[v]) ids.add(iso3to2[v]);
  });

  // Name-based lookup вЂ” most reliable since country.name is always present
  const nameKey = (country.name || '').toUpperCase().trim();
  if (nameKey) {
    ids.add(nameKey);
    const a3 = nameToAlpha3[nameKey];
    if (a3) {
      ids.add(a3);
      if (iso3to2[a3]) ids.add(iso3to2[a3]);
    }
  }

  console.log('[Corridors] Filtering for:', country.name, '| ids:', [...ids]);

  // в”Ђв”Ђ Match corridors в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
  const filteredCorridors = corridorsData.filter(corridor => {
    // Every possible source field on a corridor object
    const srcRaw = [
      corridor.source_country, corridor.from_country,
      corridor.from_cb_code, corridor.source_cb_code,
      corridor.origin_country, corridor.from_iso, corridor.source_iso,
      corridor.source, corridor.from
    ].filter(Boolean).map(v => v.toString().toUpperCase().trim());

    // Expand src codes to both alpha-2 and alpha-3
    const srcSet = new Set(srcRaw);
    srcRaw.forEach(s => {
      if (s.length === 2 && iso2to3[s]) srcSet.add(iso2to3[s]);
      if (s.length === 3 && iso3to2[s]) srcSet.add(iso3to2[s]);
      // Name lookup
      const a3 = nameToAlpha3[s];
      if (a3) { srcSet.add(a3); if (iso3to2[a3]) srcSet.add(iso3to2[a3]); }
    });

    const tgtRaw = [
      corridor.target_country, corridor.to_country,
      corridor.to_cb_code, corridor.target_cb_code,
      corridor.destination_country, corridor.to_iso, corridor.target_iso,
      corridor.target, corridor.to
    ].filter(Boolean).map(v => v.toString().toUpperCase().trim());

    const tgtSet = new Set(tgtRaw);
    tgtRaw.forEach(t => {
      if (t.length === 2 && iso2to3[t]) tgtSet.add(iso2to3[t]);
      if (t.length === 3 && iso3to2[t]) tgtSet.add(iso3to2[t]);
    });

    const isSource = [...ids].some(id => srcSet.has(id));
    return isSource; // include same-country (domestic) corridors
  });

  console.log('[Corridors] Matched', filteredCorridors.length, 'of', corridorsData.length);
  if (filteredCorridors.length === 0 && corridorsData.length > 0) {
    console.warn('[Corridors] ZERO MATCH вЂ” country obj:', JSON.stringify(country));
    console.warn('[Corridors] First corridor:', JSON.stringify(corridorsData[0]));
  }

  // Populate the select with filtered corridor options
  if (filteredCorridors.length === 0) {
    select.innerHTML = '<option value="">No corridors available for this country</option>';
    select.disabled = true;
    select.style.background = '#f3f4f6';
    select.style.cursor = 'not-allowed';
    return;
  }

  // Helper: resolve flag emoji for a raw country code or name string
  function getCorridorFlag(codeOrName) {
    if (!codeOrName) return 'рџЊҚ';
    const v = codeOrName.toString().trim();
    return countryFlags[v] || countryFlags[v.toUpperCase()] || 'рџЊҚ';
  }

  // Build entries вЂ” domestic (GHAв†’GHA) pinned first, cross-border sorted by target code.
  // Add both source and target flags: рџ‡¬рџ‡­ GHA в†’ рџ‡°рџ‡Ғ KEN
  const domesticEntries = [];
  const crossBorderEntries = [];

  // Determine source country code from the first corridor's source field (all share the same source)
  const sourceCode = (filteredCorridors[0]
    ? (filteredCorridors[0].source_country || filteredCorridors[0].from_country || filteredCorridors[0].from || '')
    : '').toString().trim().toUpperCase();

  // Check whether a domestic corridor record already exists
  const hasDomesticRecord = filteredCorridors.some(function(corridor) {
    const from = (corridor.source_country || corridor.from_country || corridor.from || '').toString().trim().toUpperCase();
    const to   = (corridor.target_country || corridor.to_country   || corridor.to   || '').toString().trim().toUpperCase();
    return from && to && (from === to ||
      (from.length === 2 && iso2to3[from] && iso2to3[from] === to) ||
      (to.length   === 2 && iso2to3[to]   && iso2to3[to]   === from));
  });

  // If no domestic corridor record exists, synthesise a placeholder so the user always sees it.
  // value="__domestic__" is handled in onCorridorChange to set asset_type=domestic client-side.
  if (!hasDomesticRecord && sourceCode) {
    const srcFlag = getCorridorFlag(sourceCode);
    domesticEntries.push({
      id: '__domestic__',
      displayLabel: srcFlag + ' ' + sourceCode + ' в†’ ' + srcFlag + ' ' + sourceCode + ' (Domestic CBDC)',
      sortKey: ''
    });
  }

  filteredCorridors.forEach(function(corridor) {
    const from     = (corridor.source_country || corridor.from_country || corridor.from || '').toString().trim().toUpperCase();
    const to       = (corridor.target_country || corridor.to_country   || corridor.to   || '').toString().trim().toUpperCase();
    const fromFlag = getCorridorFlag(from);
    const toFlag   = getCorridorFlag(to);

    const isDomestic = from && to && (from === to ||
      (from.length === 2 && iso2to3[from] && iso2to3[from] === to) ||
      (to.length   === 2 && iso2to3[to]   && iso2to3[to]   === from));

    if (isDomestic) {
      domesticEntries.push({
        id: corridor.id,
        displayLabel: fromFlag + ' ' + from + ' в†’ ' + fromFlag + ' ' + from + ' (Domestic CBDC)',
        sortKey: ''
      });
    } else {
      crossBorderEntries.push({
        id: corridor.id,
        displayLabel: fromFlag + ' ' + from + ' в†’ ' + toFlag + ' ' + to,
        sortKey: to
      });
    }
  });

  // Synthesise virtual corridors for every African AU member state not already
  // covered by a real DB record.  id = '__virtual__ALPHA3' is parsed in onCorridorChange.
  var ALL_AFRICAN_AU_ALPHA3 = [
    'DZA','AGO','BEN','BWA','BFA','BDI','CMR','CPV','CAF','TCD','COM','COG','COD',
    'CIV','DJI','EGY','GNQ','ERI','SWZ','ETH','GAB','GMB','GHA','GIN','GNB','KEN',
    'LSO','LBR','LBY','MDG','MWI','MLI','MRT','MUS','MAR','MOZ','NAM','NER','NGA',
    'RWA','STP','SEN','SYC','SLE','SOM','ZAF','SSD','SDN','TZA','TGO','TUN','UGA',
    'ZMB','ZWE'
  ];
  var srcAlpha3 = (sourceCode.length === 2 ? (iso2to3[sourceCode] || sourceCode) : sourceCode);
  var coveredTargets = new Set();
  filteredCorridors.forEach(function(c) {
    var to = (c.target_country || c.to_country || c.to || '').toString().trim().toUpperCase();
    if (to) {
      coveredTargets.add(to);
      if (to.length === 3 && iso3to2[to]) coveredTargets.add(iso3to2[to]);
      if (to.length === 2 && iso2to3[to]) coveredTargets.add(iso2to3[to]);
    }
  });
  ALL_AFRICAN_AU_ALPHA3
    .filter(function(destCode) {
      return destCode !== srcAlpha3 &&
             !coveredTargets.has(destCode) &&
             !coveredTargets.has(iso3to2[destCode] || '');
    })
    .forEach(function(destCode) {
      crossBorderEntries.push({
        id: '__virtual__' + srcAlpha3 + '__' + destCode,
        displayLabel: getCorridorFlag(srcAlpha3) + ' ' + srcAlpha3 + ' в†’ ' +
                      getCorridorFlag(destCode) + ' ' + destCode,
        sortKey: destCode
      });
    });

  crossBorderEntries.sort(function(a, b) { return a.sortKey.localeCompare(b.sortKey); });

  const allEntries = domesticEntries.concat(crossBorderEntries);

  select.innerHTML = '<option value="">Select Trade Corridor...</option>' +
    allEntries.map(function(e) {
      return '<option value="' + e.id + '">' + e.displayLabel + '</option>';
    }).join('');

  // Enable dropdown
  select.disabled = false;
  select.style.background = 'white';
  select.style.cursor = 'pointer';
}

