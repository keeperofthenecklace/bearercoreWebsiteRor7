// CENTRAL BANK & DESTINATION INSTITUTION HELPERS
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

// Fetch and display the central bank name for the selected claiming country.
// Uses /api/v2/countries/by_iso3166?code=XXX which returns a `central_bank`
// field directly from the Bank model вЂ” the same source the Qt app uses.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Holder ID Resolution
//
// HolderKeys are registered in the SmartCheq system via POST /holder_ids.
// Each has a holder_id (HMAC-SHA256 hex), recipient_public_key, and name.
//
// GET /api/v2/holder_keys returns the full list.
// We match by name substring to find the correct entity.
//
// central_bank_holder_id  в†’ Qt6 "Initial Holder" (issuing central bank)
// commercial_bank_holder_id в†’ Qt6 "Holder ID"    (receiving commercial bank)
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

let _holderKeyCache = null;  // cached once per page session

async function fetchAllHolderKeys() {
  if (_holderKeyCache) return _holderKeyCache;
  try {
    const token   = getAccessToken();  // uses same token as all other modal API calls
    const headers = { 'Accept': 'application/json' };
    if (token) headers['Authorization'] = `Bearer ${token}`;

    const res  = await fetch('/api/v2/holder_keys', { headers });
    if (!res.ok) {
      console.warn('[fetchAllHolderKeys] HTTP', res.status, 'вЂ” holder ID resolution unavailable');
      return [];
    }
    const data = await res.json();
    _holderKeyCache = Array.isArray(data)              ? data
                   : Array.isArray(data.data)           ? data.data
                   : Array.isArray(data.holder_keys)    ? data.holder_keys
                   : [];
    console.log('[fetchAllHolderKeys] loaded', _holderKeyCache.length, 'holder keys');
    return _holderKeyCache;
  } catch (e) {
    console.warn('[fetchAllHolderKeys] error:', e.message);
    return [];
  }
}

// Normalize a bank name for fuzzy matching:
// removes legal suffixes (PLC, LTD, LIMITED, INC, SA, NV, etc.) and
// collapses whitespace so "ABSA BANK KENYA PLC" matches "ABSA BANK KENYA LIMITED"
function normalizeBankName(name) {
  return (name || '')
    .toUpperCase()
    .replace(/\b(PLC|LTD|LIMITED|INC|S\.A\.|SA|NV|AG|CORP|CORPORATION|CO\.|COMPANY|BANK|PVT|PRIVATE)\b/g, '')
    .replace(/[^A-Z0-9]+/g, ' ')
    .trim();
}

// Find a holder key whose name matches a bank name.
// Uses a 4-tier priority: exact в†’ normalized exact в†’ contains в†’ token overlap
// Returns { holder_id, name } or null.
async function findHolderKey(nameHint, swiftHint) {
  const keys = await fetchAllHolderKeys();
  if (!keys.length) return null;

  const nameUpper = (nameHint  || '').toUpperCase().trim();
  const nameNorm  = normalizeBankName(nameHint);

  if (!nameUpper) return null;

  // Priority 1: exact name match (case-insensitive)
  let match = keys.find(k => (k.name || '').toUpperCase().trim() === nameUpper);
  if (match) return match;

  // Priority 2: normalized name exact match (strips PLC/LTD/etc.)
  match = keys.find(k => normalizeBankName(k.name) === nameNorm && nameNorm.length > 3);
  if (match) return match;

  // Priority 3: one name contains the other
  match = keys.find(k => {
    const kUpper = (k.name || '').toUpperCase().trim();
    return (kUpper.includes(nameUpper) || nameUpper.includes(kUpper)) && kUpper.length > 5;
  });
  if (match) return match;

  // Priority 4: normalized token overlap (в‰Ө 2 significant words in common)
  const nameTokens = nameNorm.split(' ').filter(t => t.length > 2);
  match = keys.find(k => {
    const kTokens = normalizeBankName(k.name).split(' ').filter(t => t.length > 2);
    const common  = nameTokens.filter(t => kTokens.includes(t));
    return common.length >= 2;
  });
  if (match) return match;

  console.log('[findHolderKey] no match for:', nameHint, 'в†’ normalized:', nameNorm);
  return null;
}

// Called when user selects a CB SWIFT from the combobox.
// Updates the Central Bank Holder ID hidden + display fields from the
// holder_id stored on the selected <option> element (set by loadCentralBankForCountry).
// Falls back to findHolderKey() name search if no holder_id on the option.
async function applyCentralBankSwiftSelection(swiftCode, holderId) {
  const hiddenField  = document.getElementById('tc_central_bank_holder_id');
  const displayField = document.getElementById('tc_central_bank_holder_id_display');
  const statusIcon   = document.getElementById('cbHolderIdStatus');
  const row          = document.getElementById('cbHolderIdRow');

  if (!swiftCode) {
    // "Select SWIFT..." chosen вЂ” clear holder ID
    if (hiddenField)  hiddenField.value  = '';
    if (displayField) { displayField.value = ''; displayField.style.color = '#9ca3af'; }
    if (statusIcon)   statusIcon.textContent = '';
    return;
  }

  if (row) row.style.display = 'block';

  if (holderId) {
    // Use holder_id already attached to the option (from DB)
    if (hiddenField)  hiddenField.value  = holderId;
    if (displayField) { displayField.value = holderId; displayField.style.color = '#374151'; }
    if (statusIcon)   statusIcon.textContent = 'вњ…';
    console.log('[applyCentralBankSwiftSelection]', swiftCode, 'в†’', holderId.substring(0,16) + '...');
  } else {
    // No holder_id from DB вЂ” try name-based lookup as fallback
    if (displayField) { displayField.value = ''; displayField.placeholder = 'ResolvingвЂ¦'; }
    if (statusIcon)   statusIcon.textContent = 'вЏі';
    const cbNameField = document.getElementById('tc_central_bank_name');
    const cbName      = cbNameField ? cbNameField.value : '';
    if (cbName) {
      const key = await findHolderKey(cbName, null);
      if (hiddenField)  hiddenField.value = key ? key.holder_id : '';
      if (displayField) {
        displayField.value       = key ? key.holder_id : '';
        displayField.placeholder = key ? '' : 'Not registered вЂ” Qt6 will require manual selection';
        displayField.style.color = key ? '#374151' : '#ef4444';
      }
      if (statusIcon) statusIcon.textContent = key ? 'вњ…' : 'вљ пёЏ';
    } else {
      if (hiddenField)  hiddenField.value = '';
      if (displayField) { displayField.placeholder = 'Central bank not registered'; displayField.style.color = '#ef4444'; }
      if (statusIcon)   statusIcon.textContent = 'вљ пёЏ';
    }
  }
}

// Resolve and store the central bank holder ID for the selected country.
// Also updates the read-only display field + status icon in the UI.
async function resolveCentralBankHolderId(centralBankName) {
  const hiddenField  = document.getElementById('tc_central_bank_holder_id');
  const displayField = document.getElementById('tc_central_bank_holder_id_display');
  const statusIcon   = document.getElementById('cbHolderIdStatus');
  const row          = document.getElementById('cbHolderIdRow');

  const clear = () => {
    if (hiddenField)  hiddenField.value  = '';
    if (displayField) { displayField.value = ''; displayField.placeholder = 'Select a country...'; }
    if (statusIcon)   statusIcon.textContent = '';
    if (row)          row.style.display = 'none';
  };

  if (!centralBankName || centralBankName === 'вЂ”') { clear(); return; }

  // If a SWIFT was already selected and its holder_id was applied via
  // applyCentralBankSwiftSelection(), don't overwrite with a name-based lookup.
  if (hiddenField && hiddenField.value) return;

  if (row) row.style.display = 'block';
  if (displayField) { displayField.value = ''; displayField.placeholder = 'ResolvingвЂ¦'; }
  if (statusIcon) statusIcon.textContent = 'вЏі';

  const key = await findHolderKey(centralBankName, null);

  if (hiddenField)  hiddenField.value  = key ? key.holder_id : '';
  if (displayField) {
    displayField.value       = key ? key.holder_id : '';
    displayField.placeholder = key ? '' : 'Not registered вЂ” Qt6 will require manual selection';
    displayField.style.color = key ? '#374151' : '#ef4444';
  }
  if (statusIcon) statusIcon.textContent = key ? 'вњ…' : 'вљ пёЏ';

  console.log('[resolveCentralBankHolderId]', centralBankName, 'в†’',
              key ? key.holder_id.substring(0, 16) + '...' : 'NOT REGISTERED');
}

