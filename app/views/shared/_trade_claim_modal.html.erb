// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
// GLOBAL CURRENCY PROFILE (GCP) вЂ” Dynamic Denomination Mix Engine
//
// Auto-Scale Distribution:
//   Bulk  (60%) вЂ” top 2 banknotes by face value
//   Trade (30%) вЂ” next 3 banknotes
//   Micro (10%) вЂ” remaining banknotes + fractional coins
//
// Each profile: notes (highв†’low), coins (fractional sub-units, highв†’low),
//               coin_name (display label), coin_decimals (precision).
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

const CURRENCY_PROFILES = {
  GHS: { notes:[200,100,50,20,10,5,2,1],       coins:[0.50,0.20,0.10,0.05,0.01], coin_name:'Pesewas',    coin_decimals:2 },
