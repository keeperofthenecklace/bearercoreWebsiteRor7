//  Confirmation modal вЂ” show / hide
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ

function showTradeClaimConfirmModal() {
  // Populate summary fields
  const corridorSelect  = document.getElementById('tc_corridor_id');
  const corridorText    = corridorSelect.options[corridorSelect.selectedIndex]?.text || 'вЂ”';
  const directionSelect = document.getElementById('tc_trade_direction');
  const directionText   = directionSelect.options[directionSelect.selectedIndex]?.text
                          || document.getElementById('tc_trade_direction').value;
  const currency        = document.getElementById('tc_currency_code').value;
  const amount          = document.getElementById('tc_amount').value;
  const invoiceRef      = document.getElementById('tc_invoice_ref').value || 'вЂ”';
  const beneficiaryName = document.getElementById('tc_beneficiary_name').value;
  const beneficiaryCountry = document.getElementById('tc_beneficiary_country').value.toUpperCase();
  const beneficiaryFlag = (typeof countryFlags !== 'undefined' && countryFlags[beneficiaryCountry])
                          || 'рџЏіпёЏ';
  const institutionName = selectedInstitution ? selectedInstitution.name : 'вЂ”';

  document.getElementById('confirmAmount').textContent      = `${currency} ${amount}`;
  document.getElementById('confirmCorridor').textContent    = corridorText;
  document.getElementById('confirmInstitution').textContent = institutionName;
  document.getElementById('confirmBeneficiary').innerHTML   = `${beneficiaryName} ${beneficiaryFlag}`;
  document.getElementById('confirmInvoiceRef').textContent  = invoiceRef;
  document.getElementById('confirmDirection').textContent   = directionText;

  const confirmMix = getCurrentDenomMix();
  if (confirmMix) {
    const parts = [`${denomFmtNum(confirmMix.totalNotes)} notes`];
    if (confirmMix.totalCoins > 0)
      parts.push(`${denomFmtNum(confirmMix.totalCoins)} ${confirmMix.profile.coin_name || 'coins'}`);
    document.getElementById('confirmNotesMinted').textContent = parts.join(' + ');
  } else {
    document.getElementById('confirmNotesMinted').textContent = 'вЂ”';
  }

  document.getElementById('tradeClaimConfirmModal').style.display = 'flex';
}

function cancelTradeClaimConfirm() {
  document.getElementById('tradeClaimConfirmModal').style.display = 'none';
}

// Close confirmation modal when clicking the backdrop
document.getElementById('tradeClaimConfirmModal')?.addEventListener('click', function(e) {
  if (e.target === this) cancelTradeClaimConfirm();
});

