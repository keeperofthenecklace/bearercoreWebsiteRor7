// DRAFT SAVED MODAL
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

function showDraftSavedModal(data) {
  const modal = document.getElementById('draftSavedModal');
  
  // Get form values for display
  const currencyCode = document.getElementById('tc_currency_code').value || '-';
  const amount = document.getElementById('tc_amount').value || '0';
  const direction = document.getElementById('tc_trade_direction').value;
  const beneficiaryCountry = document.getElementById('tc_beneficiary_country').value;
  
  // Generate reference from ID or use provided reference
  let reference = data.reference;
  if (!reference && data.id) {
    reference = `TC-${data.id.toString().replace(/-/g, '').slice(0, 8).toUpperCase()}`;
  }
  
  // Update modal content
  document.getElementById('draftClaimId').textContent = reference || `TC-${Date.now()}`;
  document.getElementById('draftAmount').textContent = currencyCode !== '-' ? `${currencyCode} ${amount}` : '-';
  
  // Format direction
  const directionText = direction === 'import' 
    ? `Import into ${countryCodeToName[beneficiaryCountry] || beneficiaryCountry || '-'}` 
    : direction === 'export' 
      ? `Export from ${selectedCountry?.name || '-'}`
      : '-';
  document.getElementById('draftDirection').textContent = directionText;
  
  // Show modal
  modal.style.display = 'flex';
  document.body.style.overflow = 'hidden';
}

function closeDraftModal() {
  const modal = document.getElementById('draftSavedModal');
  modal.style.display = 'none';
  document.body.style.overflow = '';
}

function closeDraftModalAndGoToDrafts() {
  closeDraftModal();
  // Navigate to drafts page - adjust URL as needed
  window.location.href = '/trade_claims?status=draft';
}

function closeDraftModalAndContinueEditing() {
  closeDraftModal();
  // Re-open the trade claim modal to continue editing
  showTradeClaimModal();
}

// Close draft modal when clicking outside
document.getElementById('draftSavedModal')?.addEventListener('click', function(e) {
  if (e.target === this) {
    closeDraftModal();
  }
});
</script>
