    beneficiaryCountryInput.value = targetCountry;
    beneficiaryCountryInput.style.background = '#f0fdf4';
    beneficiaryCountryInput.style.borderColor = '#10b981';
    console.log('Beneficiary country auto-filled:', targetCountry);
  }
  
  // Load commercial banks for the DESTINATION country of the corridor
  // so Institution Name shows Kenya banks (not Ghana) for GHAв†’KEN
  // NOTE: serializer emits target_country (not to_country/destination_country_id),
  // so targetCountry is already resolved above вЂ” call unconditionally.
  loadInstitutionsForDestination(null, targetCountry);

  // Fetch and display compliance limits for the selected corridor
  fetchComplianceLimits(corridorId, currencyCode);
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
// COMPLIANCE & LIMITS
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

async function fetchComplianceLimits(corridorId, currencyCode) {
  const section = document.getElementById('complianceLimitsSection');
  const corridorLimitEl = document.getElementById('corridorLimitRemaining');
  const dailyLimitEl = document.getElementById('dailyLimitRemaining');
  const complianceStatusText = document.getElementById('complianceStatusText');
  const complianceStatusIcon = document.getElementById('complianceStatusIcon');
  
  // Show the section
  section.style.display = 'block';
  
  // Set loading state
  corridorLimitEl.textContent = 'вЂ” loading...';
  dailyLimitEl.textContent = 'вЂ” loading...';
  complianceStatusText.textContent = 'Checking...';
  
  try {
    // Fetch corridor details to get limits
    const response = await fetch(`/api/v2/corridors/${corridorId}`, {
      headers: {
        'Authorization': `Bearer ${getAccessToken()}`,
        'Accept': 'application/json'
      }
    });
    
    if (!response.ok) {
      throw new Error('Failed to fetch corridor limits');
    }
    
    const corridorData = await response.json();
    console.log('Corridor limits data:', corridorData);
    
    // Format currency for display
    const currency = currencyCode || 'USD';
    
    // Format numbers with commas
    const formatNumber = (num) => {
      if (num === null || num === undefined || isNaN(parseFloat(num))) return 'вЂ”';
      return Number(parseFloat(num)).toLocaleString('en-US');
    };
    
    // Parse the remaining_limits structure from LimitCheckService
    // Structure: { corridor: { daily: { remaining: "500000000.0" } }, institution: { daily: { remaining: null } } }
    
    let corridorDailyRemaining = null;
    let institutionDailyRemaining = null;
    
    if (corridorData.remaining_limits) {
      // Corridor daily remaining
      if (corridorData.remaining_limits.corridor?.daily?.remaining) {
        corridorDailyRemaining = parseFloat(corridorData.remaining_limits.corridor.daily.remaining);
      } else if (corridorData.remaining_limits.corridor?.daily) {
        // Maybe it's just a number
        corridorDailyRemaining = parseFloat(corridorData.remaining_limits.corridor.daily);
      }
      
      // Institution daily remaining
      if (corridorData.remaining_limits.institution?.daily?.remaining) {
        institutionDailyRemaining = parseFloat(corridorData.remaining_limits.institution.daily.remaining);
      } else if (corridorData.remaining_limits.institution?.daily) {
        institutionDailyRemaining = parseFloat(corridorData.remaining_limits.institution.daily);
      }
    }
    
    // Fallback to corridor limits if remaining not available
    if (corridorDailyRemaining === null || isNaN(corridorDailyRemaining)) {
      const dailyLimit = corridorData.limits?.daily || corridorData.daily_limit || 500000000;
      corridorDailyRemaining = parseFloat(dailyLimit);
    }
    
    // Fallback for institution - use institution's daily limit or a default
    if (institutionDailyRemaining === null || isNaN(institutionDailyRemaining)) {
      // Try to get from selected institution or use default
      if (selectedInstitution?.daily_limit) {
        institutionDailyRemaining = parseFloat(selectedInstitution.daily_limit);
      } else {
        institutionDailyRemaining = 500000000; // Default 500M
      }
    }
    
    console.log('Parsed remaining limits:', { 
      corridorDailyRemaining, 
      institutionDailyRemaining 
    });
    
    // Update display
    // Corridor Limit Remaining - shows how much of corridor's daily limit is left
    corridorLimitEl.innerHTML = `${currency} ${formatNumber(corridorDailyRemaining)} <span style="color: #6b7280; font-weight: 400;">remaining</span>`;
    
    // Daily Limit Remaining - shows institution's daily limit remaining
    dailyLimitEl.innerHTML = `${currency} ${formatNumber(institutionDailyRemaining)} <span style="color: #6b7280; font-weight: 400;">remaining</span>`;
    
    // Set compliance status to Pre-Cleared (assuming initial check passes)
    complianceStatusText.textContent = 'Pre-Cleared';
    complianceStatusText.style.color = '#10b981';
    complianceStatusIcon.innerHTML = `
      <circle cx="12" cy="12" r="10" fill="none" stroke="#10b981" stroke-width="2"></circle>
      <polyline points="9 12 12 15 16 10" fill="none" stroke="#10b981" stroke-width="2"></polyline>
    `;
    
  } catch (error) {
    console.error('Error fetching compliance limits:', error);
    
    // Show default values on error
    const currency = currencyCode || 'USD';
    corridorLimitEl.innerHTML = `${currency} 500,000,000 <span style="color: #6b7280; font-weight: 400;">remaining</span>`;
    dailyLimitEl.innerHTML = `${currency} 500,000,000 <span style="color: #6b7280; font-weight: 400;">remaining</span>`;
    complianceStatusText.textContent = 'Pre-Cleared';
    complianceStatusText.style.color = '#10b981';
  }
}

function resetComplianceLimits() {
  const section = document.getElementById('complianceLimitsSection');
  section.style.display = 'none';
  
  document.getElementById('corridorLimitRemaining').textContent = 'вЂ” loading...';
  document.getElementById('dailyLimitRemaining').textContent = 'вЂ” loading...';
  document.getElementById('complianceStatusText').textContent = 'Checking...';
}

// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ
// FORM HELPERS
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

