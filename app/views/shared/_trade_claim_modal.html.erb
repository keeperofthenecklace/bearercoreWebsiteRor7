// DOCUMENT UPLOAD
// в•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђв•ђ

let uploadedFiles = [];
let documentHash = null;

function handleDragOver(event) {
  event.preventDefault();
  event.stopPropagation();
  const uploadArea = document.getElementById('documentUploadArea');
  uploadArea.style.borderColor = '#059669';
  uploadArea.style.background = '#f0fdf4';
}

function handleDragLeave(event) {
  event.preventDefault();
  event.stopPropagation();
  const uploadArea = document.getElementById('documentUploadArea');
  uploadArea.style.borderColor = '#d1d5db';
  uploadArea.style.background = 'white';
}

function handleDrop(event) {
  event.preventDefault();
  event.stopPropagation();
  
  const uploadArea = document.getElementById('documentUploadArea');
  uploadArea.style.borderColor = '#d1d5db';
  uploadArea.style.background = 'white';
  
  const files = event.dataTransfer.files;
  handleFileSelect(files);
}

function handleFileSelect(files) {
  if (!files || files.length === 0) return;
  
  const validTypes = ['application/pdf', 'image/png', 'image/jpeg', 'image/jpg'];
  const maxSize = 10 * 1024 * 1024; // 10MB
  
  for (let i = 0; i < files.length; i++) {
    const file = files[i];
    
    // Validate type
    if (!validTypes.includes(file.type)) {
      showError(`Invalid file type: ${file.name}. Only PDF, PNG, and JPG are allowed.`);
      continue;
    }
    
    // Validate size
    if (file.size > maxSize) {
      showError(`File too large: ${file.name}. Maximum size is 10MB.`);
      continue;
    }
    
    // Check for duplicates
    if (uploadedFiles.some(f => f.name === file.name && f.size === file.size)) {
      continue;
    }
    
    uploadedFiles.push(file);
  }
  
  renderUploadedFiles();
  calculateDocumentHash();
}

function renderUploadedFiles() {
  const listContainer = document.getElementById('uploadedFilesList');
  const fileListContainer = document.getElementById('fileListContainer');
  const fileCount = document.getElementById('fileCount');
  
  if (uploadedFiles.length === 0) {
    listContainer.style.display = 'none';
    return;
  }
  
  listContainer.style.display = 'block';
  fileCount.textContent = `${uploadedFiles.length} file${uploadedFiles.length > 1 ? 's' : ''}`;
  
  fileListContainer.innerHTML = uploadedFiles.map((file, index) => {
    const icon = file.type === 'application/pdf' ? 'рџ“„' : 'рџ–әпёЏ';
    const size = formatFileSize(file.size);
    
    return `
      <div style="
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 10px 12px;
        background: white;
        border: 1px solid #e5e7eb;
        border-radius: 6px;
      ">
        <span style="font-size: 20px;">${icon}</span>
        <div style="flex: 1; min-width: 0;">
          <div style="font-size: 13px; font-weight: 500; color: #374151; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
            ${file.name}
          </div>
          <div style="font-size: 11px; color: #6b7280;">${size}</div>
        </div>
        <button type="button" onclick="removeFile(${index})" style="
          background: none;
          border: none;
          cursor: pointer;
          padding: 4px;
          color: #9ca3af;
          transition: color 0.2s;
        " onmouseover="this.style.color='#ef4444'" onmouseout="this.style.color='#9ca3af'">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18"></line>
            <line x1="6" y1="6" x2="18" y2="18"></line>
          </svg>
        </button>
      </div>
    `;
  }).join('');
}

function removeFile(index) {
  uploadedFiles.splice(index, 1);
  renderUploadedFiles();
  calculateDocumentHash();
  
  // Reset the file input
  document.getElementById('tc_documents').value = '';
}

function formatFileSize(bytes) {
  if (bytes < 1024) return bytes + ' B';
  if (bytes < 1024 * 1024) return (bytes / 1024).toFixed(1) + ' KB';
  return (bytes / (1024 * 1024)).toFixed(1) + ' MB';
}

async function calculateDocumentHash() {
  const hashContainer = document.getElementById('documentHashContainer');
  const hashValue = document.getElementById('documentHashValue');
  
  if (uploadedFiles.length === 0) {
    hashContainer.style.display = 'none';
    documentHash = null;
    return;
  }
  
  hashContainer.style.display = 'block';
  hashValue.textContent = 'Calculating...';
  
  try {
    // Calculate SHA-256 hash of all files combined
    const hashes = [];
    
    for (const file of uploadedFiles) {
      const buffer = await file.arrayBuffer();
      const hashBuffer = await crypto.subtle.digest('SHA-256', buffer);
      const hashArray = Array.from(new Uint8Array(hashBuffer));
      const hashHex = hashArray.map(b => b.toString(16).padStart(2, '0')).join('');
      hashes.push(hashHex);
    }
    
    // Combine all hashes and hash again
    const combinedHash = hashes.sort().join('');
    const encoder = new TextEncoder();
    const data = encoder.encode(combinedHash);
    const finalHashBuffer = await crypto.subtle.digest('SHA-256', data);
    const finalHashArray = Array.from(new Uint8Array(finalHashBuffer));
    documentHash = finalHashArray.map(b => b.toString(16).padStart(2, '0')).join('');
    
    // Display truncated hash
    hashValue.textContent = documentHash.substring(0, 16) + '...' + documentHash.substring(48);
    hashValue.title = documentHash;
    
  } catch (error) {
    console.error('Error calculating hash:', error);
    hashValue.textContent = 'Error calculating hash';
    documentHash = null;
  }
}

function copyDocumentHash() {
  if (!documentHash) return;
  
  navigator.clipboard.writeText(documentHash).then(() => {
    // Show brief feedback
    const btn = event.currentTarget;
    const originalColor = btn.style.color;
    btn.style.color = '#059669';
    setTimeout(() => { btn.style.color = originalColor; }, 1000);
  });
}

async function uploadDocuments(tradeClaimId) {
  if (uploadedFiles.length === 0) return true;
  
  const formData = new FormData();
  formData.append('trade_claim_id', tradeClaimId);
  
  uploadedFiles.forEach(file => {
    formData.append('documents[]', file);
  });
  
  try {
    const response = await fetch('/api/v2/documents', {
      method: 'POST',
      headers: {
        'Authorization': `Bearer ${getAccessToken()}`
      },
      body: formData
    });
    
    if (!response.ok) {
      const data = await response.json();
      throw new Error(data.message || 'Failed to upload documents');
    }
    
    return true;
  } catch (error) {
    console.error('Document upload error:', error);
    showError('Trade claim created but document upload failed: ' + error.message);
    return false;
  }
}

function resetDocumentUpload() {
  uploadedFiles = [];
  documentHash = null;
  document.getElementById('tc_documents').value = '';
  document.getElementById('uploadedFilesList').style.display = 'none';
  document.getElementById('documentHashContainer').style.display = 'none';
  document.getElementById('fileListContainer').innerHTML = '';
}

