async function loadCountries() {
  try {
    const response = await fetch('/api/v2/countries', {
      headers: {
        'Authorization': `Bearer ${getAccessToken()}`,
        'Accept': 'application/json'
      }
    });
    
    if (!response.ok) throw new Error('Failed to load countries');
    
    countriesData = await response.json();
    countriesData.sort((a, b) => (a.name || a.country_name || '').localeCompare(b.name || b.country_name || ''));
    renderCountryOptions(countriesData);
    
  } catch (error) {
    console.error('Error loading countries:', error);
    document.getElementById('countryOptions').innerHTML = 
      '<div class="dropdown-option" style="color: #dc2626;">Error loading countries</div>';
  }
}

function renderCountryOptions(countries) {
  const container = document.getElementById('countryOptions');
  countries = [...countries].sort((a, b) => (a.name || a.country_name || '').localeCompare(b.name || b.country_name || ''));
  
  if (countries.length === 0) {
    container.innerHTML = '<div class="dropdown-option" style="color: #6b7280;">No countries found</div>';
    return;
  }
  
  container.innerHTML = countries.map(country => {
    const flag = getCountryFlag(country);
    const name = country.name || country.code || `Country ${country.id}`;
    const isSelected = selectedCountry && selectedCountry.id === country.id;
    
    return `
      <div class="dropdown-option ${isSelected ? 'selected' : ''}" 
           onclick="selectCountry(${JSON.stringify(country).replace(/"/g, '&quot;')})">
        <span class="dropdown-flag">${flag}</span>
        <span>${name}</span>
      </div>
    `;
  }).join('');
}

function filterCountries(searchTerm) {
  const filtered = countriesData.filter(country => {
    const name = (country.name || country.code || '').toLowerCase();
    return name.includes(searchTerm.toLowerCase());
  });
  renderCountryOptions(filtered);
}

function selectCountry(country) {
  selectedCountry = country;
  
  const flag = getCountryFlag(country);
  const name = country.name || country.code || `Country ${country.id}`;
  
  document.getElementById('countrySelectedText').innerHTML = `
    <span class="dropdown-flag" style="font-size: 20px;">${flag}</span>
    <span>${name}</span>
  `;
  document.getElementById('tc_country_id').value = country.id;
  
  closeCountryDropdown();

  // Load central bank name for this country
  loadCentralBankForCountry(country);

  // Filter corridors based on selected country
  filterCorridorsForCountry(country);

  // Reset institution dropdown вЂ” now driven by corridor, not country
  resetInstitutionDropdown();

