// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
// Invoice Reference Auto-Generation
// Format: INV-YYYY-DDD-SSS
//   YYYY = current year
//   DDD  = zero-padded cumulative day of year (Jan 1 = 001, Dec 31 = 365/366)
//   SSS  = zero-padded sequence number for that day (001, 002, ...)
//
// Sequence is determined by querying the last trade claim created today
// (via GET /api/v2/trade_claims?created_today=true&per_page=1&sort=desc)
// and incrementing its sequence. Falls back to 001 on any error.
// в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
function dayOfYear(date) {
  const start = new Date(date.getFullYear(), 0, 0);
  const diff  = date - start + (start.getTimezoneOffset() - date.getTimezoneOffset()) * 60 * 1000;
  return Math.floor(diff / 86400000);
}

function formatInvoiceRef(year, doy, seq) {
  const d = String(doy).padStart(3, '0');
  const s = String(seq).padStart(3, '0');
  return `INV-${year}-${d}-${s}`;
}

// Session-level invoice sequence cache вЂ” persists across multiple modal opens
// within the same page session so even if the API misses one, we never go back.
const _invoiceSeqCache = {};

async function generateInvoiceRef() {
  const field = document.getElementById('tc_invoice_ref');
  if (!field) return;

  const now    = new Date();
  const year   = now.getFullYear();
  const doy    = dayOfYear(now);
  const prefix = `INV-${year}-${String(doy).padStart(3, '0')}-`;

  field.value = '';
  field.placeholder = 'GeneratingвЂ¦';

  // Start from our in-memory cache for this session (avoids going backwards)
  let maxSeq = _invoiceSeqCache[prefix] || 0;

  try {
    const scApiBase = window.SC_API_BASE || '';
    const token     = window.SC_API_TOKEN || '';
    const headers   = { 'Accept': 'application/json' };
    if (token) headers['Authorization'] = `Bearer ${token}`;

    // Strategy 1: fetch ALL trade claims created today, scan for highest sequence.
    // Use created_today=true or a date filter вЂ” fetch up to 200 to be safe.
    const todayISO = now.toISOString().slice(0, 10); // "2026-03-21"
    const url = `${scApiBase}/api/v2/trade_claims?created_after=${todayISO}&per_page=200`;

    const res = await fetch(url, { headers });
    if (res.ok) {
      const data  = await res.json();
      const list  = Array.isArray(data)             ? data
                  : Array.isArray(data.data)         ? data.data
                  : Array.isArray(data.trade_claims) ? data.trade_claims
                  : [];

      list.forEach(claim => {
        const ref = (claim.invoice_ref || claim.invoice_reference || '').trim();
        if (ref.startsWith(prefix)) {
          const seq = parseInt(ref.slice(prefix.length), 10);
          if (!isNaN(seq) && seq > maxSeq) maxSeq = seq;
        }
      });
    }
  } catch (e) {
    console.warn('[generateInvoiceRef] API fetch failed, using session cache:', e.message);
  }

  // Next sequence = highest found + 1 (minimum 1)
  const nextSeq = maxSeq + 1;

  // Update session cache so subsequent opens this session increment correctly
  _invoiceSeqCache[prefix] = nextSeq;

  field.value = formatInvoiceRef(year, doy, nextSeq);
  field.style.color = '#374151';
