async function loadCentralBankForCountry(country) {
  const field = document.getElementById('tc_central_bank_name');
  if (!field) return;

  // Resolve ISO3 code вЂ” try every field the country object may carry
  const iso3 = [
    country.alpha3, country.iso3, country.iso_alpha3,
    country.central_bank_code, country.cb_code
  ].map(v => (v || '').toString().trim().toUpperCase())
   .find(v => v.length === 3);

  // Fall back: try 2-letter code (iso2 в†’ expand via corridor iso2to3 map isn't available here,
  // but the by_iso3166 endpoint also accepts 2-letter codes)
  const code = iso3
    || (country.code || country.iso2 || country.alpha2 || '').toString().trim().toUpperCase();

  if (!code) { field.value = 'вЂ”'; return; }

  field.value = 'Loading...';
  field.style.color = '#9ca3af';

  // Last-resort fallback map вЂ” only used if both DB (BankBranch) and Bank.swift_code are empty.
  // No holder_id available at this level вЂ” user will see вљ пёЏ and Qt6 requires manual selection.
  const centralBankSwiftMap = {
    'DZA': 'BAALDZAL', 'AGO': 'BNANAOAA', 'BEN': 'BCEBBJ',  'BWA': 'BSBOBWGA',
    'BFA': 'BCEBBF',   'BDI': 'BRBUBI',   'CPV': 'BCVCVCV',  'CMR': 'BEACCMCX',
    'CAF': 'BCUCCF',   'TCD': 'BCECTD',   'COM': 'BCCCKM',   'COD': 'BCCECD',
    'COG': 'BCECCG',   'CIV': 'BCEACI',   'DJI': 'CBDDDJ',   'EGY': 'NBEGEGCX',
    'GNQ': 'BCECGQ',   'ERI': 'HBERER',   'SWZ': 'CBSWSZ',   'ETH': 'CBETETAA',
    'GAB': 'BCECGA',   'GMB': 'CBGMGM',   'GHA': 'BKGHGH',   'GIN': 'BCRGGNC',
    'GNB': 'BCREGW',   'KEN': 'CBKEKEN',  'LSO': 'CBLSLSMA', 'LBR': 'CBLRLR',
    'LBY': 'CBLYLYLT', 'MDG': 'BMOIMGMG', 'MWI': 'RMBKMWMW', 'MLI': 'BCEAML',
    'MRT': 'BCMRMRN',  'MUS': 'BMMUMUMU', 'MAR': 'BKAMMAMR', 'MOZ': 'BCIMMZMA',
    'NAM': 'BNNANAAA', 'NER': 'BCEANE',   'NGA': 'CBNINGLA', 'RWA': 'NBRRWRWA',
    'STP': 'BCSTP',    'SEN': 'BCEAEN',   'SYC': 'CBSCSCMA', 'SLE': 'BSLESLL',
    'SOM': 'CBBSSOM',  'ZAF': 'SARB',     'SSD': 'BSSSS',    'SDN': 'CBSUSDKH',
    'TZA': 'BKTZTZTZ', 'TGO': 'BCEATG',   'TUN': 'CBTUTNTU', 'UGA': 'BKUGUGKA',
    'ZMB': 'BKZAZALU', 'ZWE': 'RBZWZWHA',
    // 2-letter fallbacks
    'DZ': 'BAALDZAL', 'AO': 'BNANAOAA', 'BJ': 'BCEBBJ',  'BW': 'BSBOBWGA',
    'BF': 'BCEBBF',   'BI': 'BRBUBI',   'CV': 'BCVCVCV',  'CM': 'BEACCMCX',
    'CF': 'BCUCCF',   'TD': 'BCECTD',   'KM': 'BCCCKM',   'CD': 'BCCECD',
    'CG': 'BCECCG',   'CI': 'BCEACI',   'DJ': 'CBDDDJ',   'EG': 'NBEGEGCX',
    'GQ': 'BCECGQ',   'ER': 'HBERER',   'SZ': 'CBSWSZ',   'ET': 'CBETETAA',
    'GA': 'BCECGA',   'GM': 'CBGMGM',   'GH': 'BKGHGH',   'GN': 'BCRGGNC',
    'GW': 'BCREGW',   'KE': 'CBKEKEN',  'LS': 'CBLSLSMA', 'LR': 'CBLRLR',
    'LY': 'CBLYLYLT', 'MG': 'BMOIMGMG', 'MW': 'RMBKMWMW', 'ML': 'BCEAML',
    'MR': 'BCMRMRN',  'MU': 'BMMUMUMU', 'MA': 'BKAMMAMR', 'MZ': 'BCIMMZMA',
    'NA': 'BNNANAAA', 'NE': 'BCEANE',   'NG': 'CBNINGLA', 'RW': 'NBRRWRWA',
    'ST': 'BCSTP',    'SN': 'BCEAEN',   'SC': 'CBSCSCMA', 'SL': 'BSLESLL',
    'SO': 'CBBSSOM',  'ZA': 'SARB',     'SS': 'BSSSS',    'SD': 'CBSUSDKH',
    'TZ': 'BKTZTZTZ', 'TG': 'BCEATG',   'TN': 'CBTUTNTU', 'UG': 'BKUGUGKA',
    'ZM': 'BKZAZALU', 'ZW': 'RBZWZWHA',
  };

  try {
    // /api/v2/countries/by_iso3166 returns { central_bank: "Bank of Ghana", ... }
    const res = await fetch(`/api/v2/countries/by_iso3166?code=${code}`, {
      headers: {
        'Authorization': `Bearer ${getAccessToken()}`,
        'Accept': 'application/json'
      }
    });
    if (!res.ok) throw new Error(`by_iso3166 ${res.status}`);
    const data = await res.json();

    // Unwrap envelope if needed
    const payload = data.data || data;
    const cbName = payload.central_bank || payload.bank_name || payload.cb_name || null;

    // Build branch list from Rails by_iso3166 response.
    // Rails now returns: bank_branches: [{bank:, swift_code:, holder_id:}]
    // Each branch carries the central bank's holder_id (same for all branches вЂ”
    // one HolderKey entity, multiple SWIFT/BIC codes for different operations).
    //
    // Resolution order (DB first, hardcoded last):
    //   1. payload.bank_branches  вЂ” DB-sourced from BankBranch table (most accurate)
    //   2. payload.central_bank_swifts вЂ” flat array from by_iso3166 (no holder_id)
    //   3. payload.bic_swift_code / central_bank_swift вЂ” single value
    //   4. centralBankSwiftMap вЂ” hardcoded fallback (no holder_id)
    let branches = []; // [{ bank, swift_code, holder_id }]

    if (Array.isArray(payload.bank_branches) && payload.bank_branches.length) {
      // DB sourced вЂ” may already have holder_id attached
      branches = payload.bank_branches.filter(br => br.swift_code);
      // If Rails returned central_bank_holder_id at top level, attach to all branches
      if (payload.central_bank_holder_id) {
        branches = branches.map(br => ({
          ...br,
          holder_id: br.holder_id || payload.central_bank_holder_id
        }));
      }
    } else if (Array.isArray(payload.central_bank_swifts) && payload.central_bank_swifts.length) {
      branches = payload.central_bank_swifts.filter(Boolean).map(sw => ({
        bank: cbName || '', swift_code: sw, holder_id: payload.central_bank_holder_id || null
      }));
    } else {
      const single = payload.bic_swift_code || payload.central_bank_swift || null;
      if (single) branches = [{ bank: cbName || '', swift_code: single,
                                 holder_id: payload.central_bank_holder_id || null }];
    }

    // Hardcoded fallback вЂ” no holder_id (will show вљ пёЏ)
    if (!branches.length) {
      const fallback = centralBankSwiftMap[code] || centralBankSwiftMap[code.substring(0,2)];
      if (fallback) branches = [{ bank: cbName || '', swift_code: fallback, holder_id: null }];
    }

    field.value = cbName || 'вЂ”';
    field.style.color = cbName ? '#374151' : '#9ca3af';

    // Populate CB SWIFT combobox from DB data
    // Each option stores its holder_id as a data attribute so selecting
    // a SWIFT immediately updates the Central Bank Holder ID display.
    const swiftSel = document.getElementById('tc_central_bank_swift');
    if (swiftSel) {
      swiftSel.innerHTML = '<option value="">Select SWIFT...</option>';
      branches.forEach(br => {
        const opt = document.createElement('option');
        opt.value = br.swift_code;
        opt.textContent = br.swift_code;
        opt.dataset.holderId = br.holder_id || '';  // stash holder_id on the option
        swiftSel.appendChild(opt);
      });

      // Auto-select if only one SWIFT available
      if (branches.length === 1) {
        swiftSel.value = branches[0].swift_code;
        swiftSel.style.color = '#374151';
        // Immediately apply holder ID for the auto-selected option
        applyCentralBankSwiftSelection(branches[0].swift_code, branches[0].holder_id);
      } else if (branches.length > 1) {
        swiftSel.style.color = '#374151';
      }

      // Wire change event so selecting a SWIFT updates the holder ID display
      swiftSel.onchange = function() {
        const selectedOpt = swiftSel.options[swiftSel.selectedIndex];
        const holderId    = selectedOpt ? selectedOpt.dataset.holderId : '';
        applyCentralBankSwiftSelection(swiftSel.value, holderId);
      };
    }

    console.log('[loadCentralBankForCountry]', code, 'в†’', cbName,
                'branches (DB):', branches.length, branches.map(b => b.swift_code),
                'source:', payload.bank_branches ? 'DB' : 'fallback');
  } catch (e) {
    console.warn('[loadCentralBankForCountry] error:', e);
    field.value = 'вЂ”';
    field.style.color = '#9ca3af';
    const swiftSel = document.getElementById('tc_central_bank_swift');
    if (swiftSel) {
      const fallback = centralBankSwiftMap[code] || centralBankSwiftMap[(code||'').substring(0,2)];
      swiftSel.innerHTML = '<option value="">Select SWIFT...</option>';
      if (fallback) {
        swiftSel.innerHTML += `<option value="${fallback}" selected>${fallback}</option>`;
        swiftSel.style.color = '#374151';
      }
    }
  }
}

// Load commercial banks for the DESTINATION country of a corridor.
// Called from onCorridorChange with the ISO3 target country code.
// Populates the Institution Name dropdown in the Trade Details section.
async function loadInstitutionsForDestination(destCountryId, destIso3) {
  const selected = document.getElementById('institutionSelected');
  const hint     = document.getElementById('institutionHint');
  if (!selected) return;

  // Reset prior selection
  selectedInstitution = null;
  document.getElementById('tc_institution_id').value = '';
  document.getElementById('tc_swift_code').value = 'вЂ”';
  document.getElementById('tc_institution_role').value = 'Commercial Bank';

  if (!destIso3 && !destCountryId) {
    selected.innerHTML = `<span id="institutionSelectedText">Select Corridor first...</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>`;
    selected.style.background = '#f3f4f6';
    selected.style.cursor = 'not-allowed';
    hint.textContent = 'Select a corridor to load destination-country institutions.';
    return;
  }

  selected.innerHTML = `<span>Loading institutions...</span>
    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>`;
  selected.style.cursor = 'wait';

  // Build URL вЂ” prefer numeric country_id if available, fall back to ISO3 country_code
  const url = destCountryId
    ? `/api/v2/commercial_banks?country_id=${destCountryId}`
    : `/api/v2/commercial_banks?country_code=${destIso3}`;

  try {
    const res = await fetch(url, {
      headers: {
        'Authorization': `Bearer ${getAccessToken()}`,
        'Accept': 'application/json'
      }
    });
    if (!res.ok) throw new Error('Failed to load institutions');

    commercialBanksData = await res.json();
    if (!Array.isArray(commercialBanksData)) {
      commercialBanksData = commercialBanksData.data || commercialBanksData.banks || [];
    }
    renderInstitutionOptions(commercialBanksData);

    selected.style.background = 'white';
    selected.style.cursor = 'pointer';

    if (commercialBanksData.length === 0) {
      selected.innerHTML = `<span id="institutionSelectedText">No institutions found for ${destIso3}</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>`;
      hint.textContent = `No commercial banks available for ${destIso3}.`;
    } else {
      selected.innerHTML = `<span id="institutionSelectedText">Select Institution (${destIso3})...</span>
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>`;
      hint.textContent = `${commercialBanksData.length} institution(s) in ${destIso3}.`;
    }
  } catch (err) {
    console.error('[loadInstitutionsForDestination] error:', err);
    selected.innerHTML = `<span id="institutionSelectedText" style="color:#dc2626;">Error loading institutions</span>
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#6b7280" stroke-width="2"><polyline points="6 9 12 15 18 9"/></svg>`;
    hint.textContent = 'Failed to load. Please try again.';
  }
}

